{
  "name": "sad-sad",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "seed:local": "node ./scripts/seed-local.mjs",
    "seed:remote": "D1_REMOTE=1 node ./scripts/seed-local.mjs",
    "create:admin": "node ./scripts/create-admin.mjs",
    "push:vapid": "npx @pushforge/builder vapid",
    "check": "astro check && npm run build"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.10",
    "@pushforge/builder": "^2.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.7",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
