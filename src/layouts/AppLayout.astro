---
import '../styles/global.css';

type Props = {
  title: string;
};

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const isAdminRoute = pathname.startsWith('/admin') && pathname !== '/admin';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-dvh bg-[#F9FAFB] text-zinc-900 antialiased flex flex-col relative overflow-x-hidden selection:bg-sky-200 selection:text-sky-900">
    <!-- Decorative background -->
    <div class="fixed inset-0 z-[-1] pointer-events-none bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-60"></div>
    <div class="fixed top-0 inset-x-0 h-[600px] z-[-1] pointer-events-none bg-gradient-to-b from-sky-50/50 via-white/10 to-transparent"></div>

    {isAdminRoute && (
      <header class="sticky top-0 z-50 w-full border-b border-zinc-200/80 bg-white/70 backdrop-blur-xl shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)]">
        <div class="mx-auto flex h-14 w-full max-w-6xl items-center justify-between px-4">
          <div class="flex items-center gap-6">
            <a href="/admin" class="flex items-center gap-2 font-bold text-zinc-900 hover:text-[#0284C7] transition-colors" title="Volver al Inicio">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
              <span>SAD-SAD</span>
            </a>
            <nav class="hidden md:flex items-center gap-4 text-sm font-medium">
              <a href="/admin/workers" class={`hover:text-[#0284C7] transition-colors ${pathname.startsWith('/admin/workers') ? 'text-[#0284C7]' : 'text-zinc-600'}`}>Trabajadoras</a>
              <a href="/admin/users" class={`hover:text-emerald-600 transition-colors ${pathname.startsWith('/admin/users') ? 'text-emerald-600' : 'text-zinc-600'}`}>Usuarios/as</a>
              <a href="/admin/schedule/week" class={`hover:text-indigo-600 transition-colors ${pathname.startsWith('/admin/schedule') ? 'text-indigo-600' : 'text-zinc-600'}`}>Agenda</a>
              <a href="/admin/balances" class={`hover:text-zinc-900 transition-colors ${pathname.startsWith('/admin/balances') ? 'text-zinc-900' : 'text-zinc-600'}`}>Balances</a>
              <a href="/admin/holidays" class={`hover:text-orange-600 transition-colors ${pathname.startsWith('/admin/holidays') ? 'text-orange-600' : 'text-zinc-600'}`}>Festivos</a>
            </nav>
          </div>
          <div class="md:hidden flex items-center gap-3">
             <a href="/admin/workers" class="text-xs font-medium text-zinc-600 hover:text-[#0284C7]">Trab.</a>
             <a href="/admin/users" class="text-xs font-medium text-zinc-600 hover:text-emerald-600">Usua.</a>
             <a href="/admin/schedule/week" class="text-xs font-medium text-zinc-600 hover:text-indigo-600">Agen.</a>
             <a href="/admin/balances" class="text-xs font-medium text-zinc-600 hover:text-zinc-900">Bal.</a>
             <a href="/admin/holidays" class="text-xs font-medium text-zinc-600 hover:text-orange-600">Fest.</a>
          </div>
        </div>
      </header>
    )}
    <main class="mx-auto w-full max-w-6xl px-4 py-6 flex-1">
      <slot />
    </main>
  </body>
</html>
