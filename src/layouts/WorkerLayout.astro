---
import '../styles/global.css';

type TabId = 'today' | 'week' | 'travel' | 'profile';

type Props = {
  title: string;
  activeTab: TabId;
};

const { title, activeTab } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh bg-zinc-50 text-zinc-900 antialiased">
    <div class="mx-auto w-full max-w-xl px-4 pb-24 pt-6">
      <slot />
    </div>

    <nav class="fixed inset-x-0 bottom-0 z-10 border-t border-zinc-200 bg-white/95 backdrop-blur">
      <div class="mx-auto grid w-full max-w-xl grid-cols-4 px-4 py-2">
        <a
          class={`flex flex-col items-center gap-1 rounded-lg px-2 py-2 text-xs ${activeTab === 'today' ? 'text-zinc-900' : 'text-zinc-500'}`}
          href="/w/today"
        >
          <span class="text-sm">Hoy</span>
        </a>
        <a
          class={`flex flex-col items-center gap-1 rounded-lg px-2 py-2 text-xs ${activeTab === 'week' ? 'text-zinc-900' : 'text-zinc-500'}`}
          href="/w/week"
        >
          <span class="text-sm">Semana</span>
        </a>
        <a
          class={`flex flex-col items-center gap-1 rounded-lg px-2 py-2 text-xs ${activeTab === 'travel' ? 'text-zinc-900' : 'text-zinc-500'}`}
          href="/w/travel"
        >
          <span class="text-sm">Viajes</span>
        </a>
        <a
          class={`flex flex-col items-center gap-1 rounded-lg px-2 py-2 text-xs ${activeTab === 'profile' ? 'text-zinc-900' : 'text-zinc-500'}`}
          href="/w/profile"
        >
          <span class="text-sm">Perfil</span>
        </a>
      </div>
    </nav>
  </body>
</html>

