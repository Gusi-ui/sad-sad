---
import AppLayout from '../layouts/AppLayout.astro';
import { getSessionAccount } from '../lib/auth';

const error = Astro.url.searchParams.get('error');

const existingAccount = await getSessionAccount(Astro as never);
if (existingAccount) {
  return Astro.redirect(existingAccount.role === 'ADMIN' ? '/admin' : '/w/today');
}
---

<AppLayout title="Login | SAD">
  <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
    <div class="rounded-2xl bg-zinc-900 p-6 text-white">
      <h1 class="text-2xl font-semibold tracking-tight">SAD</h1>
      <p class="mt-2 text-sm text-zinc-200">
        Acceso para administración y trabajadoras. En el MVP el login se hace con email y contraseña.
      </p>
      <ul class="mt-6 space-y-2 text-sm text-zinc-200">
        <li><span class="font-medium text-white">Admin:</span> planificación, sustituciones, festivos, revisión semanal</li>
        <li><span class="font-medium text-white">Trabajadora:</span> agenda, fichajes, desplazamientos, balance</li>
      </ul>
    </div>

    <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold">Iniciar sesión</h2>

      {error ? (
        <div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800" role="alert">
          Credenciales incorrectas o cuenta inactiva.
        </div>
      ) : null}

      <form class="mt-4 space-y-4" method="post" action="/api/auth/login">
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Email</span>
          <input
            class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none ring-zinc-900 focus:ring-2"
            type="email"
            name="email"
            autocomplete="email"
            required
          />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Contraseña</span>
          <input
            class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none ring-zinc-900 focus:ring-2"
            type="password"
            name="password"
            autocomplete="current-password"
            required
          />
        </label>

        <button class="inline-flex w-full items-center justify-center rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white">
          Entrar
        </button>
      </form>

      <p class="mt-4 text-xs text-zinc-500">
        Nota: en producción, el secreto de sesión debe ir como “secret” en Cloudflare.
      </p>
    </div>
  </div>
</AppLayout>

