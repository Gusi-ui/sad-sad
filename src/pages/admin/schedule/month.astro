---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { toYmd } from '../../../lib/dates';

export const prerender = false;

const database = db();

const now = new Date();
const defaultMonth = `${now.getUTCFullYear()}-${String(now.getUTCMonth() + 1).padStart(2, '0')}`;
const monthParam = String(Astro.url.searchParams.get('month') ?? defaultMonth);
const [yRaw, mRaw] = monthParam.split('-');
const year = Number(yRaw);
const month = Number(mRaw);
const safeYear = Number.isFinite(year) ? year : now.getUTCFullYear();
const safeMonth = Number.isFinite(month) && month >= 1 && month <= 12 ? month : now.getUTCMonth() + 1;
const safeMonthKey = `${safeYear}-${String(safeMonth).padStart(2, '0')}`;

const selectedUserIdRaw = String(Astro.url.searchParams.get('userId') ?? '').trim();
const selectedWorkerIdRaw = String(Astro.url.searchParams.get('workerId') ?? '').trim();
const selectedUserId = selectedUserIdRaw === '' ? null : selectedUserIdRaw;
const selectedWorkerId = selectedWorkerIdRaw === '' ? null : selectedWorkerIdRaw;
const selectedDayRaw = String(Astro.url.searchParams.get('day') ?? '').trim();
const selectedDay = selectedDayRaw === '' ? null : selectedDayRaw;

const toMinutes = (hhmm: string) => {
  const [hRaw, mRaw] = hhmm.split(':');
  const h = Number(hRaw);
  const m = Number(mRaw);
  if (!Number.isFinite(h) || !Number.isFinite(m)) return 0;
  return h * 60 + m;
};
const minutesToHours = (m: number) => m / 60;
const formatHours = (hours: number) => {
  const sign = hours < 0 ? '-' : '';
  const abs = Math.abs(hours);
  const totalMinutes = Math.round(abs * 60);
  const h = Math.floor(totalMinutes / 60);
  const mm = totalMinutes % 60;
  return `${sign}${h}h ${String(mm).padStart(2, '0')}m`;
};

const getWeekRangeYmd = (ymd: string) => {
  const base = new Date(`${ymd}T00:00:00Z`);
  const jsDow = base.getUTCDay();
  const mondayShift = (jsDow + 6) % 7;
  const monday = new Date(base);
  monday.setUTCDate(base.getUTCDate() - mondayShift);
  const sunday = new Date(monday);
  sunday.setUTCDate(monday.getUTCDate() + 6);
  return { start: toYmd(monday), end: toYmd(sunday) };
};

const monthStart = new Date(Date.UTC(safeYear, safeMonth - 1, 1));
const monthEnd = new Date(Date.UTC(safeYear, safeMonth, 0));
const startYmd = toYmd(monthStart);
const endYmd = toYmd(monthEnd);

const users = await database
  .prepare(`SELECT id, name FROM service_users WHERE active = 1 ORDER BY name ASC`)
  .all<{ id: string; name: string }>();
const workers = await database
  .prepare(`SELECT id, name FROM workers WHERE active = 1 ORDER BY name ASC`)
  .all<{ id: string; name: string }>();

const allAssignments = await database
  .prepare(
    `SELECT a.id, a.date, a.kind, a.planned_start, a.planned_end,
            su.id as user_id, su.name as user_name,
            w.id as worker_id, w.name as worker_name
     FROM assignments a
     JOIN service_users su ON su.id = a.service_user_id
     LEFT JOIN workers w ON w.id = a.assigned_worker_id
     WHERE a.date >= ? AND a.date <= ? AND a.status != 'cancelled'
     ORDER BY a.date ASC, a.planned_start ASC, su.name ASC`
  )
  .bind(startYmd, endYmd)
  .all<{
    id: string;
    date: string;
    kind: string;
    planned_start: string;
    planned_end: string;
    user_id: string;
    user_name: string;
    worker_id: string | null;
    worker_name: string | null;
  }>();

const selectedUserInfo = selectedUserId
  ? await database
      .prepare(`SELECT id, name, monthly_hours_quota FROM service_users WHERE id = ? LIMIT 1`)
      .bind(selectedUserId)
      .first<{ id: string; name: string; monthly_hours_quota: number | null }>()
  : null;

const selectedWorkerInfo = selectedWorkerId
  ? await database
      .prepare(`SELECT id, name FROM workers WHERE id = ? LIMIT 1`)
      .bind(selectedWorkerId)
      .first<{ id: string; name: string }>()
  : null;

const selectedWorkerContract = selectedWorkerId
  ? await database
      .prepare(
        `SELECT hours_per_week, hours_per_month
         FROM worker_contracts
         WHERE worker_id = ?
           AND start_date <= ?
           AND (end_date IS NULL OR end_date >= ?)
         ORDER BY start_date DESC
         LIMIT 1`
      )
      .bind(selectedWorkerId, endYmd, startYmd)
      .first<{ hours_per_week: number; hours_per_month: number | null }>()
  : null;

const realUserMinutes = selectedUserId
  ? allAssignments.results
      .filter((a) => a.user_id === selectedUserId)
      .reduce((acc, a) => acc + Math.max(0, toMinutes(a.planned_end) - toMinutes(a.planned_start)), 0)
  : 0;
const realUserHours = minutesToHours(realUserMinutes);
const userQuota = selectedUserInfo?.monthly_hours_quota ?? null;
const userDelta = userQuota !== null ? realUserHours - userQuota : null;

const realWorkerMinutes = selectedWorkerId
  ? allAssignments.results
      .filter((a) => a.worker_id === selectedWorkerId)
      .reduce((acc, a) => acc + Math.max(0, toMinutes(a.planned_end) - toMinutes(a.planned_start)), 0)
  : 0;
const realWorkerHours = minutesToHours(realWorkerMinutes);
const workerMonthTargetExplicit = selectedWorkerContract?.hours_per_month ?? null;
const workerWeekTarget = selectedWorkerContract?.hours_per_week ?? null;
const daysInMonth = monthEnd.getUTCDate();
const avgWeekHoursRealWorker = daysInMonth > 0 ? (realWorkerHours * 7) / daysInMonth : 0;
const workerMonthTargetFromWeek = workerWeekTarget !== null ? (workerWeekTarget * daysInMonth) / 7 : null;
const workerMonthTarget = workerMonthTargetExplicit ?? workerMonthTargetFromWeek;
const workerDeltaMonth = workerMonthTarget !== null ? realWorkerHours - workerMonthTarget : null;
const workerDeltaWeek = workerWeekTarget !== null ? avgWeekHoursRealWorker - workerWeekTarget : null;

const query = `
  SELECT a.id, a.date, a.kind, a.template_id, a.planned_start, a.planned_end,
         su.id as user_id, su.name as user_name,
         w.id as worker_id, w.name as worker_name
  FROM assignments a
  JOIN service_users su ON su.id = a.service_user_id
  LEFT JOIN workers w ON w.id = a.assigned_worker_id
  WHERE a.date >= ? AND a.date <= ?
    AND (? IS NULL OR su.id = ?)
    AND (? IS NULL OR w.id = ?)
    AND a.status != 'cancelled'
  ORDER BY a.date ASC, a.planned_start ASC, su.name ASC
`;
const assignments = await database
  .prepare(query)
  .bind(startYmd, endYmd, selectedUserId, selectedUserId, selectedWorkerId, selectedWorkerId)
  .all<{
    id: string;
    date: string;
    kind: string;
    template_id: string | null;
    planned_start: string;
    planned_end: string;
    user_id: string;
    user_name: string;
    worker_id: string | null;
    worker_name: string | null;
  }>();

const holidayRows = await database
  .prepare(`SELECT date FROM holidays WHERE date >= ? AND date <= ? AND scope IN ('national','catalonia','barcelona','mataro')`)
  .bind(startYmd, endYmd)
  .all<{ date: string }>();
const holidaySet = new Set(holidayRows.results.map((r) => r.date));

const templates = await database
  .prepare(
    `SELECT t.id, t.service_user_id, t.kind, t.weekday, t.start_time, t.end_time, t.preferred_worker_id,
            su.name as user_name
     FROM service_templates t
     JOIN service_users su ON su.id = t.service_user_id
     WHERE (? IS NULL OR su.id = ?)
     ORDER BY su.name ASC, t.start_time ASC`
  )
  .bind(selectedUserId, selectedUserId)
  .all<{
    id: string;
    service_user_id: string;
    kind: 'laborable' | 'festivo';
    weekday: number | null;
    start_time: string;
    end_time: string;
    preferred_worker_id: string | null;
    user_name: string;
  }>();

const workersById = new Map(workers.results.map((w) => [w.id, w.name]));

const assignmentWorkerVotes = await database
  .prepare(
    `SELECT template_id, assigned_worker_id, COUNT(*) AS c
     FROM assignments
     WHERE date >= ? AND date <= ?
       AND template_id IS NOT NULL
       AND assigned_worker_id IS NOT NULL
       AND status != 'cancelled'
     GROUP BY template_id, assigned_worker_id`
  )
  .bind(startYmd, endYmd)
  .all<{ template_id: string; assigned_worker_id: string; c: number }>();

const templateWorkerMap = new Map<string, { workerId: string; count: number }>();
for (const v of assignmentWorkerVotes.results) {
  const prev = templateWorkerMap.get(v.template_id);
  if (!prev || v.c > prev.count) {
    templateWorkerMap.set(v.template_id, { workerId: v.assigned_worker_id, count: v.c });
  }
}

const dayKindOf = (ymd: string) => {
  const d = new Date(`${ymd}T00:00:00Z`);
  const weekday = d.getUTCDay();
  const isWeekend = weekday === 0 || weekday === 6;
  if (holidaySet.has(ymd)) return 'festivo' as const;
  if (isWeekend) return 'fin_semana' as const;
  return 'laborable' as const;
};

const templateApplies = (
  t: { kind: 'laborable' | 'festivo'; weekday: number | null },
  ymd: string
) => {
  const d = new Date(`${ymd}T00:00:00Z`);
  const weekday = d.getUTCDay();
  const dayKind = dayKindOf(ymd);
  if (dayKind === 'laborable') {
    if (t.kind !== 'laborable') return false;
    if (t.weekday === null) return true;
    return t.weekday === weekday;
  }
  if (t.kind !== 'festivo') return false;
  if (t.weekday === null) return true;
  return t.weekday === weekday;
};

const totalDays = monthEnd.getUTCDate();
const mondayIndex = (monthStart.getUTCDay() + 6) % 7;
const cells: Array<{ ymd: string | null; day: number | null }> = [];
for (let i = 0; i < mondayIndex; i += 1) cells.push({ ymd: null, day: null });
for (let day = 1; day <= totalDays; day += 1) {
  const ymd = `${safeYear}-${String(safeMonth).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  cells.push({ ymd, day });
}
while (cells.length % 7 !== 0) cells.push({ ymd: null, day: null });

const prevMonth = new Date(Date.UTC(safeYear, safeMonth - 2, 1));
const nextMonth = new Date(Date.UTC(safeYear, safeMonth, 1));
const prevMonthKey = `${prevMonth.getUTCFullYear()}-${String(prevMonth.getUTCMonth() + 1).padStart(2, '0')}`;
const nextMonthKey = `${nextMonth.getUTCFullYear()}-${String(nextMonth.getUTCMonth() + 1).padStart(2, '0')}`;

const monthLabel = new Date(Date.UTC(safeYear, safeMonth - 1, 1)).toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });
const buildQuery = (monthKey: string, dayKey?: string) => {
  const p = new URLSearchParams();
  p.set('month', monthKey);
  if (selectedUserId) p.set('userId', selectedUserId);
  if (selectedWorkerId) p.set('workerId', selectedWorkerId);
  if (dayKey) p.set('day', dayKey);
  return `/admin/schedule/month?${p.toString()}`;
};

const clearFilterQuery = () => {
  const p = new URLSearchParams();
  p.set('month', safeMonthKey);
  return `/admin/schedule/month?${p.toString()}`;
};

const mergedByDate = new Map<string, Array<{
  id: string;
  date: string;
  kind: string;
  planned_start: string;
  planned_end: string;
  user_id: string;
  user_name: string;
  worker_id: string | null;
  worker_name: string | null;
  template_id: string | null;
  source: 'assignment' | 'projection';
}>>();

for (let day = 1; day <= monthEnd.getUTCDate(); day += 1) {
  const ymd = `${safeYear}-${String(safeMonth).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  const dayAssignments = (assignments.results.filter((a) => a.date === ymd)).map((a) => ({ ...a, source: 'assignment' as const }));
  const existingTemplateIds = new Set(dayAssignments.map((a) => a.template_id).filter(Boolean));
  const projections: Array<{
    id: string;
    date: string;
    kind: string;
    planned_start: string;
    planned_end: string;
    user_id: string;
    user_name: string;
    worker_id: string | null;
    worker_name: string | null;
    template_id: string | null;
    source: 'projection';
  }> = [];

  for (const t of templates.results) {
    if (!templateApplies(t, ymd)) continue;
    if (existingTemplateIds.has(t.id)) continue;
    const voted = templateWorkerMap.get(t.id)?.workerId ?? null;
    const fallbackPref = t.preferred_worker_id;
    const workerId = voted ?? fallbackPref ?? null;
    if (selectedWorkerId && workerId !== selectedWorkerId) continue;
    projections.push({
      id: `projection:${t.id}:${ymd}`,
      date: ymd,
      kind: dayKindOf(ymd),
      planned_start: t.start_time,
      planned_end: t.end_time,
      user_id: t.service_user_id,
      user_name: t.user_name,
      worker_id: workerId,
      worker_name: workerId ? workersById.get(workerId) ?? null : null,
      template_id: t.id,
      source: 'projection',
    });
  }

  const merged = [...dayAssignments, ...projections].sort((a, b) =>
    a.planned_start.localeCompare(b.planned_start) || a.user_name.localeCompare(b.user_name)
  );
  mergedByDate.set(ymd, merged);
}

const selectedItems = selectedDay ? mergedByDate.get(selectedDay) ?? [] : [];
const mergedMonthCount = Array.from(mergedByDate.values()).reduce((acc, arr) => acc + arr.length, 0);

const userTheoreticalMinutes = selectedUserId
  ? Array.from(mergedByDate.values())
      .flatMap((rows) => rows)
      .filter((r) => r.user_id === selectedUserId)
      .reduce((acc, r) => acc + Math.max(0, toMinutes(r.planned_end) - toMinutes(r.planned_start)), 0)
  : 0;
const userTheoreticalHours = minutesToHours(userTheoreticalMinutes);
const userTheoreticalDelta = userQuota !== null ? userTheoreticalHours - userQuota : null;

const referenceYmd = selectedDay ?? startYmd;
const weekRef = getWeekRangeYmd(referenceYmd);
const userWeekRealMinutes = selectedUserId
  ? allAssignments.results
      .filter((a) => a.user_id === selectedUserId && a.date >= weekRef.start && a.date <= weekRef.end)
      .reduce((acc, a) => acc + Math.max(0, toMinutes(a.planned_end) - toMinutes(a.planned_start)), 0)
  : 0;
const workerWeekRealMinutes = selectedWorkerId
  ? allAssignments.results
      .filter((a) => a.worker_id === selectedWorkerId && a.date >= weekRef.start && a.date <= weekRef.end)
      .reduce((acc, a) => acc + Math.max(0, toMinutes(a.planned_end) - toMinutes(a.planned_start)), 0)
  : 0;
const userDayMinutes = selectedUserId
  ? selectedItems
      .filter((a) => a.user_id === selectedUserId)
      .reduce((acc, a) => acc + Math.max(0, toMinutes(a.planned_end) - toMinutes(a.planned_start)), 0)
  : 0;
const workerDayMinutes = selectedWorkerId
  ? selectedItems
      .filter((a) => a.worker_id === selectedWorkerId)
      .reduce((acc, a) => acc + Math.max(0, toMinutes(a.planned_end) - toMinutes(a.planned_start)), 0)
  : 0;
---

<AppLayout title="Agenda mensual | Admin">
  <div class="flex items-center justify-between border-b border-zinc-200 pb-4">
    <div>
      <div class="flex items-center gap-2">
        <a class="text-sm font-medium text-zinc-500 hover:text-zinc-800 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-400">/</span>
        <a class="text-sm font-medium text-zinc-500 hover:text-zinc-800 transition-colors" href="/admin/schedule/week">Agenda semanal</a>
        <span class="text-zinc-400">/</span>
        <span class="text-sm font-medium text-zinc-800">Agenda mensual</span>
      </div>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-zinc-900">Agenda Mensual</h1>
      <p class="mt-1 text-sm text-zinc-600">Calendario operativo para ver el mes completo por usuario o trabajadora.</p>
    </div>
    <a href="/admin/schedule/week" class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium hover:bg-zinc-50 transition-colors">Volver a semana</a>
  </div>

  <form method="get" class="mt-6 grid gap-3 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm md:grid-cols-4">
    <label class="block">
      <span class="text-sm font-medium text-zinc-700">Mes</span>
      <input type="month" name="month" value={safeMonthKey} class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" />
    </label>
    <label class="block">
      <span class="text-sm font-medium text-zinc-700">Usuario/a</span>
      <select name="userId" class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm">
        <option value="">Todos</option>
        {users.results.map((u) => (
          <option value={u.id} selected={selectedUserId === u.id}>{u.name}</option>
        ))}
      </select>
    </label>
    <label class="block">
      <span class="text-sm font-medium text-zinc-700">Trabajadora</span>
      <select name="workerId" class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm">
        <option value="">Todas</option>
        {workers.results.map((w) => (
          <option value={w.id} selected={selectedWorkerId === w.id}>{w.name}</option>
        ))}
      </select>
    </label>
    <div class="flex items-end gap-2">
      <button class="w-full rounded-lg bg-zinc-900 px-4 py-2 text-sm font-semibold text-white">Aplicar</button>
      <a href={clearFilterQuery()} class="rounded-lg border border-red-300 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100 whitespace-nowrap">Limpiar filtros</a>
    </div>
  </form>

  <div class="mt-6 flex items-center justify-between">
    <a href={buildQuery(prevMonthKey)} class="rounded-lg border border-zinc-300 bg-white px-3 py-1.5 text-sm hover:bg-zinc-50">← Mes anterior</a>
    <h2 class="text-lg font-semibold capitalize">{monthLabel}</h2>
    <a href={buildQuery(nextMonthKey)} class="rounded-lg border border-zinc-300 bg-white px-3 py-1.5 text-sm hover:bg-zinc-50">Mes siguiente →</a>
  </div>

  <div class="mt-3 text-xs text-zinc-600">
    Servicios del mes (totales): <span class="font-semibold text-zinc-800">{mergedMonthCount}</span>
    {selectedUserId || selectedWorkerId ? (
      <>
        {' '}· Filtrados en vista: <span class="font-semibold text-zinc-800">{mergedMonthCount}</span>
      </>
    ) : null}
  </div>

  {(selectedUserInfo || selectedWorkerInfo) && (
    <section class="mt-4 grid gap-3 md:grid-cols-2">
      {selectedUserInfo && (
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-4">
          <div class="text-xs text-emerald-700">Cómputo mensual usuario (real + teórico)</div>
          <div class="mt-1 text-base font-semibold text-emerald-900">{selectedUserInfo.name}</div>
          <div class="mt-2 text-sm text-emerald-900">Día seleccionado: <span class="font-semibold">{formatHours(minutesToHours(userDayMinutes))}</span></div>
          <div class="text-sm text-emerald-900">Semana de referencia ({weekRef.start} → {weekRef.end}): <span class="font-semibold">{formatHours(minutesToHours(userWeekRealMinutes))}</span></div>
          <div class="text-sm text-emerald-900">Mes real (asignaciones guardadas): <span class="font-semibold">{formatHours(realUserHours)}</span></div>
          <div class="text-sm text-emerald-900">Mes teórico (si se realizan todos los servicios del mes): <span class="font-semibold">{formatHours(userTheoreticalHours)}</span></div>
          <div class="text-sm text-emerald-900">Cuota ayuntamiento: <span class="font-semibold">{userQuota !== null ? formatHours(userQuota) : 'No definida'}</span></div>
          <div class={`mt-2 text-sm font-semibold ${userDelta === null ? 'text-emerald-800' : userDelta > 0.02 ? 'text-amber-700' : userDelta < -0.02 ? 'text-blue-700' : 'text-emerald-700'}`}>
            {userDelta === null
              ? 'Sin cuota mensual configurada'
              : userDelta > 0.02
                ? `Mes real: sobran ${formatHours(userDelta)}`
                : userDelta < -0.02
                  ? `Mes real: faltan ${formatHours(Math.abs(userDelta))}`
                  : 'Mes real en equilibrio'}
          </div>
          <div class={`mt-1 text-sm font-semibold ${userTheoreticalDelta === null ? 'text-emerald-800' : userTheoreticalDelta > 0.02 ? 'text-amber-700' : userTheoreticalDelta < -0.02 ? 'text-blue-700' : 'text-emerald-700'}`}>
            {userTheoreticalDelta === null
              ? 'Sin cuota mensual configurada'
              : userTheoreticalDelta > 0.02
                ? `Mes teórico: sobran ${formatHours(userTheoreticalDelta)}`
                : userTheoreticalDelta < -0.02
                  ? `Mes teórico: faltan ${formatHours(Math.abs(userTheoreticalDelta))}`
                  : 'Mes teórico en equilibrio'}
          </div>
        </div>
      )}
      {selectedWorkerInfo && (
        <div class="rounded-2xl border border-sky-200 bg-sky-50 p-4">
          <div class="text-xs text-sky-700">Cómputo trabajadora (día/semana/mes)</div>
          <div class="mt-1 text-base font-semibold text-sky-900">{selectedWorkerInfo.name}</div>
          <div class="mt-2 text-sm text-sky-900">Día seleccionado: <span class="font-semibold">{formatHours(minutesToHours(workerDayMinutes))}</span></div>
          <div class="text-sm text-sky-900">Semana de referencia ({weekRef.start} → {weekRef.end}): <span class="font-semibold">{formatHours(minutesToHours(workerWeekRealMinutes))}</span></div>
          <div class="text-sm text-sky-900">Mes real: <span class="font-semibold">{formatHours(realWorkerHours)}</span></div>
          <div class="text-sm text-sky-900">Objetivo mensual contrato: <span class="font-semibold">{workerMonthTarget !== null ? formatHours(workerMonthTarget) : 'No definido'}</span>{workerMonthTargetExplicit === null && workerMonthTargetFromWeek !== null ? ' (derivado de h/sem)' : ''}</div>
          <div class="text-sm text-sky-900">Media semanal real: <span class="font-semibold">{formatHours(avgWeekHoursRealWorker)}</span> {workerWeekTarget !== null ? `· objetivo ${formatHours(workerWeekTarget)}/sem` : ''}</div>
          <div class={`mt-2 text-sm font-semibold ${
            workerDeltaMonth !== null
              ? workerDeltaMonth > 0.02 ? 'text-amber-700' : workerDeltaMonth < -0.02 ? 'text-blue-700' : 'text-emerald-700'
              : workerDeltaWeek !== null
                ? workerDeltaWeek > 0.02 ? 'text-amber-700' : workerDeltaWeek < -0.02 ? 'text-blue-700' : 'text-emerald-700'
                : 'text-sky-800'
          }`}>
            {workerDeltaMonth !== null
              ? workerDeltaMonth > 0.02
                ? `Sobra ${formatHours(workerDeltaMonth)} frente al mes`
                : workerDeltaMonth < -0.02
                  ? `Faltan ${formatHours(Math.abs(workerDeltaMonth))} frente al mes`
                  : 'Objetivo mensual en equilibrio'
              : workerDeltaWeek !== null
                ? workerDeltaWeek > 0.02
                  ? `Sobra ${formatHours(workerDeltaWeek)}/sem de media`
                  : workerDeltaWeek < -0.02
                    ? `Faltan ${formatHours(Math.abs(workerDeltaWeek))}/sem de media`
                    : 'Objetivo semanal en equilibrio'
                : 'Sin contrato para comparar'}
          </div>
        </div>
      )}
    </section>
  )}

  <section class="mt-4 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
    <div class="grid grid-cols-7 gap-2 text-center text-xs font-semibold uppercase text-zinc-500">
      <div>Lun</div><div>Mar</div><div>Mié</div><div>Jue</div><div>Vie</div><div>Sáb</div><div>Dom</div>
    </div>
    <div class="mt-2 grid grid-cols-7 gap-2">
      {cells.map((c) => {
        if (!c.ymd || !c.day) return <div class="min-h-[88px] rounded-lg bg-zinc-50" />;
        const items = mergedByDate.get(c.ymd) ?? [];
        const isHoliday = holidaySet.has(c.ymd);
        const weekday = new Date(`${c.ymd}T00:00:00Z`).getUTCDay();
        const isWeekend = weekday === 0 || weekday === 6;
        const isSelected = selectedDay === c.ymd;
        return (
          <a
            href={buildQuery(safeMonthKey, c.ymd)}
            class={`min-h-[88px] rounded-lg border p-2 transition-colors ${
              isSelected
                ? 'border-indigo-500 bg-indigo-50'
                : (isHoliday || isWeekend)
                  ? 'border-red-300 bg-red-50'
                  : 'border-zinc-200 hover:bg-zinc-50'
            }`}
          >
            <div class="flex items-center justify-between">
              <span class="text-sm font-semibold text-zinc-800">{c.day}</span>
            </div>
            <div class="mt-3 flex items-center justify-center">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-300 bg-white text-sm font-semibold text-zinc-800">
                {items.length}
              </div>
            </div>
            <div class="mt-3 flex items-center gap-1">
              <span class="h-2 w-2 rounded-full bg-blue-500" title="Día con planificación mensual"></span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-zinc-600">
    <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-blue-500"></span> Día del calendario</span>
    <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-red-500"></span> Festivo / Fin de semana</span>
    <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-zinc-400"></span> Laborable</span>
  </div>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
    <h3 class="text-sm font-semibold">Servicios del día {selectedDay ? selectedDay : '—'}</h3>
    <div class="mt-3 overflow-x-auto">
      <table class="w-full min-w-[680px] text-left text-sm">
        <thead class="text-xs uppercase text-zinc-500">
          <tr>
            <th class="px-3 py-2">Horario</th>
            <th class="px-3 py-2">Usuario/a</th>
            <th class="px-3 py-2">Tipo</th>
            <th class="px-3 py-2">Trabajadora</th>
            <th class="px-3 py-2">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          {selectedItems.map((it) => (
            <tr>
              <td class="px-3 py-2 font-medium text-[#4B79A1]">{it.planned_start} - {it.planned_end}</td>
              <td class="px-3 py-2 font-semibold text-emerald-700">{it.user_name}</td>
              <td class="px-3 py-2"><span class="rounded bg-zinc-100 px-2 py-0.5 text-xs capitalize">{it.kind}</span></td>
              <td class="px-3 py-2 text-zinc-700">{it.worker_name ?? 'Sin asignar'}</td>
              <td class="px-3 py-2">
                <span class={`rounded px-2 py-0.5 text-xs font-medium ${it.source === 'assignment' ? 'bg-emerald-100 text-emerald-700' : 'bg-indigo-100 text-indigo-700'}`}>
                  {it.source === 'assignment' ? 'Real' : 'Proyección'}
                </span>
              </td>
            </tr>
          ))}
          {selectedItems.length === 0 && (
            <tr>
              <td colspan="5" class="px-3 py-6 text-center text-zinc-500 italic">
                Selecciona un día del calendario para ver sus servicios.
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>
</AppLayout>
