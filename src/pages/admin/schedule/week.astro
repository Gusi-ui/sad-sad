---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { datesOfIsoWeek, getIsoWeekKey, toYmd } from '../../../lib/dates';
import { randomId } from '../../../lib/crypto';

export const prerender = false;

const currentWeek = getIsoWeekKey(new Date());
const weekKey = String(Astro.url.searchParams.get('week') ?? currentWeek);
const weekDates = datesOfIsoWeek(weekKey);
if (!weekDates) return Astro.redirect(`/admin/schedule/week?week=${currentWeek}`);

const database = db();

const holidayScopes = ['national', 'catalonia', 'barcelona', 'mataro'] as const;

const timeToMinutes = (hhmm: string) => {
  const [hRaw, mRaw] = hhmm.split(':');
  const h = Number(hRaw);
  const m = Number(mRaw);
  if (!Number.isFinite(h) || !Number.isFinite(m)) return null;
  if (h < 0 || h > 23 || m < 0 || m > 59) return null;
  return h * 60 + m;
};

const overlaps = (aStart: number, aEnd: number, bStart: number, bEnd: number) => aStart < bEnd && bStart < aEnd;

const getDayKind = async (dateYmd: string, weekday0to6: number) => {
  const isWeekend = weekday0to6 === 0 || weekday0to6 === 6;
  const holiday = await database
    .prepare(`SELECT 1 FROM holidays WHERE date = ? AND scope IN (${holidayScopes.map(() => '?').join(',')}) LIMIT 1`)
    .bind(dateYmd, ...holidayScopes)
    .first();
  if (holiday) return 'festivo' as const;
  if (isWeekend) return 'fin_semana' as const;
  return 'laborable' as const;
};

const matchesWorkerType = (required: string | null, workerType: 'laborable' | 'festivo' | 'ambos') => {
  const req = required ?? 'ambos';
  if (req === 'ambos') return true;
  if (workerType === 'ambos') return true;
  return workerType === req;
};

const autoAssignWeekRange = async (startYmd: string, endYmd: string) => {
  const workers = await database
    .prepare(`SELECT id, name, worker_type FROM workers WHERE active = 1 ORDER BY name ASC`)
    .all<{ id: string; name: string; worker_type: 'laborable' | 'festivo' | 'ambos' }>();
  if (workers.results.length === 0) return;

  const userPrefs = await database
    .prepare(`SELECT id, preferred_worker_id, preferred_weekend_worker_id FROM service_users`)
    .all<{ id: string; preferred_worker_id: string | null; preferred_weekend_worker_id: string | null }>();
  const prefsMap = new Map<string, { preferred_worker_id: string | null; preferred_weekend_worker_id: string | null }>();
  for (const p of userPrefs.results) prefsMap.set(p.id, p);

  const weekAssignments = await database
    .prepare(
      `SELECT a.id, a.date, a.kind, a.planned_start, a.planned_end, a.service_user_id, a.assigned_worker_id,
              t.required_worker_type
       FROM assignments a
       LEFT JOIN service_templates t ON t.id = a.template_id
       WHERE a.date >= ? AND a.date <= ? AND a.status != 'cancelled'
       ORDER BY a.date ASC, a.planned_start ASC, a.id ASC`
    )
    .bind(startYmd, endYmd)
    .all<{
      id: string;
      date: string;
      kind: string;
      planned_start: string;
      planned_end: string;
      service_user_id: string;
      assigned_worker_id: string | null;
      required_worker_type: string | null;
    }>();

  const workerIntervalsByDate = new Map<string, { start: number; end: number }[]>();
  const workerLoadMinutes = new Map<string, number>();
  for (const a of weekAssignments.results) {
    if (!a.assigned_worker_id) continue;
    const start = timeToMinutes(a.planned_start);
    const end = timeToMinutes(a.planned_end);
    if (start === null || end === null) continue;
    const key = `${a.assigned_worker_id}|${a.date}`;
    const arr = workerIntervalsByDate.get(key) ?? [];
    arr.push({ start, end });
    workerIntervalsByDate.set(key, arr);
    workerLoadMinutes.set(a.assigned_worker_id, (workerLoadMinutes.get(a.assigned_worker_id) ?? 0) + Math.max(0, end - start));
  }

  for (const a of weekAssignments.results.filter((x) => !x.assigned_worker_id)) {
    const start = timeToMinutes(a.planned_start);
    const end = timeToMinutes(a.planned_end);
    if (start === null || end === null) continue;

    const pref = prefsMap.get(a.service_user_id);
    const habitualWorkerId = a.kind === 'laborable'
      ? pref?.preferred_worker_id ?? null
      : pref?.preferred_weekend_worker_id ?? pref?.preferred_worker_id ?? null;

    const candidates = workers.results
      .map((w) => {
        const key = `${w.id}|${a.date}`;
        const intervals = workerIntervalsByDate.get(key) ?? [];
        const available = !intervals.some((it) => overlaps(start, end, it.start, it.end));
        const compatible = matchesWorkerType(a.required_worker_type, w.worker_type);
        const habitual = habitualWorkerId === w.id;
        const loadMinutes = workerLoadMinutes.get(w.id) ?? 0;
        return { w, available, compatible, habitual, loadMinutes };
      })
      .sort((x, y) =>
        Number(y.compatible) - Number(x.compatible) ||
        Number(y.available) - Number(x.available) ||
        Number(y.habitual) - Number(x.habitual) ||
        x.loadMinutes - y.loadMinutes ||
        x.w.name.localeCompare(y.w.name)
      );

    const pick = candidates.find((c) => c.compatible && c.available)
      ?? candidates.find((c) => c.available)
      ?? candidates.find((c) => c.compatible)
      ?? candidates[0];
    if (!pick) continue;

    await database.prepare(`UPDATE assignments SET assigned_worker_id = ? WHERE id = ?`).bind(pick.w.id, a.id).run();
    const key = `${pick.w.id}|${a.date}`;
    const arr = workerIntervalsByDate.get(key) ?? [];
    arr.push({ start, end });
    workerIntervalsByDate.set(key, arr);
    workerLoadMinutes.set(pick.w.id, (workerLoadMinutes.get(pick.w.id) ?? 0) + Math.max(0, end - start));
  }
};

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('_action') ?? 'generate');

  if (action === 'assign') {
    const assignmentId = String(formData.get('assignmentId') ?? '').trim();
    const workerIdRaw = String(formData.get('workerId') ?? '').trim();
    const workerId = workerIdRaw === '' ? null : workerIdRaw;

    if (assignmentId) {
      await database
        .prepare(`UPDATE assignments SET assigned_worker_id = ? WHERE id = ?`)
        .bind(workerId, assignmentId)
        .run();
    }
    return Astro.redirect(`/admin/schedule/week?week=${weekKey}`);
  }

  if (action === 'auto_assign') {
    await autoAssignWeekRange(toYmd(new Date(weekDates[0])), toYmd(new Date(weekDates[6])));
    return Astro.redirect(`/admin/schedule/week?week=${weekKey}`);
  }

  if (action === 'regenerate_week') {
    await database
      .prepare(`DELETE FROM assignments WHERE source = 'template' AND status != 'done' AND date >= ? AND date <= ?`)
      .bind(toYmd(new Date(weekDates[0])), toYmd(new Date(weekDates[6])))
      .run();
  }

  const dates = weekDates.map((d) => ({ d, ymd: toYmd(new Date(d)) }));

  const users = await database
    .prepare(`SELECT id, name FROM service_users WHERE active = 1 ORDER BY created_at ASC`)
    .all<{ id: string; name: string }>();

  const templates = await database
    .prepare(
      `SELECT id, service_user_id, kind, weekday, start_time, end_time
       FROM service_templates
       ORDER BY service_user_id ASC, kind ASC, weekday ASC, start_time ASC`
    )
    .all<{ id: string; service_user_id: string; kind: 'laborable' | 'festivo'; weekday: number | null; start_time: string; end_time: string }>();

  const byUser = new Map<string, (typeof templates.results)[number][]>();
  for (const t of templates.results) {
    const arr = byUser.get(t.service_user_id) ?? [];
    arr.push(t);
    byUser.set(t.service_user_id, arr);
  }

  for (const u of users.results) {
    const userTemplates = byUser.get(u.id) ?? [];
    if (userTemplates.length === 0) continue;

    for (const { d, ymd } of dates) {
      const weekday = d.getUTCDay(); // 0..6
      const kind = await getDayKind(ymd, weekday);

      const applicable = userTemplates.filter((t) => {
        if (kind === 'laborable') {
          if (t.kind !== 'laborable') return false;
          if (t.weekday === null) return true;
          return t.weekday === weekday;
        }
        // festivo o fin_semana
        if (t.kind !== 'festivo') return false;
        if (t.weekday === null) return true;
        return t.weekday === weekday;
      });

      for (const t of applicable) {
        await database
          .prepare(
            `INSERT INTO assignments
              (id, date, service_user_id, template_id, kind, planned_start, planned_end, source)
             VALUES (?, ?, ?, ?, ?, ?, ?, 'template')
             ON CONFLICT(service_user_id, date, template_id) DO UPDATE SET
               kind = excluded.kind,
               planned_start = excluded.planned_start,
               planned_end = excluded.planned_end,
               status = 'planned',
               source = 'template'`
          )
          .bind(randomId(), ymd, u.id, t.id, kind === 'fin_semana' ? 'fin_semana' : t.kind, t.start_time, t.end_time)
          .run();
      }
    }
  }

  if (action === 'generate' || action === 'regenerate_week') {
    await autoAssignWeekRange(toYmd(new Date(weekDates[0])), toYmd(new Date(weekDates[6])));
  }

  return Astro.redirect(`/admin/schedule/week?week=${weekKey}`);
}

const assignments = await database
  .prepare(
    `SELECT a.id, a.date, a.kind, a.source, a.template_id, a.planned_start, a.planned_end, a.assigned_worker_id,
            a.service_user_id,
            su.name as user_name,
            w.name as worker_name,
            t.required_worker_type as required_worker_type
     FROM assignments a
     JOIN service_users su ON su.id = a.service_user_id
     LEFT JOIN workers w ON w.id = a.assigned_worker_id
     LEFT JOIN service_templates t ON t.id = a.template_id
     WHERE a.date >= ? AND a.date <= ?
     ORDER BY a.date ASC, a.planned_start ASC, su.name ASC`
  )
  .bind(toYmd(new Date(weekDates[0])), toYmd(new Date(weekDates[6])))
  .all<{
    id: string;
    date: string;
    kind: string;
    source: string;
    template_id: string | null;
    planned_start: string;
    planned_end: string;
    assigned_worker_id: string | null;
    service_user_id: string;
    user_name: string;
    worker_name: string | null;
    required_worker_type: string | null;
  }>();

type AssignmentRow = (typeof assignments.results)[number];

const assignmentsByDate = new Map<string, AssignmentRow[]>();
for (const a of assignments.results) {
  const arr = assignmentsByDate.get(a.date) ?? [];
  arr.push(a);
  assignmentsByDate.set(a.date, arr);
}
const groupedDays = Array.from(assignmentsByDate.entries())
  .sort(([a], [b]) => (a < b ? -1 : a > b ? 1 : 0))
  .map(([date, items]) => ({ date, items }));

const formatDateEs = (ymd: string) => {
  const d = new Date(`${ymd}T00:00:00Z`);
  return d.toLocaleDateString('es-ES', { weekday: 'long', day: '2-digit', month: '2-digit' });
};

const workers = await database
  .prepare(`SELECT id, name, worker_type, active FROM workers WHERE active = 1 ORDER BY name ASC`)
  .all<{ id: string; name: string; worker_type: 'laborable' | 'festivo' | 'ambos'; active: number }>();

type WorkerRow = (typeof workers.results)[number];

const workerIntervalsByDate = new Map<string, { start: number; end: number }[]>();
for (const a of assignments.results) {
  if (!a.assigned_worker_id) continue;
  const start = timeToMinutes(a.planned_start);
  const end = timeToMinutes(a.planned_end);
  if (start === null || end === null) continue;
  const key = `${a.assigned_worker_id}|${a.date}`;
  const arr = workerIntervalsByDate.get(key) ?? [];
  arr.push({ start, end });
  workerIntervalsByDate.set(key, arr);
}

const workerLoadMinutes = new Map<string, number>();
for (const a of assignments.results) {
  if (!a.assigned_worker_id) continue;
  const start = timeToMinutes(a.planned_start);
  const end = timeToMinutes(a.planned_end);
  if (start === null || end === null) continue;
  const duration = Math.max(0, end - start);
  workerLoadMinutes.set(a.assigned_worker_id, (workerLoadMinutes.get(a.assigned_worker_id) ?? 0) + duration);
}

const getWorkerAvailability = (workerId: string, date: string, start: number, end: number) => {
  const key = `${workerId}|${date}`;
  const intervals = workerIntervalsByDate.get(key) ?? [];
  for (const it of intervals) {
    if (overlaps(start, end, it.start, it.end)) return { available: false as const };
  }
  return { available: true as const };
};

const habitualRows = await database
  .prepare(
    `SELECT id, preferred_worker_id, preferred_weekend_worker_id FROM service_users WHERE preferred_worker_id IS NOT NULL OR preferred_weekend_worker_id IS NOT NULL`
  )
  .all<{ id: string; preferred_worker_id: string | null; preferred_weekend_worker_id: string | null }>();

const usersCountRow = await database.prepare(`SELECT count(id) as count FROM service_users`).first<{ count: number }>();
const usersCount = usersCountRow?.count ?? 0;

const habitualByUser = new Map<string, { weekdayWorkerId: string | null, weekendWorkerId: string | null }>();
for (const row of habitualRows.results) {
  habitualByUser.set(row.id, { 
    weekdayWorkerId: row.preferred_worker_id,
    weekendWorkerId: row.preferred_weekend_worker_id
  });
}

type Candidate = { w: WorkerRow; available: boolean; loadMinutes: number; habitual: boolean; compatible: boolean };

const formatMinutes = (minutes: number) => {
  const total = Math.max(0, Math.floor(minutes));
  const h = Math.floor(total / 60);
  const m = total % 60;
  return `${h}h ${String(m).padStart(2, '0')}m`;
};
---

<AppLayout title="Agenda semanal | Admin">
  <div class="flex items-center justify-between border-b border-zinc-200 pb-4">
    <div>
      <div class="flex items-center gap-2">
        <a class="text-sm font-medium text-zinc-500 hover:text-zinc-800 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-400">/</span>
        <span class="text-sm font-medium text-zinc-800">Agenda</span>
      </div>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-zinc-900">Agenda Semanal</h1>
      <div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-zinc-600">
        <span>Semana: <span class="font-bold text-zinc-800">{weekKey}</span></span>
        <span class="text-zinc-300">•</span>
        <button type="button" id="reset-filters" class="inline-flex items-center rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-semibold text-zinc-800 hover:bg-zinc-200 transition-colors cursor-pointer" title="Ver todos los servicios">
          {assignments.results.length} servicios
        </button>
        <a href="/admin/users" class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold text-emerald-800 hover:bg-emerald-200 transition-colors cursor-pointer" title="Ir a gestión de usuarios">
          {usersCount} usuarios/as
        </a>
        <a href="/admin/workers" class="inline-flex items-center rounded-full bg-sky-100 px-2.5 py-0.5 text-xs font-semibold text-sky-800 hover:bg-sky-200 transition-colors cursor-pointer" title="Ir a gestión de trabajadoras">
          {workers.results.length} trabajadoras
        </a>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <form method="get" class="flex items-center gap-2">
        <input class="w-36 rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all" name="week" value={weekKey} />
        <button class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium hover:bg-zinc-50 transition-colors shadow-sm">Ir</button>
      </form>
      <form method="post">
        <input type="hidden" name="_action" value="generate" />
        <button class="flex items-center gap-2 rounded-lg bg-zinc-900 hover:bg-zinc-800 transition-colors px-4 py-2 text-sm font-bold text-white shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
          Generar de plantillas
        </button>
      </form>
      <form method="post" onsubmit="return confirm('Esto recalcula la semana desde plantillas y borra servicios de origen plantilla no finalizados. ¿Continuar?');">
        <input type="hidden" name="_action" value="regenerate_week" />
        <button class="flex items-center gap-2 rounded-lg border border-zinc-300 bg-white hover:bg-zinc-50 transition-colors px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm">
          Regenerar semana
        </button>
      </form>
      <form method="post">
        <input type="hidden" name="_action" value="auto_assign" />
        <button class="flex items-center gap-2 rounded-lg bg-[#0284C7] hover:bg-sky-700 transition-colors px-4 py-2 text-sm font-bold text-white shadow-sm" title="Asigna automáticamente la trabajadora más adecuada a los turnos sin asignar">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><polyline points="16 11 18 13 22 9"></polyline></svg>
          Auto-asignar vacíos
        </button>
      </form>
    </div>
  </div>

  <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl">
    <div class="relative">
      <svg class="absolute left-3 top-2.5 h-4 w-4 text-zinc-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="filter-user" class="w-full rounded-lg border border-zinc-300 bg-white py-2 pl-9 pr-4 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all" placeholder="Filtrar por Usuario/a..." autocomplete="off" />
    </div>
    <div class="relative">
      <svg class="absolute left-3 top-2.5 h-4 w-4 text-zinc-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
      <input type="text" id="filter-worker" class="w-full rounded-lg border border-zinc-300 bg-white py-2 pl-9 pr-4 text-sm shadow-sm focus:border-[#0284C7] focus:outline-none focus:ring-1 focus:ring-[#0284C7] transition-all" placeholder="Filtrar por Trabajadora asignada..." autocomplete="off" />
    </div>
    <label class="md:col-span-2 inline-flex items-center gap-2 text-sm text-zinc-700">
      <input id="filter-unassigned" type="checkbox" class="h-4 w-4 rounded border-zinc-300 text-amber-600 focus:ring-amber-500" />
      Ver solo servicios sin trabajadora asignada
    </label>
  </div>
  <p class="mt-3 text-xs text-zinc-500">
    La asignación se guarda automáticamente al cambiar la trabajadora. Si editas/borras plantillas, usa <strong>Regenerar semana</strong> para refrescar la agenda.
  </p>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white shadow-sm overflow-hidden">
    <div class="p-6 border-b border-zinc-100 flex items-center justify-between bg-zinc-50/50">
      <h2 class="text-lg font-bold text-zinc-900" id="assignments-count">Servicios Planificados ({assignments.results.length})</h2>
    </div>
    <div>
      <table class="w-full table-fixed text-left text-sm">
        <thead class="bg-zinc-50 text-xs uppercase text-zinc-500 border-b border-zinc-200">
          <tr>
            <th class="px-6 py-3 font-semibold">Fecha</th>
            <th class="px-6 py-3 font-semibold">Usuario/a</th>
            <th class="px-6 py-3 font-semibold">Servicio</th>
            <th class="px-6 py-3 font-semibold">Asignación</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100" id="assignments-tbody">
          {assignments.results.map((a: AssignmentRow) => (
            <tr class={`assignment-row ${a.assigned_worker_id ? 'hover:bg-zinc-50/50' : 'bg-amber-50/30 hover:bg-amber-50/60'} transition-colors`} data-user={a.user_name} data-worker={a.worker_name ?? ''} data-assigned={a.assigned_worker_id ? '1' : '0'}>
              <td class="px-4 py-4 font-medium text-zinc-700 whitespace-nowrap">{a.date}</td>
              <td class="px-4 py-4 font-semibold text-emerald-700 truncate" title={a.user_name}>{a.user_name}</td>
              <td class="px-4 py-4">
                <div class="flex items-center gap-2 whitespace-nowrap overflow-hidden">
                  <span class="font-bold text-[#4B79A1]">{a.planned_start} - {a.planned_end}</span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-zinc-100 text-zinc-600 capitalize">
                    {a.kind}
                  </span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-zinc-100 text-zinc-600 capitalize">
                    {a.required_worker_type ?? 'cualquiera'}
                  </span>
                </div>
              </td>
              <td class="px-4 py-4">
                {(() => {
                  const start = timeToMinutes(a.planned_start);
                  const end = timeToMinutes(a.planned_end);
                  if (start === null || end === null) {
                    return <span class="text-xs text-red-500 font-bold">Horas inválidas</span>;
                  }

                  const candidates = workers.results
                    .map((w: WorkerRow) => {
                      const availability = getWorkerAvailability(w.id, a.date, start, end);
                      const loadMinutes = workerLoadMinutes.get(w.id) ?? 0;
                      
                      const userPrefs = habitualByUser.get(a.service_user_id);
                      let habitualWorkerId = null;
                      if (userPrefs) {
                        if (a.kind === 'laborable') {
                          habitualWorkerId = userPrefs.weekdayWorkerId;
                        } else {
                          // festivo o fin_semana
                          habitualWorkerId = userPrefs.weekendWorkerId || userPrefs.weekdayWorkerId; // fallback to weekday if no weekend specific
                        }
                      }
                      
                      const habitual = habitualWorkerId === w.id;
                      const compatible = matchesWorkerType(a.required_worker_type, w.worker_type);
                      const candidate: Candidate = { w, available: availability.available, loadMinutes, habitual, compatible };
                      return candidate;
                    })
                    .sort(
                      (x: Candidate, y: Candidate) =>
                        Number(y.compatible) - Number(x.compatible) ||
                        Number(y.available) - Number(x.available) ||
                        Number(y.habitual) - Number(x.habitual) ||
                        x.loadMinutes - y.loadMinutes ||
                        x.w.name.localeCompare(y.w.name)
                    );

                  const suggested = candidates.find((c: Candidate) => c.available && c.compatible)?.w.id
                    ?? candidates.find((c: Candidate) => c.available)?.w.id
                    ?? '';

                  return (
                    <form method="post" class="flex items-center gap-2 w-full">
                      <input type="hidden" name="_action" value="assign" />
                      <input type="hidden" name="assignmentId" value={a.id} />
                      <select class={`w-full max-w-full rounded-lg border ${a.assigned_worker_id ? 'border-zinc-300' : 'border-amber-300 bg-amber-50 text-amber-900'} px-2 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all`} name="workerId">
                        <option value="">— Sin asignar —</option>
                        {candidates.map(({ w, available, habitual, compatible }: Candidate) => (
                          <option value={w.id} selected={a.assigned_worker_id === w.id || (!a.assigned_worker_id && suggested === w.id)}>
                            {habitual ? '★ ' : ''}
                            {w.name} ({formatMinutes(workerLoadMinutes.get(w.id) ?? 0)}) {compatible ? '' : '(tipo no compatible)'} {available ? '' : '(solape)'}
                          </option>
                        ))}
                      </select>
                      
                      {!a.assigned_worker_id && (
                        <span class="ml-2 flex h-2 w-2 rounded-full bg-amber-500" title="Requiere asignación"></span>
                      )}
                    </form>
                  );
                })()}
              </td>
            </tr>
          ))}
          
          {assignments.results.length === 0 && (
            <tr>
              <td colspan="4" class="px-4 py-8 text-center text-zinc-500 italic">
                No hay servicios planificados para esta semana. Genera el cuadrante usando las plantillas.
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
    <h2 class="text-sm font-semibold">Vista por día</h2>
    <p class="mt-1 text-xs text-zinc-600">Lectura rápida para revisar por fecha qué usuario tiene servicio, horario y trabajadora asignada.</p>
    <div class="mt-4 space-y-3">
      {groupedDays.map((day) => (
        <details class="rounded-xl border border-zinc-200 bg-zinc-50/40 day-group" data-date={day.date} open>
          <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-zinc-800">
            {formatDateEs(day.date)} · {day.items.length} servicios
          </summary>
          <div class="border-t border-zinc-200 bg-white">
            {day.items.map((a) => (
              <div class="day-item grid gap-2 border-b border-zinc-100 px-4 py-3 text-sm last:border-b-0 md:grid-cols-[1fr_auto_auto]" data-assignment-id={a.id} data-user={a.user_name} data-worker={a.worker_name ?? ''} data-assigned={a.assigned_worker_id ? '1' : '0'}>
                <div class="font-semibold text-emerald-700 uppercase">{a.user_name}</div>
                <div class="font-medium text-[#4B79A1]">{a.planned_start} - {a.planned_end}</div>
                <div class="text-zinc-600 day-worker-name">{a.worker_name ?? 'Sin asignar'}</div>
              </div>
            ))}
          </div>
        </details>
      ))}
      {groupedDays.length === 0 && (
        <div class="rounded-lg border border-zinc-200 px-4 py-4 text-sm text-zinc-500 italic">
          No hay servicios para mostrar por día en esta semana.
        </div>
      )}
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filterUser = document.getElementById('filter-user') as HTMLInputElement;
      const filterWorker = document.getElementById('filter-worker') as HTMLInputElement;
      const filterUnassigned = document.getElementById('filter-unassigned') as HTMLInputElement;
      const rows = document.querySelectorAll('.assignment-row') as NodeListOf<HTMLElement>;
      const dayItems = document.querySelectorAll('.day-item') as NodeListOf<HTMLElement>;
      const dayGroups = document.querySelectorAll('.day-group') as NodeListOf<HTMLElement>;
      const countEl = document.getElementById('assignments-count');
      
      const normalize = (str: string) => str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
      const extractWorkerName = (label: string) =>
        label.replace(/^★\s*/, '').split(' (')[0]?.trim() ?? '';

      const syncWorkerIndexFromSelect = () => {
        rows.forEach((row) => {
          const select = row.querySelector('select[name="workerId"]') as HTMLSelectElement | null;
          if (!select || !select.value) {
            row.setAttribute('data-worker', '');
            return;
          }
          const selectedLabel = select.selectedOptions?.[0]?.textContent ?? '';
          row.setAttribute('data-worker', extractWorkerName(selectedLabel));
        });
      };
      
      const updateFilters = () => {
        const uQuery = normalize(filterUser.value.trim());
        const wQuery = normalize(filterWorker.value.trim());
        const onlyUnassigned = Boolean(filterUnassigned?.checked);
        
        let visibleCount = 0;
        
        rows.forEach(row => {
          const rUser = normalize(row.getAttribute('data-user') || '');
          const rWorker = normalize(row.getAttribute('data-worker') || '');
          const rAssigned = row.getAttribute('data-assigned') === '1';
          
          const matchUser = !uQuery || rUser.includes(uQuery);
          const matchWorker = !wQuery || rWorker.includes(wQuery);
          const matchUnassigned = !onlyUnassigned || !rAssigned;
          
          if (matchUser && matchWorker && matchUnassigned) {
            row.style.display = '';
            visibleCount++;
          } else {
            row.style.display = 'none';
          }
        });

        dayItems.forEach((item) => {
          const rUser = normalize(item.getAttribute('data-user') || '');
          const rWorker = normalize(item.getAttribute('data-worker') || '');
          const rAssigned = item.getAttribute('data-assigned') === '1';

          const matchUser = !uQuery || rUser.includes(uQuery);
          const matchWorker = !wQuery || rWorker.includes(wQuery);
          const matchUnassigned = !onlyUnassigned || !rAssigned;
          item.style.display = matchUser && matchWorker && matchUnassigned ? '' : 'none';
        });

        dayGroups.forEach((group) => {
          const visibleItems = group.querySelectorAll('.day-item:not([style*="display: none"])').length;
          group.style.display = visibleItems > 0 ? '' : 'none';
        });
        
        if (countEl) {
          countEl.textContent = `Servicios Planificados (${visibleCount})`;
        }
      };

      if (filterUser && filterWorker) {
        filterUser.addEventListener('input', updateFilters);
        filterWorker.addEventListener('input', updateFilters);
      }
      if (filterUnassigned) {
        filterUnassigned.addEventListener('change', updateFilters);
      }

      rows.forEach((row) => {
        const select = row.querySelector('select[name="workerId"]') as HTMLSelectElement | null;
        if (!select) return;
        select.addEventListener('change', () => {
          const selectedLabel = select.selectedOptions?.[0]?.textContent ?? '';
          const selectedWorker = select.value ? extractWorkerName(selectedLabel) : '';
          row.setAttribute('data-worker', selectedWorker);
          row.setAttribute('data-assigned', select.value ? '1' : '0');
          const assignmentIdInput = row.querySelector('input[name="assignmentId"]') as HTMLInputElement | null;
          if (assignmentIdInput?.value) {
            const mirror = document.querySelector(`.day-item[data-assignment-id="${assignmentIdInput.value}"]`) as HTMLElement | null;
            if (mirror) {
              mirror.setAttribute('data-worker', selectedWorker);
              mirror.setAttribute('data-assigned', select.value ? '1' : '0');
              const workerText = mirror.querySelector('.day-worker-name');
              if (workerText) workerText.textContent = selectedWorker || 'Sin asignar';
            }
          }
          updateFilters();
          select.form?.requestSubmit();
        });
      });

      const resetBtn = document.getElementById('reset-filters');
      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          if (filterUser) filterUser.value = '';
          if (filterWorker) filterWorker.value = '';
          if (filterUnassigned) filterUnassigned.checked = false;
          updateFilters();
        });
      }

      syncWorkerIndexFromSelect();
      updateFilters();
    });
  </script>
</AppLayout>
