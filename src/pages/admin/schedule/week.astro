---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { datesOfIsoWeek, getIsoWeekKey, toYmd } from '../../../lib/dates';
import { bumpManyWorkerAssignmentsVersions, bumpWorkerAssignmentsVersion } from '../../../lib/realtime';
import { sendPushToWorkerIds } from '../../../lib/push';
import { randomId } from '../../../lib/crypto';
import { timeToMinutes, autoAssignWeekRange, generateWeek, matchesWorkerType, overlaps } from '../../../lib/schedule-generator';

export const prerender = false;

const currentWeek = getIsoWeekKey(new Date());
const rawWeek = String(Astro.url.searchParams.get('week') ?? currentWeek).trim();
const normalizeWeekKey = (value: string) => {
  if (/^\d{4}-W\d{2}$/.test(value)) return value;
  if (/^\d{4}-\d{2}-\d{2}$/.test(value)) return getIsoWeekKey(new Date(`${value}T00:00:00Z`));
  if (/^\d{4}-\d{2}$/.test(value)) return getIsoWeekKey(new Date(`${value}-01T00:00:00Z`));
  return null;
};
const weekKey = normalizeWeekKey(rawWeek) ?? currentWeek;
const weekDates = datesOfIsoWeek(weekKey) ?? datesOfIsoWeek(currentWeek);
if (!weekDates) return Astro.redirect(`/admin`);

const database = db();
const travelError = String(Astro.url.searchParams.get('travelError') ?? '').trim();

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('_action') ?? 'regenerate_week');

  let assignmentsChanged = false;
  const cf = Astro.locals.cfContext;
  const queuePush = (workerIds: string[]) => {
    cf?.waitUntil(
      sendPushToWorkerIds(database, workerIds, {
        title: 'Planificación actualizada',
        body: 'Se han aplicado cambios en tu agenda. Entra para verlos.',
        url: '/w/planning'
      }) as any
    );
  };

  if (action === 'set_travel') {
    const workerId = String(formData.get('workerId') ?? '').trim();
    const date = String(formData.get('date') ?? '').trim();
    const travelRaw = String(formData.get('travelMinutes') ?? '').trim();
    const travelParsed = travelRaw === '' ? 0 : Number(travelRaw);
    const travel = Number.isFinite(travelParsed) && travelParsed >= 0 ? Math.floor(travelParsed) : 0;

    if (workerId && /^\d{4}-\d{2}-\d{2}$/.test(date)) {
      try {
        await database
          .prepare(
            `INSERT INTO worker_day_extras (id, worker_id, date, travel_minutes, source)
             VALUES (?, ?, ?, ?, 'manual')
             ON CONFLICT(worker_id, date) DO UPDATE SET
               travel_minutes = excluded.travel_minutes,
               source = 'manual',
               updated_at = datetime('now')`
          )
          .bind(randomId(), workerId, date, travel)
          .run();
      } catch {
        try {
          await database
            .prepare(
              `INSERT INTO worker_day_extras (id, worker_id, date, travel_minutes)
               VALUES (?, ?, ?, ?)
               ON CONFLICT(worker_id, date) DO UPDATE SET
                 travel_minutes = excluded.travel_minutes,
                 updated_at = datetime('now')`
            )
            .bind(randomId(), workerId, date, travel)
            .run();
        } catch {
          return Astro.redirect(`/admin/schedule/week?week=${weekKey}&travelError=missing_table`);
        }
      }

      await bumpWorkerAssignmentsVersion(database, workerId);
      queuePush([workerId]);
    }

    return Astro.redirect(`/admin/schedule/week?week=${weekKey}`);
  }

  if (action === 'assign') {
    const assignmentId = String(formData.get('assignmentId') ?? '').trim();
    const workerIdRaw = String(formData.get('workerId') ?? '').trim();
    const workerId = workerIdRaw === '' ? null : workerIdRaw;

    if (assignmentId) {
      const prev = await database
        .prepare(`SELECT assigned_worker_id FROM assignments WHERE id = ? LIMIT 1`)
        .bind(assignmentId)
        .first<{ assigned_worker_id: string | null }>();

      await database
        .prepare(`UPDATE assignments SET assigned_worker_id = ? WHERE id = ?`)
        .bind(workerId, assignmentId)
        .run();
      assignmentsChanged = true;

      const prevWorkerId = prev?.assigned_worker_id ?? null;
      if (prevWorkerId) await bumpWorkerAssignmentsVersion(database, prevWorkerId);
      if (workerId) await bumpWorkerAssignmentsVersion(database, workerId);

      queuePush([prevWorkerId ?? '', workerId ?? '']);
    }
    return Astro.redirect(`/admin/schedule/week?week=${weekKey}`);
  }

  if (action === 'auto_assign') {
    await autoAssignWeekRange(database, toYmd(new Date(weekDates[0])), toYmd(new Date(weekDates[6])));
    const allWorkers = await database
      .prepare(`SELECT id FROM workers WHERE active = 1`)
      .all<{ id: string }>();
    await bumpManyWorkerAssignmentsVersions(database, allWorkers.results.map((w) => w.id));
    queuePush(allWorkers.results.map((w) => w.id));
    return Astro.redirect(`/admin/schedule/week?week=${weekKey}`);
  }

  if (action === 'regenerate_week') {
    const dates = weekDates.map((d) => ({ d: new Date(d), ymd: toYmd(new Date(d)) }));
    await generateWeek(database, dates, true);
    assignmentsChanged = true;
  }

  if (assignmentsChanged) {
    const allWorkers = await database
      .prepare(`SELECT id FROM workers WHERE active = 1`)
      .all<{ id: string }>();
    await bumpManyWorkerAssignmentsVersions(database, allWorkers.results.map((w) => w.id));
    queuePush(allWorkers.results.map((w) => w.id));
  }
  return Astro.redirect(`/admin/schedule/week?week=${weekKey}`);
}

const assignments = await database
  .prepare(
    `SELECT a.id, a.date, a.kind, a.source, a.template_id, a.planned_start, a.planned_end, a.assigned_worker_id,
            a.service_user_id,
            su.name as user_name,
            w.name as worker_name,
            t.required_worker_type as required_worker_type,
            t.preferred_worker_id as preferred_worker_id
     FROM assignments a
     JOIN service_users su ON su.id = a.service_user_id
     LEFT JOIN workers w ON w.id = a.assigned_worker_id
     LEFT JOIN service_templates t ON t.id = a.template_id
     WHERE a.date >= ? AND a.date <= ?
     ORDER BY a.date ASC, a.planned_start ASC, su.name ASC`
  )
  .bind(toYmd(new Date(weekDates[0])), toYmd(new Date(weekDates[6])))
  .all<{
    id: string;
    date: string;
    kind: string;
    source: string;
    template_id: string | null;
    planned_start: string;
    planned_end: string;
    assigned_worker_id: string | null;
    service_user_id: string;
    user_name: string;
    worker_name: string | null;
    required_worker_type: string | null;
    preferred_worker_id: string | null;
  }>();

type AssignmentRow = (typeof assignments.results)[number];

const startYmd = toYmd(new Date(weekDates[0]));
const endYmd = toYmd(new Date(weekDates[6]));

let travelExtras: { results: Array<{ worker_id: string; date: string; travel_minutes: number }> } = { results: [] };
let travelExtrasAvailable = true;
try {
  travelExtras = await database
    .prepare(`SELECT worker_id, date, travel_minutes FROM worker_day_extras WHERE date >= ? AND date <= ?`)
    .bind(startYmd, endYmd)
    .all<{ worker_id: string; date: string; travel_minutes: number }>();
} catch {
  travelExtrasAvailable = false;
}

const travelByWorkerDate = new Map<string, number>(
  travelExtras.results.map((r) => [`${r.worker_id}|${r.date}`, r.travel_minutes ?? 0])
);

const assignedWorkerMapByDate = new Map<string, Map<string, string>>();
for (const a of assignments.results) {
  if (!a.assigned_worker_id) continue;
  const name = a.worker_name ?? '';
  if (!name) continue;
  const map = assignedWorkerMapByDate.get(a.date) ?? new Map<string, string>();
  map.set(a.assigned_worker_id, name);
  assignedWorkerMapByDate.set(a.date, map);
}

const travelSumByDate = new Map<string, number>();
let travelWeekTotal = 0;
for (const [date, workerMap] of assignedWorkerMapByDate.entries()) {
  let sum = 0;
  for (const workerId of workerMap.keys()) {
    sum += travelByWorkerDate.get(`${workerId}|${date}`) ?? 0;
  }
  travelSumByDate.set(date, sum);
  travelWeekTotal += sum;
}

const holidayRows = await database
  .prepare(`SELECT date FROM holidays WHERE date >= ? AND date <= ? AND scope IN ('national','catalonia','mataro')`)
  .bind(startYmd, endYmd)
  .all<{ date: string }>();
const holidaySet = new Set(holidayRows.results.map((r) => r.date));

const templates = await database
  .prepare(
    `SELECT t.id, t.service_user_id, t.kind, t.weekday, t.start_time, t.end_time, t.required_worker_type, t.preferred_worker_id,
            su.name as user_name
     FROM service_templates t
     JOIN service_users su ON su.id = t.service_user_id
     WHERE su.active = 1
     ORDER BY su.name ASC, t.start_time ASC`
  )
  .all<{
    id: string;
    service_user_id: string;
    kind: 'laborable' | 'festivo';
    weekday: number | null;
    start_time: string;
    end_time: string;
    required_worker_type: string | null;
    preferred_worker_id: string | null;
    user_name: string;
  }>();

const existingTemplateKeys = new Set(
  assignments.results
    .filter((a) => Boolean(a.template_id))
    .map((a) => `${a.date}|${a.template_id}`)
);

const dayKindOf = (ymd: string) => {
  const d = new Date(`${ymd}T00:00:00Z`);
  const weekday = d.getUTCDay();
  const isWeekend = weekday === 0 || weekday === 6;
  if (holidaySet.has(ymd)) return 'festivo' as const;
  if (isWeekend) return 'fin_semana' as const;
  return 'laborable' as const;
};

const projectionRows: AssignmentRow[] = [];
for (const d of weekDates) {
  const ymd = toYmd(new Date(d));
  const weekday = new Date(`${ymd}T00:00:00Z`).getUTCDay();
  const kind = dayKindOf(ymd);
  for (const t of templates.results) {
    if (kind === 'laborable') {
      if (t.kind !== 'laborable') continue;
      if (t.weekday !== null && t.weekday !== weekday) continue;
    } else {
      if (t.kind !== 'festivo') continue;
      if (t.weekday !== null && t.weekday !== weekday) continue;
    }
    const key = `${ymd}|${t.id}`;
    if (existingTemplateKeys.has(key)) continue;
    projectionRows.push({
      id: `projection:${t.id}:${ymd}`,
      date: ymd,
      kind: kind === 'fin_semana' ? 'fin_semana' : t.kind,
      source: 'projection',
      template_id: t.id,
      planned_start: t.start_time,
      planned_end: t.end_time,
      assigned_worker_id: null,
      service_user_id: t.service_user_id,
      user_name: t.user_name,
      worker_name: null,
      required_worker_type: t.required_worker_type ?? null,
      preferred_worker_id: t.preferred_worker_id ?? null,
    });
  }
}

const viewRows = [...assignments.results, ...projectionRows].sort((a, b) =>
  a.date.localeCompare(b.date) || a.planned_start.localeCompare(b.planned_start) || a.user_name.localeCompare(b.user_name)
);

const assignmentsByDate = new Map<string, AssignmentRow[]>();
for (const a of viewRows) {
  const arr = assignmentsByDate.get(a.date) ?? [];
  arr.push(a);
  assignmentsByDate.set(a.date, arr);
}
const groupedDays = Array.from(assignmentsByDate.entries())
  .sort(([a], [b]) => (a < b ? -1 : a > b ? 1 : 0))
  .map(([date, items]) => ({ date, items }));

const formatDateEs = (ymd: string) => {
  const d = new Date(`${ymd}T00:00:00Z`);
  return d.toLocaleDateString('es-ES', { weekday: 'long', day: '2-digit', month: '2-digit' });
};

const workers = await database
  .prepare(`SELECT id, name, worker_type, active FROM workers WHERE active = 1 ORDER BY name ASC`)
  .all<{ id: string; name: string; worker_type: 'laborable' | 'festivo' | 'ambos'; active: number }>();

type WorkerRow = (typeof workers.results)[number];

const workerIntervalsByDate = new Map<string, { id: string; start: number; end: number }[]>();
for (const a of assignments.results) {
  if (!a.assigned_worker_id) continue;
  const start = timeToMinutes(a.planned_start);
  const end = timeToMinutes(a.planned_end);
  if (start === null || end === null) continue;
  const key = `${a.assigned_worker_id}|${a.date}`;
  const arr = workerIntervalsByDate.get(key) ?? [];
  arr.push({ id: a.id, start, end });
  workerIntervalsByDate.set(key, arr);
}

const workerLoadMinutes = new Map<string, number>();
for (const a of assignments.results) {
  if (!a.assigned_worker_id) continue;
  const start = timeToMinutes(a.planned_start);
  const end = timeToMinutes(a.planned_end);
  if (start === null || end === null) continue;
  const duration = Math.max(0, end - start);
  workerLoadMinutes.set(a.assigned_worker_id, (workerLoadMinutes.get(a.assigned_worker_id) ?? 0) + duration);
}

const unassignedCount = viewRows.filter((a) => !a.assigned_worker_id).length;
const assignedCount = viewRows.length - unassignedCount;
const byWorkerCount = new Map<string, number>();
for (const a of viewRows) {
  if (!a.assigned_worker_id) continue;
  byWorkerCount.set(a.assigned_worker_id, (byWorkerCount.get(a.assigned_worker_id) ?? 0) + 1);
}
const workerOperationalSummary = workers.results
  .map((w) => ({
    id: w.id,
    name: w.name,
    services: byWorkerCount.get(w.id) ?? 0,
    minutes: workerLoadMinutes.get(w.id) ?? 0,
  }))
  .filter((w) => w.services > 0)
  .sort((a, b) => b.services - a.services || b.minutes - a.minutes || a.name.localeCompare(b.name));

const getWorkerAvailability = (workerId: string, date: string, start: number, end: number, assignmentId: string) => {
  const key = `${workerId}|${date}`;
  const intervals = workerIntervalsByDate.get(key) ?? [];
  for (const it of intervals) {
    if (it.id === assignmentId) continue;
    if (overlaps(start, end, it.start, it.end)) return { available: false as const };
  }
  return { available: true as const };
};

const usersCountRow = await database.prepare(`SELECT count(id) as count FROM service_users`).first<{ count: number }>();
const usersCount = usersCountRow?.count ?? 0;

type Candidate = { w: WorkerRow; available: boolean; loadMinutes: number; habitual: boolean; compatible: boolean };

const formatMinutes = (minutes: number) => {
  const total = Math.max(0, Math.floor(minutes));
  const h = Math.floor(total / 60);
  const m = total % 60;
  return `${h}h ${String(m).padStart(2, '0')}m`;
};

const formatTravelMinutes = (minutes: number) => {
  const total = Math.max(0, Math.floor(minutes));
  if (total < 60) return `${total} min`;
  const h = Math.floor(total / 60);
  const m = total % 60;
  return `${h}h ${String(m).padStart(2, '0')}m`;
};
---

<AppLayout title="Agenda semanal | Admin">
  <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-zinc-200 pb-4 gap-4">
    <div>
      <div class="flex items-center gap-2">
        <a class="text-sm font-medium text-zinc-500 hover:text-zinc-800 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-400">/</span>
        <span class="text-sm font-medium text-zinc-800">Agenda Semanal</span>
      </div>
      <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-zinc-600">
        <span class="text-xl font-bold tracking-tight text-zinc-900 mr-2">Semana {weekKey}</span>
        <button type="button" id="reset-filters" class="inline-flex items-center rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-semibold text-zinc-800 hover:bg-zinc-200 transition-colors cursor-pointer" title="Ver todos los servicios">
          {viewRows.length} servicios
        </button>
        <a href="/admin/users" class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold text-emerald-800 hover:bg-emerald-200 transition-colors cursor-pointer" title="Ir a gestión de usuarios">
          {usersCount} usuarios/as
        </a>
        <a href="/admin/workers" class="inline-flex items-center rounded-full bg-sky-100 px-2.5 py-0.5 text-xs font-semibold text-sky-800 hover:bg-sky-200 transition-colors cursor-pointer" title="Ir a gestión de trabajadoras">
          {workers.results.length} trabajadoras
        </a>
      </div>
    </div>
    
    {(travelError === 'missing_table' || !travelExtrasAvailable) && (
      <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
        La tabla de desplazamientos no está disponible en esta base de datos. Aplica la migración 0010 (y 0012 si procede) y recarga.
      </div>
    )}

    <div class="flex flex-wrap items-center gap-2">
      <form method="get" class="flex items-center">
        <input class="ui-input w-40 rounded-l-xl border-r-0" type="week" name="week" value={weekKey} />
        <button class="ui-btn ui-btn-secondary rounded-r-xl rounded-l-none px-3 py-2 shadow-sm">Ir</button>
      </form>
      
      <a href="/admin/schedule/month" class="ui-btn ui-btn-secondary px-3 py-2 shadow-sm" title="Vista mensual">
        Mes
      </a>
      
      <form method="post" onsubmit="return window.confirm('Esto recalcula la semana desde plantillas y borra servicios de origen plantilla no finalizados. ¿Continuar?')">
        <input type="hidden" name="_action" value="regenerate_week" />
        <button class="ui-btn ui-btn-primary px-3 py-2 shadow-sm" title="Regenerar la semana entera desde plantillas">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
          Regenerar
        </button>
      </form>
      
      <form method="post">
        <input type="hidden" name="_action" value="auto_assign" />
        <button class="ui-btn ui-btn-primary px-3 py-2 shadow-sm" title="Asignar automáticamente a las trabajadoras">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><polyline points="16 11 18 13 22 9"></polyline></svg>
          Asignar
        </button>
      </form>
    </div>
  </div>

  <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl">
    <div class="relative">
      <svg class="absolute left-3 top-2.5 h-4 w-4 text-zinc-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="filter-user" class="ui-input py-2 pl-9 pr-4" placeholder="Filtrar por Usuario/a..." autocomplete="off" />
    </div>
    <div class="relative">
      <svg class="absolute left-3 top-2.5 h-4 w-4 text-zinc-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
      <input type="text" id="filter-worker" class="ui-input py-2 pl-9 pr-4" placeholder="Filtrar por Trabajadora asignada..." autocomplete="off" />
    </div>
    <label class="md:col-span-2 inline-flex items-center gap-2 text-sm text-zinc-700">
      <input id="filter-unassigned" type="checkbox" class="h-4 w-4 rounded border-zinc-300 text-amber-600 focus:ring-amber-500" />
      Ver solo servicios sin trabajadora asignada
    </label>
  </div>
  <p class="mt-3 text-xs text-zinc-500">
    La asignación se guarda automáticamente al cambiar la trabajadora. Si editas/borras plantillas, usa <strong>Regenerar semana</strong> para refrescar la agenda.
  </p>

  <section class="mt-4 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
    <h2 class="text-sm font-semibold">Modo Ultra Operativo</h2>
    <div class="mt-3 grid gap-3 md:grid-cols-3">
      <div class="rounded-lg border border-zinc-200 bg-zinc-50 px-3 py-2">
        <div class="text-xs text-zinc-500">Servicios totales</div>
          <div class="text-xl font-semibold text-zinc-900">{viewRows.length}</div>
      </div>
      <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2">
        <div class="text-xs text-emerald-700">Asignados</div>
        <div class="text-xl font-semibold text-emerald-800">{assignedCount}</div>
      </div>
      <div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2">
        <div class="text-xs text-amber-700">Sin asignar</div>
        <div class="text-xl font-semibold text-amber-800">{unassignedCount}</div>
      </div>
    </div>
    <div class="mt-3 flex flex-wrap gap-2">
      {workerOperationalSummary.map((w) => (
        <span class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs">
          <span class="font-semibold text-zinc-700">{w.name}</span>
          <span class="text-zinc-500">{w.services} servicios</span>
          <span class="text-zinc-500">{formatMinutes(w.minutes)}</span>
        </span>
      ))}
      {workerOperationalSummary.length === 0 && (
        <span class="text-xs text-zinc-500">Aún no hay trabajadoras con servicios asignados esta semana.</span>
      )}
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white shadow-sm overflow-hidden">
    <div class="p-6 border-b border-zinc-100 flex items-center justify-between bg-zinc-50/50">
      <h2 class="text-lg font-bold text-zinc-900" id="assignments-count">Servicios Planificados ({viewRows.length})</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[800px] table-fixed text-left text-sm">
        <thead class="bg-zinc-50 text-xs uppercase text-zinc-500 border-b border-zinc-200">
          <tr>
            <th class="px-6 py-3 font-semibold">Fecha</th>
            <th class="px-6 py-3 font-semibold">Usuario/a</th>
            <th class="px-6 py-3 font-semibold">Servicio</th>
            <th class="px-6 py-3 font-semibold">Asignación</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100" id="assignments-tbody">
          {viewRows.map((a: AssignmentRow) => (
            <tr class={`assignment-row ${a.assigned_worker_id ? 'hover:bg-zinc-50/50' : 'bg-amber-50/30 hover:bg-amber-50/60'} transition-colors`} data-user={a.user_name} data-worker={a.worker_name ?? ''} data-assigned={a.assigned_worker_id ? '1' : '0'}>
              <td class="px-4 py-4 font-medium text-zinc-700 whitespace-nowrap">{a.date}</td>
              <td class="px-4 py-4 font-semibold text-emerald-700 truncate" title={a.user_name}>{a.user_name}</td>
              <td class="px-4 py-4">
                <div class="flex items-center gap-2 whitespace-nowrap overflow-hidden">
                  <span class="font-bold text-[#4B79A1]">{a.planned_start} - {a.planned_end}</span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-zinc-100 text-zinc-600 capitalize">
                    {a.kind}
                  </span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-zinc-100 text-zinc-600 capitalize">
                    {a.required_worker_type ?? 'cualquiera'}
                  </span>
                </div>
              </td>
              <td class="px-4 py-4">
                {a.source === 'projection' ? (
                  <span class="text-xs font-semibold text-indigo-700">Proyección (pulsa Regenerar)</span>
                ) : (() => {
                  const start = timeToMinutes(a.planned_start);
                  const end = timeToMinutes(a.planned_end);
                  if (start === null || end === null) {
                    return <span class="text-xs text-red-500 font-bold">Horas inválidas</span>;
                  }

                  const candidates = workers.results
                    .map((w: WorkerRow) => {
                      const availability = getWorkerAvailability(w.id, a.date, start, end, a.id);
                      const loadMinutes = workerLoadMinutes.get(w.id) ?? 0;
                      
                      let habitualWorkerId = a.preferred_worker_id ?? null;

                      const habitual = habitualWorkerId === w.id;
                      const compatible = matchesWorkerType(a.required_worker_type, w.worker_type);
                      const candidate: Candidate = { w, available: availability.available, loadMinutes, habitual, compatible };
                      return candidate;
                    })
                    .sort(
                      (x: Candidate, y: Candidate) =>
                        Number(y.compatible) - Number(x.compatible) ||
                        Number(y.available) - Number(x.available) ||
                        Number(y.habitual) - Number(x.habitual) ||
                        x.loadMinutes - y.loadMinutes ||
                        x.w.name.localeCompare(y.w.name)
                    );

                  const suggested = candidates.find((c: Candidate) => c.available && c.compatible)?.w.id
                    ?? candidates.find((c: Candidate) => c.available)?.w.id
                    ?? '';

                  return (
                    <form method="post" class="flex items-center gap-2 w-full">
                      <input type="hidden" name="_action" value="assign" />
                      <input type="hidden" name="assignmentId" value={a.id} />
                      <select class={`w-full max-w-full rounded-lg border ${a.assigned_worker_id ? 'border-zinc-300' : 'border-amber-300 bg-amber-50 text-amber-900'} px-2 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all`} name="workerId">
                        <option value="">— Sin asignar —</option>
                        {candidates.map(({ w, available, habitual, compatible }: Candidate) => (
                          <option value={w.id} selected={a.assigned_worker_id === w.id || (!a.assigned_worker_id && suggested === w.id)}>
                            {habitual ? '★ ' : ''}
                            {w.name} ({formatMinutes(workerLoadMinutes.get(w.id) ?? 0)}) {compatible ? '' : '(tipo no compatible)'} {available ? '' : '(solape)'}
                          </option>
                        ))}
                      </select>
                      
                      {!a.assigned_worker_id && (
                        <span class="ml-2 flex h-2 w-2 rounded-full bg-amber-500" title="Requiere asignación"></span>
                      )}
                    </form>
                  );
                })()}
              </td>
            </tr>
          ))}
          
          {viewRows.length === 0 && (
            <tr>
              <td colspan="4" class="px-4 py-8 text-center text-zinc-500 italic">
                No hay servicios planificados para esta semana. Genera el cuadrante usando las plantillas.
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
    <h2 class="text-sm font-semibold">Vista por día</h2>
    <p class="mt-1 text-xs text-zinc-600">Lectura rápida para revisar por fecha qué usuario tiene servicio, horario y trabajadora asignada.</p>
    <div class="mt-4 space-y-3">
      {groupedDays.map((day) => {
        const workersMap = assignedWorkerMapByDate.get(day.date) ?? new Map();
        const dayWorkers = Array.from(workersMap.entries())
          .map(([id, name]) => ({ id, name }))
          .sort((a, b) => a.name.localeCompare(b.name));
        const dayTravelTotal = travelSumByDate.get(day.date) ?? 0;

        return (
          <details class="rounded-xl border border-zinc-200 bg-zinc-50/40 day-group" data-date={day.date} open>
            <summary class="cursor-pointer select-none px-4 py-3 text-sm font-semibold text-zinc-800">
              {formatDateEs(day.date)} · {day.items.length} servicios · Desplazamientos: {travelExtrasAvailable ? formatTravelMinutes(dayTravelTotal) : '—'}
            </summary>
            <div class="border-t border-zinc-200 bg-white">
              {day.items.map((a: AssignmentRow) => (
                <div class="day-item grid gap-2 border-b border-zinc-100 px-4 py-3 text-sm last:border-b-0 md:grid-cols-[1fr_auto_auto]" data-assignment-id={a.id} data-user={a.user_name} data-worker={a.worker_name ?? ''} data-assigned={a.assigned_worker_id ? '1' : '0'}>
                  <div class="font-semibold text-emerald-700 uppercase">{a.user_name}</div>
                  <div class="font-medium text-[#4B79A1]">{a.planned_start} - {a.planned_end}</div>
                  <div class="text-zinc-600 day-worker-name">{a.worker_name ?? 'Sin asignar'}</div>
                </div>
              ))}

              {travelExtrasAvailable && dayWorkers.length > 0 && (
                <div class="border-t border-zinc-100 bg-zinc-50/40 px-4 py-3">
                  <div class="text-xs font-semibold uppercase tracking-wider text-zinc-600">Desplazamientos por trabajadora (min)</div>
                  <div class="mt-2 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
                    {dayWorkers.map((w: { id: string; name: string }) => (
                      <form method="post" class="flex items-center justify-between gap-2 rounded-lg border border-zinc-200 bg-white px-3 py-2">
                        <input type="hidden" name="_action" value="set_travel" />
                        <input type="hidden" name="workerId" value={w.id} />
                        <input type="hidden" name="date" value={day.date} />
                        <div class="min-w-0 flex-1 text-xs font-semibold text-zinc-800 truncate">{w.name}</div>
                        <input
                          class="w-20 rounded-lg border border-zinc-300 px-2 py-1 text-sm"
                          name="travelMinutes"
                          type="number"
                          min="0"
                          step="1"
                          value={travelByWorkerDate.get(`${w.id}|${day.date}`) ?? 0}
                        />
                        <button class="rounded-lg bg-zinc-900 px-2 py-1 text-xs font-semibold text-white">OK</button>
                      </form>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </details>
        );
      })}

      {travelExtrasAvailable && groupedDays.length > 0 && (
        <div class="rounded-xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm flex items-center justify-between">
          <span class="font-semibold text-indigo-900">Total desplazamientos semana</span>
          <span class="font-bold text-indigo-900">{formatTravelMinutes(travelWeekTotal)}</span>
        </div>
      )}
      {groupedDays.length === 0 && (
        <div class="rounded-lg border border-zinc-200 px-4 py-4 text-sm text-zinc-500 italic">
          No hay servicios para mostrar por día en esta semana.
        </div>
      )}
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filterUser = document.getElementById('filter-user') as HTMLInputElement;
      const filterWorker = document.getElementById('filter-worker') as HTMLInputElement;
      const filterUnassigned = document.getElementById('filter-unassigned') as HTMLInputElement;
      const rows = document.querySelectorAll('.assignment-row') as NodeListOf<HTMLElement>;
      const dayItems = document.querySelectorAll('.day-item') as NodeListOf<HTMLElement>;
      const dayGroups = document.querySelectorAll('.day-group') as NodeListOf<HTMLElement>;
      const countEl = document.getElementById('assignments-count');
      
      const normalize = (str: string) => str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
      const extractWorkerName = (label: string) =>
        label.replace(/^★\s*/, '').split(' (')[0]?.trim() ?? '';

      const syncWorkerIndexFromSelect = () => {
        rows.forEach((row) => {
          const select = row.querySelector('select[name="workerId"]') as HTMLSelectElement | null;
          if (!select || !select.value) {
            row.setAttribute('data-worker', '');
            return;
          }
          const selectedLabel = select.selectedOptions?.[0]?.textContent ?? '';
          row.setAttribute('data-worker', extractWorkerName(selectedLabel));
        });
      };
      
      const updateFilters = () => {
        const uQuery = normalize(filterUser.value.trim());
        const wQuery = normalize(filterWorker.value.trim());
        const onlyUnassigned = Boolean(filterUnassigned?.checked);
        
        let visibleCount = 0;
        
        rows.forEach(row => {
          const rUser = normalize(row.getAttribute('data-user') || '');
          const rWorker = normalize(row.getAttribute('data-worker') || '');
          const rAssigned = row.getAttribute('data-assigned') === '1';
          
          const matchUser = !uQuery || rUser.includes(uQuery);
          const matchWorker = !wQuery || rWorker.includes(wQuery);
          const matchUnassigned = !onlyUnassigned || !rAssigned;
          
          if (matchUser && matchWorker && matchUnassigned) {
            row.style.display = '';
            visibleCount++;
          } else {
            row.style.display = 'none';
          }
        });

        dayItems.forEach((item) => {
          const rUser = normalize(item.getAttribute('data-user') || '');
          const rWorker = normalize(item.getAttribute('data-worker') || '');
          const rAssigned = item.getAttribute('data-assigned') === '1';

          const matchUser = !uQuery || rUser.includes(uQuery);
          const matchWorker = !wQuery || rWorker.includes(wQuery);
          const matchUnassigned = !onlyUnassigned || !rAssigned;
          item.style.display = matchUser && matchWorker && matchUnassigned ? '' : 'none';
        });

        dayGroups.forEach((group) => {
          const visibleItems = group.querySelectorAll('.day-item:not([style*="display: none"])').length;
          group.style.display = visibleItems > 0 ? '' : 'none';
        });
        
        if (countEl) {
          countEl.textContent = `Servicios Planificados (${visibleCount})`;
        }
      };

      if (filterUser && filterWorker) {
        filterUser.addEventListener('input', updateFilters);
        filterWorker.addEventListener('input', updateFilters);
      }
      if (filterUnassigned) {
        filterUnassigned.addEventListener('change', updateFilters);
      }

      rows.forEach((row) => {
        const select = row.querySelector('select[name="workerId"]') as HTMLSelectElement | null;
        if (!select) return;
        select.addEventListener('change', () => {
          const selectedLabel = select.selectedOptions?.[0]?.textContent ?? '';
          const selectedWorker = select.value ? extractWorkerName(selectedLabel) : '';
          row.setAttribute('data-worker', selectedWorker);
          row.setAttribute('data-assigned', select.value ? '1' : '0');
          const assignmentIdInput = row.querySelector('input[name="assignmentId"]') as HTMLInputElement | null;
          if (assignmentIdInput?.value) {
            const mirror = document.querySelector(`.day-item[data-assignment-id="${assignmentIdInput.value}"]`) as HTMLElement | null;
            if (mirror) {
              mirror.setAttribute('data-worker', selectedWorker);
              mirror.setAttribute('data-assigned', select.value ? '1' : '0');
              const workerText = mirror.querySelector('.day-worker-name');
              if (workerText) workerText.textContent = selectedWorker || 'Sin asignar';
            }
          }
          updateFilters();
          select.form?.requestSubmit();
        });
      });

      const resetBtn = document.getElementById('reset-filters');
      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          if (filterUser) filterUser.value = '';
          if (filterWorker) filterWorker.value = '';
          if (filterUnassigned) filterUnassigned.checked = false;
          updateFilters();
        });
      }

      syncWorkerIndexFromSelect();
      updateFilters();
    });
  </script>
</AppLayout>
