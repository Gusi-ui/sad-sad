---
import AppLayout from '../../../layouts/AppLayout.astro';

export const prerender = false;

const now = new Date();
const ymParam = String(Astro.url.searchParams.get('ym') ?? '').trim(); // YYYY-MM
const parsedYear = ymParam ? Number(ymParam.split('-')[0]) : Number(Astro.url.searchParams.get('year') ?? now.getFullYear());
const parsedMonth = ymParam ? Number(ymParam.split('-')[1]) : Number(Astro.url.searchParams.get('month') ?? now.getMonth() + 1);
const safeYear = Number.isFinite(parsedYear) ? parsedYear : now.getFullYear();
const safeMonth = Number.isFinite(parsedMonth) && parsedMonth >= 1 && parsedMonth <= 12 ? parsedMonth : now.getMonth() + 1;
const monthLabel = `${safeYear}-${String(safeMonth).padStart(2, '0')}`;
---
<AppLayout title="Balances | Admin">
  <div class="ui-header">
    <div>
      <div class="text-sm font-medium text-zinc-500">Balances</div>
      <h1 class="ui-title mt-1">Resumen mensual</h1>
      <p class="ui-subtitle">Cuotas, contratos y comparativas por usuario y trabajadora.</p>
    </div>

    <form class="flex items-end gap-2" method="get">
      <label class="block">
        <span class="text-xs font-semibold uppercase tracking-wider text-zinc-500">Mes</span>
        <input class="ui-input mt-1 h-10" type="month" name="ym" value={monthLabel} />
      </label>
      <button class="ui-btn ui-btn-primary h-10 px-4">Ver</button>
    </form>
  </div>

  <div class="mt-6 grid gap-4 md:grid-cols-2">
    <a
      class="group rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm hover:border-emerald-300 transition-colors"
      href={`/admin/balances/users?year=${safeYear}&month=${safeMonth}`}
    >
      <div class="flex items-start justify-between gap-3">
        <div>
          <div class="text-sm font-semibold text-zinc-900">Usuarios/as</div>
          <div class="mt-1 text-sm text-zinc-600">Cuota mensual vs horas planificadas, con detalle por día y semana.</div>
        </div>
        <div class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-700">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
        </div>
      </div>
      <div class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 group-hover:text-emerald-800">
        Abrir
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m13 5 7 7-7 7"></path></svg>
      </div>
    </a>

    <a
      class="group rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm hover:border-indigo-300 transition-colors"
      href={`/admin/balances/workers?year=${safeYear}&month=${safeMonth}`}
    >
      <div class="flex items-start justify-between gap-3">
        <div>
          <div class="text-sm font-semibold text-zinc-900">Trabajadoras</div>
          <div class="mt-1 text-sm text-zinc-600">Contrato vs horas planificadas, con descansos y desplazamientos.</div>
        </div>
        <div class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-700">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 9-5 5-4-4-3 3"></path><path d="M3 3v18h18"></path></svg>
        </div>
      </div>
      <div class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-indigo-700 group-hover:text-indigo-800">
        Abrir
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m13 5 7 7-7 7"></path></svg>
      </div>
    </a>
  </div>
</AppLayout>
