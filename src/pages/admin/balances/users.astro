---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { computeUsersForecastMinutesForMonth, hours } from '../../../lib/balances';
import { formatHours } from '../../../lib/month-hours';

export const prerender = false;

const now = new Date();
const year = Number(Astro.url.searchParams.get('year') ?? now.getFullYear());
const month = Number(Astro.url.searchParams.get('month') ?? now.getMonth() + 1);
const safeYear = Number.isFinite(year) ? year : now.getFullYear();
const safeMonth = Number.isFinite(month) && month >= 1 && month <= 12 ? month : now.getMonth() + 1;

const database = db();

const users = await database
  .prepare(`SELECT id, name, active, monthly_hours_quota FROM service_users ORDER BY active DESC, name ASC`)
  .all<{ id: string; name: string; active: number; monthly_hours_quota: number | null }>();

const minutesByUser = await computeUsersForecastMinutesForMonth(
  database,
  users.results.map((u) => u.id),
  safeYear,
  safeMonth
);

const fmt = (h: number) => formatHours(h);
---

<AppLayout title="Balances Usuarios | Admin">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <a class="text-sm font-medium text-zinc-600 hover:text-zinc-900 transition-colors" href="/admin/balances">← Balances</a>
      <h1 class="mt-1 text-2xl font-bold tracking-tight text-zinc-900">Usuarios/as</h1>
      <p class="mt-1 text-sm text-zinc-600">Mes {safeYear}-{String(safeMonth).padStart(2, '0')}</p>
    </div>

    <form class="flex flex-wrap items-end gap-2" method="get">
      <label class="block">
        <span class="text-xs font-semibold uppercase tracking-wider text-zinc-500">Año</span>
        <input class="mt-1 h-10 w-28 rounded-xl border border-zinc-200 bg-white px-3 text-sm shadow-sm focus:border-[#0284C7] focus:outline-none focus:ring-1 focus:ring-[#0284C7]" type="number" name="year" value={safeYear} />
      </label>
      <label class="block">
        <span class="text-xs font-semibold uppercase tracking-wider text-zinc-500">Mes</span>
        <input class="mt-1 h-10 w-20 rounded-xl border border-zinc-200 bg-white px-3 text-sm shadow-sm focus:border-[#0284C7] focus:outline-none focus:ring-1 focus:ring-[#0284C7]" type="number" min="1" max="12" name="month" value={safeMonth} />
      </label>
      <button class="h-10 rounded-xl bg-zinc-900 px-4 text-sm font-semibold text-white shadow-sm hover:bg-zinc-800 transition-colors">Ver</button>
    </form>
  </div>

  <div class="mt-6 overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full min-w-[600px] text-sm">
        <thead class="bg-zinc-50 text-left text-xs uppercase tracking-wider text-zinc-600">
        <tr>
          <th class="px-4 py-3">Usuario/a</th>
          <th class="px-4 py-3">Cuota mes</th>
          <th class="px-4 py-3">Planificado</th>
          <th class="px-4 py-3">Delta</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-100">
        {users.results.map((u) => {
          const mins = minutesByUser.get(u.id) ?? 0;
          const plannedH = hours(mins);
          const quota = u.monthly_hours_quota;
          const delta = quota === null ? null : plannedH - quota;
          return (
            <tr class={u.active === 1 ? '' : 'opacity-60'}>
              <td class="px-4 py-3 font-medium text-zinc-900">{u.name}</td>
              <td class="px-4 py-3">{quota === null ? '—' : fmt(quota)}</td>
              <td class="px-4 py-3">{fmt(plannedH)}</td>
              <td class={`px-4 py-3 ${delta === null ? '' : delta > 0.01 ? 'text-rose-700' : delta < -0.01 ? 'text-emerald-700' : 'text-zinc-700'}`}>
                {delta === null ? '—' : `${delta > 0 ? '+' : ''}${fmt(delta)}`}
              </td>
              <td class="px-4 py-3 text-right">
                <a class="text-[#0284C7] hover:underline" href={`/admin/balances/users/${u.id}?year=${safeYear}&month=${safeMonth}`}>
                  Ver detalle →
                </a>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
    </div>
  </div>
</AppLayout>
