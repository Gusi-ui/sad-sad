---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { randomId } from '../../../lib/crypto';
import { toYmd } from '../../../lib/dates';
import {
  computeWorkerMonthAssignmentStats,
  formatHours,
  minutesToHours,
  pickContractForMonth
} from '../../../lib/month-hours';

export const prerender = false;

const { workerId } = Astro.params;
if (!workerId) return Astro.redirect('/admin/workers');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('_action') ?? '');
  const database = db();

  if (action === 'update_worker') {
    const name = String(formData.get('name') ?? '').trim();
    const phone = String(formData.get('phone') ?? '').trim();
    const address = String(formData.get('address') ?? '').trim();
    const workerType = String(formData.get('workerType') ?? 'laborable');
    const active = formData.get('active') === 'on' ? 1 : 0;
    if (name) {
      await database.prepare(`UPDATE workers SET name = ?, phone = ?, address = ?, worker_type = ?, active = ? WHERE id = ?`).bind(name, phone || null, address || null, workerType, active, workerId).run();
    }
    return Astro.redirect(`/admin/workers/${workerId}`);
  }

  if (action === 'delete_worker') {
    await database.prepare(`UPDATE service_users SET preferred_worker_id = NULL WHERE preferred_worker_id = ?`).bind(workerId).run();
    await database.prepare(`UPDATE service_users SET preferred_weekend_worker_id = NULL WHERE preferred_weekend_worker_id = ?`).bind(workerId).run();
    await database.prepare(`UPDATE assignments SET assigned_worker_id = NULL WHERE assigned_worker_id = ?`).bind(workerId).run();
    await database.prepare(`DELETE FROM sessions WHERE account_id IN (SELECT id FROM accounts WHERE worker_id = ?)`).bind(workerId).run();
    await database.prepare(`DELETE FROM worker_contracts WHERE worker_id = ?`).bind(workerId).run();
    await database.prepare(`DELETE FROM accounts WHERE worker_id = ?`).bind(workerId).run();
    await database.prepare(`DELETE FROM workers WHERE id = ?`).bind(workerId).run();
    return Astro.redirect('/admin/workers');
  }

  if (action === 'add_contract') {
    const hoursPerWeekRaw = String(formData.get('hoursPerWeek') ?? '').trim();
    const hoursPerWeek = Number(hoursPerWeekRaw);
    const hoursPerMonthRaw = String(formData.get('hoursPerMonth') ?? '').trim();
    const hoursPerMonthParsed = hoursPerMonthRaw === '' ? null : Number(hoursPerMonthRaw);
    const hoursPerMonth =
      hoursPerMonthParsed === null || !Number.isFinite(hoursPerMonthParsed) ? null : hoursPerMonthParsed;
    const startDate = String(formData.get('startDate') ?? '').trim();
    const endDate = String(formData.get('endDate') ?? '').trim();

    if (Number.isFinite(hoursPerWeek) && hoursPerWeek > 0 && startDate) {
      await database
        .prepare(
          `INSERT INTO worker_contracts (id, worker_id, hours_per_week, hours_per_month, start_date, end_date) VALUES (?, ?, ?, ?, ?, ?)`
        )
        .bind(randomId(), workerId, hoursPerWeek, hoursPerMonth, startDate, endDate || null)
        .run();
    }
    return Astro.redirect(`/admin/workers/${workerId}`);
  }
}

const worker = await db()
  .prepare(`SELECT id, name, phone, address, active, worker_type, created_at FROM workers WHERE id = ? LIMIT 1`)
  .bind(workerId)
  .first<{ id: string; name: string; phone: string | null; address: string | null; active: number; worker_type: string; created_at: string }>();

if (!worker) return Astro.redirect('/admin/workers');

const contracts = await db()
  .prepare(
    `SELECT id, hours_per_week, hours_per_month, start_date, end_date FROM worker_contracts WHERE worker_id = ? ORDER BY start_date DESC`
  )
  .bind(workerId)
  .all<{ id: string; hours_per_week: number; hours_per_month: number | null; start_date: string; end_date: string | null }>();

type ContractRow = (typeof contracts.results)[number];

const today = toYmd(new Date());

const now = new Date();
const wYear = Number(Astro.url.searchParams.get('year') ?? now.getFullYear());
const wMonth = Number(Astro.url.searchParams.get('month') ?? now.getMonth() + 1);
const safeWYear = Number.isFinite(wYear) ? wYear : now.getFullYear();
const safeWMonth = Number.isFinite(wMonth) && wMonth >= 1 && wMonth <= 12 ? wMonth : now.getMonth() + 1;

const workerMonthStats = await computeWorkerMonthAssignmentStats(db(), workerId, safeWYear, safeWMonth);
const assignedHours = minutesToHours(workerMonthStats.assignedMinutes);
const contractForMonth = pickContractForMonth(contracts.results, safeWYear, safeWMonth);
const monthlyCap = contractForMonth?.hours_per_month ?? null;
const deltaWorker = monthlyCap !== null ? assignedHours - monthlyCap : null;
const weeklyContract = contractForMonth?.hours_per_week ?? null;
const deltaAvgVsWeekly =
  weeklyContract !== null ? workerMonthStats.avgWeeklyAssignedHours - weeklyContract : null;
---

<AppLayout title={`${worker.name} | Admin`}>
  <div class="flex items-start justify-between gap-4">
    <div>
      <a class="text-sm font-medium text-zinc-700 underline decoration-zinc-300" href="/admin/workers">← Volver a trabajadoras</a>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight">{worker.name}</h1>
      <p class="mt-1 text-sm text-zinc-600">ID: {worker.id}</p>
    </div>
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-2">
    <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm lg:col-span-2">
      <h2 class="text-sm font-semibold">Datos</h2>
      <form method="post" class="mt-4 grid gap-4 sm:grid-cols-2">
        <input type="hidden" name="_action" value="update_worker" />
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Nombre</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="name" value={worker.name} required />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Teléfono</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="phone" value={worker.phone || ''} type="tel" />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Dirección</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="address" value={worker.address || ''} />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Tipo</span>
          <select class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="workerType">
            <option value="laborable" selected={worker.worker_type === 'laborable'}>Laborable</option>
            <option value="festivo" selected={worker.worker_type === 'festivo'}>Festivo/Finde</option>
            <option value="ambos" selected={worker.worker_type === 'ambos'}>Ambos</option>
          </select>
        </label>

        <div class="sm:col-span-2 flex items-center justify-between mt-2 border-t border-zinc-100 pt-4">
          <label class="flex items-center gap-2">
            <input class="h-4 w-4" type="checkbox" name="active" checked={worker.active === 1} />
            <span class="text-sm font-medium text-zinc-700">Trabajadora activa</span>
          </label>
          <button class="rounded-lg bg-[#0284C7] hover:bg-sky-700 transition-colors px-6 py-2 text-sm font-bold text-white shadow-sm">Guardar cambios</button>
        </div>
      </form>
    </section>

    <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm lg:col-span-2">
      <h2 class="text-sm font-semibold">Contrato (semana y mes)</h2>
      <form method="post" class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <input type="hidden" name="_action" value="add_contract" />
        <label class="block sm:col-span-1">
          <span class="text-sm font-medium text-zinc-700">Horas/semana</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="hoursPerWeek" inputmode="decimal" required />
        </label>
        <label class="block sm:col-span-1">
          <span class="text-sm font-medium text-zinc-700">Horas/mes (opcional)</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="hoursPerMonth" inputmode="decimal" placeholder="Para cuadre mensual" />
        </label>
        <label class="block sm:col-span-1">
          <span class="text-sm font-medium text-zinc-700">Inicio</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" type="date" name="startDate" value={today} required />
        </label>
        <label class="block sm:col-span-1">
          <span class="text-sm font-medium text-zinc-700">Fin (opcional)</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" type="date" name="endDate" />
        </label>
        <button class="sm:col-span-2 lg:col-span-4 rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white">
          Añadir contrato
        </button>
      </form>

      <div class="mt-6 overflow-x-auto">
        <table class="w-full min-w-[520px] text-left text-sm">
          <thead class="text-xs uppercase text-zinc-500">
            <tr>
              <th class="px-3 py-2">Horas/semana</th>
              <th class="px-3 py-2">Horas/mes</th>
              <th class="px-3 py-2">Inicio</th>
              <th class="px-3 py-2">Fin</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-100">
            {contracts.results.map((c: ContractRow) => (
              <tr>
                <td class="px-3 py-2">{c.hours_per_week}</td>
                <td class="px-3 py-2">{c.hours_per_month ?? '—'}</td>
                <td class="px-3 py-2">{c.start_date}</td>
                <td class="px-3 py-2">{c.end_date ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm lg:col-span-2">
      <h2 class="text-sm font-semibold">Cuadre trabajadora (mes natural)</h2>
      <p class="mt-1 text-xs text-zinc-600">
        Suma horas en <code class="rounded bg-zinc-100 px-1">assignments</code> (no cancelados), cuenta <strong>días con al menos un servicio</strong> y calcula una
        <strong>media semanal del mes</strong> dividiendo las horas entre las semanas ISO que toca el mes (suele ser 4–5; a veces 6). El contrato habitual es en
        h/semana: así se ve si el mes ha quedado por encima o por debajo del ritmo contractual. Opcionalmente compara con <strong>horas/mes</strong> si están en el contrato.
      </p>

      <form method="get" class="mt-4 flex flex-wrap items-end gap-3">
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Año</span>
          <input class="mt-1 w-28 rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="year" type="number" value={safeWYear} />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Mes</span>
          <input class="mt-1 w-24 rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="month" type="number" min="1" max="12" value={safeWMonth} />
        </label>
        <button class="rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white">Calcular</button>
      </form>

      <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="text-xs text-zinc-500">Horas del mes (assignments)</div>
          <div class="mt-1 text-xl font-semibold">{formatHours(assignedHours)}</div>
          <div class="mt-0.5 text-xs text-zinc-600">{assignedHours.toFixed(2)} h</div>
        </div>
        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="text-xs text-zinc-500">Días con servicio</div>
          <div class="mt-1 text-xl font-semibold">{workerMonthStats.distinctServiceDays}</div>
          <div class="mt-0.5 text-xs text-zinc-600">Días distintos con al menos un turno</div>
        </div>
        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="text-xs text-zinc-500">Semanas ISO en el mes</div>
          <div class="mt-1 text-xl font-semibold">{workerMonthStats.isoWeeksInMonth}</div>
          <div class="mt-0.5 text-xs text-zinc-600">Para media semanal del mes</div>
        </div>
        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="text-xs text-zinc-500">Media semanal (este mes)</div>
          <div class="mt-1 text-xl font-semibold">{formatHours(workerMonthStats.avgWeeklyAssignedHours)}</div>
          <div class="mt-0.5 text-xs text-zinc-600">{workerMonthStats.avgWeeklyAssignedHours.toFixed(2)} h / semana ISO</div>
        </div>
      </div>

      <div class="mt-4 grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="text-sm font-semibold">Contrato vigente en el mes</div>
          {contractForMonth ? (
            <div class="mt-2 text-sm text-zinc-700">
              <div>Semanal: {contractForMonth.hours_per_week} h/semana</div>
              <div class="mt-1">Mensual: {contractForMonth.hours_per_month !== null ? `${contractForMonth.hours_per_month} h` : '— (opcional en contrato)'}</div>
            </div>
          ) : (
            <div class="mt-2 text-sm text-zinc-600">Sin contrato que cubra este mes.</div>
          )}
          {deltaAvgVsWeekly !== null ? (
            <div
              class={`mt-3 text-sm font-medium ${deltaAvgVsWeekly > 0.02 ? 'text-amber-700' : deltaAvgVsWeekly < -0.02 ? 'text-blue-700' : 'text-emerald-700'}`}
            >
              {deltaAvgVsWeekly > 0.02
                ? `La media del mes (~${workerMonthStats.avgWeeklyAssignedHours.toFixed(2)} h/sem.) supera el contrato (${weeklyContract} h/sem.) en ~${Math.abs(deltaAvgVsWeekly).toFixed(2)} h`
                : deltaAvgVsWeekly < -0.02
                  ? `La media del mes queda ~${Math.abs(deltaAvgVsWeekly).toFixed(2)} h/sem. por debajo del contrato (${weeklyContract} h/sem.)`
                  : 'La media semanal del mes cuadra con el contrato (aprox.)'}
            </div>
          ) : (
            <div class="mt-3 text-xs text-zinc-500">Añade un contrato con h/semana para comparar con la media del mes.</div>
          )}
          {deltaWorker !== null ? (
            <div
              class={`mt-3 border-t border-zinc-100 pt-3 text-sm font-medium ${deltaWorker > 0.02 ? 'text-amber-700' : deltaWorker < -0.02 ? 'text-blue-700' : 'text-emerald-700'}`}
            >
              {deltaWorker > 0.02
                ? `Horas del mes: sobran ~${Math.abs(deltaWorker).toFixed(2)} h respecto al tope mensual del contrato`
                : deltaWorker < -0.02
                  ? `Horas del mes: faltan ~${Math.abs(deltaWorker).toFixed(2)} h para el tope mensual del contrato`
                  : 'Horas del mes: cuadra con el tope mensual (aprox.)'}
            </div>
          ) : (
            <div class="mt-3 border-t border-zinc-100 pt-3 text-xs text-zinc-500">Opcional: define horas/mes en el contrato para cuadre mensual explícito.</div>
          )}
        </div>
        <div class="rounded-xl border border-dashed border-zinc-200 bg-zinc-50 p-4 text-xs text-zinc-600">
          <p>
            Los meses no tienen siempre “las mismas semanas”: por eso las horas del mes se comparan con el contrato semanal usando{' '}
            <strong>horas ÷ semanas ISO del mes</strong>. Si además guardas <strong>horas/mes</strong> en el contrato, aparece el segundo cuadre (tope mensual).
          </p>
        </div>
      </div>
    </section>

    <section class="rounded-2xl border border-red-200 bg-red-50 p-5 shadow-sm lg:col-span-2">
      <h2 class="text-sm font-semibold text-red-800">Zona de peligro</h2>
      <p class="mt-1 text-xs text-red-600">
        Eliminar a esta trabajadora es una acción irreversible. Se perderán todos sus datos y relaciones.
      </p>
      <form method="post" class="mt-4" onsubmit="return confirm('¿Estás completamente seguro de que deseas eliminar esta trabajadora?');">
        <input type="hidden" name="_action" value="delete_worker" />
        <button class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">
          Eliminar trabajadora
        </button>
      </form>
    </section>
  </div>
</AppLayout>
