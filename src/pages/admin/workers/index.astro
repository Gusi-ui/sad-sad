---
import AppLayout from '../../../layouts/AppLayout.astro';
import EntitySearchList from '../../../components/EntitySearchList.astro';
import { db } from '../../../lib/db';

const workers = await db()
  .prepare(
    `
    SELECT w.id, w.name, w.active, w.worker_type, w.phone, w.address,
           a.email
    FROM workers w
    LEFT JOIN accounts a ON a.worker_id = w.id AND a.role = 'WORKER'
    ORDER BY w.name ASC
  `
  )
  .all<{ id: string; name: string; active: number; worker_type: string; phone: string | null; address: string | null; email: string | null }>();

const items = workers.results.map((w) => ({
  id: w.id,
  name: w.name,
  href: `/admin/workers/${w.id}`,
  active: w.active,
  meta: w.phone || 'Sin teléfono',
  detail: w.worker_type
}));
---

<AppLayout title="Trabajadoras | Admin">
  <div class="ui-header">
    <div>
      <div class="ui-breadcrumbs">
        <a class="hover:text-zinc-900 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-300">/</span>
        <span class="text-zinc-800">Trabajadoras</span>
        <span class="ui-badge bg-sky-100 text-sky-900">Total {workers.results.length}</span>
      </div>
      <h1 class="ui-title">Trabajadoras</h1>
      <p class="ui-subtitle">La lista se muestra completa y se filtra al escribir.</p>
    </div>
    <a href="/admin/workers/new" class="ui-btn ui-btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      Nueva trabajadora
    </a>
  </div>

  <div class="mt-6 max-w-3xl">
    <EntitySearchList
      id="workers"
      placeholder="Buscar por nombre…"
      items={items}
      emptyText="No se encontraron trabajadoras."
    />
  </div>
</AppLayout>
