---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { randomId, hashPassword } from '../../../lib/crypto';

const account = Astro.locals.account;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = String(formData.get('name') ?? '').trim();
  const workerType = String(formData.get('workerType') ?? 'laborable');
  const email = String(formData.get('email') ?? '').trim().toLowerCase();
  const password = String(formData.get('password') ?? '');

  if (name && email && password) {
    const workerId = randomId();
    const accountId = randomId();
    const pwd = await hashPassword(password);

    const database = db();
    await database
      .prepare(`INSERT INTO workers (id, name, worker_type) VALUES (?, ?, ?)`)
      .bind(workerId, name, workerType)
      .run();

    await database
      .prepare(
        `INSERT INTO accounts (id, email, password_hash, password_salt, password_iterations, role, worker_id) VALUES (?, ?, ?, ?, ?, 'WORKER', ?)`
      )
      .bind(accountId, email, pwd.hashBase64, pwd.saltBase64, pwd.iterations, workerId)
      .run();

    return Astro.redirect('/admin/workers');
  }
}

const workers = await db()
  .prepare(
    `
    SELECT w.id, w.name, w.active, w.worker_type,
           a.email
    FROM workers w
    LEFT JOIN accounts a ON a.worker_id = w.id AND a.role = 'WORKER'
    ORDER BY w.created_at DESC
  `
  )
  .all<{ id: string; name: string; active: number; worker_type: string; email: string | null }>();

type WorkerRow = (typeof workers.results)[number];
---

<AppLayout title="Trabajadoras | Admin">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Trabajadoras</h1>
      <p class="mt-1 text-sm text-zinc-600">Sesión: {account?.email}</p>
    </div>
    <a class="rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm font-medium" href="/admin">
      Volver
    </a>
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-3">
    <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm lg:col-span-1">
      <h2 class="text-sm font-semibold">Alta trabajadora</h2>
      <form method="post" class="mt-4 space-y-4">
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Nombre</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="name" required />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Tipo</span>
          <select class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" name="workerType">
            <option value="laborable">Laborable</option>
            <option value="festivo">Festivo/Finde</option>
            <option value="ambos">Ambos</option>
          </select>
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Email</span>
          <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm" type="email" name="email" required />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Contraseña</span>
          <input
            class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm"
            type="password"
            name="password"
            required
          />
        </label>

        <button class="inline-flex w-full items-center justify-center rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white">
          Crear
        </button>
      </form>
    </section>

    <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm lg:col-span-2">
      <h2 class="text-sm font-semibold">Listado</h2>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[720px] text-left text-sm">
          <thead class="text-xs uppercase text-zinc-500">
            <tr>
              <th class="px-3 py-2">Nombre</th>
              <th class="px-3 py-2">Email</th>
              <th class="px-3 py-2">Tipo</th>
              <th class="px-3 py-2">Activa</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-100">
            {workers.results.map((w: WorkerRow) => (
              <tr>
                <td class="px-3 py-2">
                  <a class="font-medium text-zinc-900 underline decoration-zinc-300" href={`/admin/workers/${w.id}`}>
                    {w.name}
                  </a>
                </td>
                <td class="px-3 py-2 text-zinc-700">{w.email ?? '—'}</td>
                <td class="px-3 py-2 text-zinc-700">{w.worker_type}</td>
                <td class="px-3 py-2 text-zinc-700">{w.active === 1 ? 'Sí' : 'No'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</AppLayout>

