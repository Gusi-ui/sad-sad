---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { randomId, hashPassword } from '../../../lib/crypto';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = String(formData.get('name') ?? '').trim();
  const workerType = String(formData.get('workerType') ?? 'laborable');
  const email = String(formData.get('email') ?? '').trim().toLowerCase();
  const password = String(formData.get('password') ?? '');
  const phone = String(formData.get('phone') ?? '').trim();
  const address = String(formData.get('address') ?? '').trim();

  if (name && email && password) {
    const workerId = randomId();
    const accountId = randomId();
    const pwd = await hashPassword(password);

    const database = db();
    await database
      .prepare(`INSERT INTO workers (id, name, worker_type, phone, address) VALUES (?, ?, ?, ?, ?)`)
      .bind(workerId, name, workerType, phone || null, address || null)
      .run();

    await database
      .prepare(
        `INSERT INTO accounts (id, email, password_hash, password_salt, password_iterations, role, worker_id) VALUES (?, ?, ?, ?, ?, 'WORKER', ?)`
      )
      .bind(accountId, email, pwd.hashBase64, pwd.saltBase64, pwd.iterations, workerId)
      .run();

    return Astro.redirect('/admin/workers');
  }
}
---

<AppLayout title="Nueva Trabajadora | Admin">
  <div class="flex items-center justify-between border-b border-zinc-200 pb-4">
    <div>
      <div class="flex items-center gap-2">
        <a class="text-sm font-medium text-zinc-500 hover:text-zinc-800 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-400">/</span>
        <a class="text-sm font-medium text-zinc-500 hover:text-zinc-800 transition-colors" href="/admin/workers">Trabajadoras</a>
        <span class="text-zinc-400">/</span>
        <span class="text-sm font-medium text-zinc-800">Alta</span>
      </div>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-zinc-900">Nueva Trabajadora</h1>
    </div>
    <a class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium hover:bg-zinc-50 transition-colors shadow-sm" href="/admin/workers">
      Cancelar
    </a>
  </div>

  <div class="mt-6 max-w-2xl">
    <section class="rounded-2xl border border-zinc-200 bg-white p-8 shadow-sm">
      <form method="post" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="md:col-span-2">
            <h3 class="text-sm font-bold text-zinc-900 border-b border-zinc-100 pb-2 mb-4 uppercase tracking-wider">Datos Personales</h3>
            <label class="block mb-4">
              <span class="text-sm font-semibold text-zinc-700">Nombre completo *</span>
              <input class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition-all" name="name" placeholder="Ej: Rosa Robles Muñoz" required />
            </label>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <label class="block">
                <span class="text-sm font-semibold text-zinc-700">Teléfono de contacto</span>
                <input class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition-all" type="tel" name="phone" placeholder="Ej: 600 123 456" />
              </label>

              <label class="block">
                <span class="text-sm font-semibold text-zinc-700">Tipo de contrato *</span>
                <select class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition-all" name="workerType">
                  <option value="laborable">Laborable (Lunes a Viernes)</option>
                  <option value="festivo">Festivo / Fines de Semana</option>
                  <option value="ambos">Ambos (Total disponibilidad)</option>
                </select>
              </label>
            </div>

            <label class="block mt-4">
              <span class="text-sm font-semibold text-zinc-700">Dirección completa</span>
              <input class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition-all" name="address" placeholder="Ej: Calle Mayor 12, 3ºA, Madrid" />
            </label>
          </div>

          <div class="md:col-span-2 mt-2">
            <h3 class="text-sm font-bold text-zinc-900 border-b border-zinc-100 pb-2 mb-4 uppercase tracking-wider">Acceso App Móvil</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <label class="block">
                <span class="text-sm font-semibold text-zinc-700">Email de acceso *</span>
                <input class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition-all" type="email" name="email" placeholder="trabajadora@empresa.com" required />
              </label>

              <label class="block">
                <span class="text-sm font-semibold text-zinc-700">Contraseña temporal *</span>
                <input
                  class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition-all"
                  type="password"
                  name="password"
                  placeholder="Mínimo 8 caracteres"
                  required
                />
              </label>
            </div>
          </div>
        </div>

        <div class="pt-4 border-t border-zinc-100 flex justify-end gap-3">
          <a href="/admin/workers" class="px-4 py-2.5 text-sm font-medium text-zinc-700 hover:bg-zinc-50 rounded-lg transition-colors">Cancelar</a>
          <button class="inline-flex items-center justify-center rounded-lg bg-[#0284C7] hover:bg-sky-700 transition-colors px-6 py-2.5 text-sm font-bold text-white shadow-sm">
            Guardar trabajadora
          </button>
        </div>
      </form>
    </section>
  </div>
</AppLayout>