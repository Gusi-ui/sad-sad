---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { randomId, hashPassword } from '../../../lib/crypto';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = String(formData.get('name') ?? '').trim();
  const workerType = String(formData.get('workerType') ?? 'laborable');
  const email = String(formData.get('email') ?? '').trim().toLowerCase();
  const password = String(formData.get('password') ?? '');
  const phone = String(formData.get('phone') ?? '').trim();
  const address = String(formData.get('address') ?? '').trim();

  if (name && email && password) {
    const workerId = randomId();
    const accountId = randomId();
    const pwd = await hashPassword(password);

    const database = db();
    await database
      .prepare(`INSERT INTO workers (id, name, worker_type, phone, address) VALUES (?, ?, ?, ?, ?)`)
      .bind(workerId, name, workerType, phone || null, address || null)
      .run();

    await database
      .prepare(
        `INSERT INTO accounts (id, email, password_hash, password_salt, password_iterations, role, worker_id) VALUES (?, ?, ?, ?, ?, 'WORKER', ?)`
      )
      .bind(accountId, email, pwd.hashBase64, pwd.saltBase64, pwd.iterations, workerId)
      .run();

    return Astro.redirect('/admin/workers');
  }
}
---

<AppLayout title="Nueva Trabajadora | Admin">
  <div class="ui-header">
    <div>
      <div class="ui-breadcrumbs">
        <a class="hover:text-zinc-900 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-300">/</span>
        <a class="hover:text-zinc-900 transition-colors" href="/admin/workers">Trabajadoras</a>
        <span class="text-zinc-300">/</span>
        <span class="text-zinc-800">Alta</span>
      </div>
      <h1 class="ui-title">Nueva trabajadora</h1>
      <p class="ui-subtitle">Datos personales y acceso a la app móvil.</p>
    </div>
    <a class="ui-btn ui-btn-secondary" href="/admin/workers">Cancelar</a>
  </div>

  <div class="mt-6 max-w-2xl">
    <section class="ui-card-solid p-8">
      <form method="post" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="md:col-span-2">
            <h3 class="text-sm font-bold text-zinc-900 border-b border-zinc-100 pb-2 mb-4 uppercase tracking-wider">Datos Personales</h3>
            <label class="block mb-4">
              <span class="ui-label">Nombre completo *</span>
              <input class="ui-input mt-1.5" name="name" placeholder="Ej: Rosa Robles Muñoz" required />
            </label>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <label class="block">
                <span class="ui-label">Teléfono de contacto</span>
                <input class="ui-input mt-1.5" type="tel" name="phone" placeholder="Ej: 600 123 456" />
              </label>

              <label class="block">
                <span class="ui-label">Tipo de contrato *</span>
                <select class="ui-select mt-1.5" name="workerType">
                  <option value="laborable">Laborable (Lunes a Viernes)</option>
                  <option value="festivo">Festivo / Fines de Semana</option>
                  <option value="ambos">Ambos (Total disponibilidad)</option>
                </select>
              </label>
            </div>

            <label class="block mt-4">
              <span class="ui-label">Dirección completa</span>
              <input class="ui-input mt-1.5" name="address" placeholder="Ej: Calle Mayor 12, 3ºA, Madrid" />
            </label>
          </div>

          <div class="md:col-span-2 mt-2">
            <h3 class="text-sm font-bold text-zinc-900 border-b border-zinc-100 pb-2 mb-4 uppercase tracking-wider">Acceso App Móvil</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <label class="block">
                <span class="ui-label">Email de acceso *</span>
                <input class="ui-input mt-1.5" type="email" name="email" placeholder="trabajadora@empresa.com" required />
              </label>

              <label class="block">
                <span class="ui-label">Contraseña temporal *</span>
                <input
                  class="ui-input mt-1.5"
                  type="password"
                  name="password"
                  placeholder="Mínimo 8 caracteres"
                  required
                />
              </label>
            </div>
          </div>
        </div>

        <div class="pt-4 border-t border-zinc-100 flex justify-end gap-3">
          <a href="/admin/workers" class="ui-btn ui-btn-secondary px-4 py-2.5">Cancelar</a>
          <button class="ui-btn ui-btn-primary px-6 py-2.5">
            Guardar trabajadora
          </button>
        </div>
      </form>
    </section>
  </div>
</AppLayout>
