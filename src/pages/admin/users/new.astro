---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { randomId } from '../../../lib/crypto';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action');

  if (action === 'create_user') {
    const name = String(formData.get('name') ?? '').trim();
    const address = String(formData.get('address') ?? '').trim();
    const phone = String(formData.get('phone') ?? '').trim();
    const notes = String(formData.get('notes') ?? '').trim();

    if (name) {
      const id = randomId();
      await db()
        .prepare(`INSERT INTO service_users (id, name, address, phone, notes) VALUES (?, ?, ?, ?, ?)`)
        .bind(id, name, address || null, phone || null, notes || null)
        .run();
      return Astro.redirect(`/admin/users/${id}`);
    }
  }
}


---

<AppLayout title="Nuevo Usuario/a | Admin">
  <div class="ui-header">
    <div>
      <div class="ui-breadcrumbs">
        <a class="hover:text-zinc-900 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-300">/</span>
        <a class="hover:text-zinc-900 transition-colors" href="/admin/users">Usuarios/as</a>
        <span class="text-zinc-300">/</span>
        <span class="text-zinc-800">Nuevo</span>
      </div>
      <h1 class="ui-title">Nuevo/a usuario/a</h1>
      <p class="ui-subtitle">Registra los datos básicos del beneficiario.</p>
    </div>
    <a class="ui-btn ui-btn-secondary" href="/admin/users">Volver</a>
  </div>

  <div class="mt-6 max-w-2xl">
    <section class="ui-card-solid ui-card-body">
      <h2 class="text-base font-semibold text-zinc-900">Datos</h2>
      <form method="post" class="space-y-4">
        <input type="hidden" name="_action" value="create_user" />
        
        <label class="block">
          <span class="ui-label">Nombre completo</span>
          <input class="ui-input mt-1.5" name="name" placeholder="Ej: Dolores Góngora Orive" required />
        </label>

        <label class="block">
          <span class="ui-label">Teléfono (opcional)</span>
          <input class="ui-input mt-1.5" name="phone" type="tel" placeholder="Ej: 600 123 456" />
        </label>

        <label class="block">
          <span class="ui-label">Dirección (opcional)</span>
          <input class="ui-input mt-1.5" name="address" placeholder="Ej: Calle Mayor 12, 3ºA" />
        </label>

        <label class="block">
          <span class="ui-label">Notas / Observaciones (opcional)</span>
          <textarea class="ui-textarea mt-1.5" name="notes" rows="3" placeholder="Información relevante sobre el usuario..."></textarea>
        </label>

        <div class="pt-2">
          <button class="ui-btn ui-btn-primary w-full py-2.5">
            Registrar usuario/a
          </button>
        </div>
      </form>
    </section>
  </div>
</AppLayout>
