---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { randomId } from '../../../lib/crypto';

const account = Astro.locals.account;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = String(formData.get('name') ?? '').trim();
  const address = String(formData.get('address') ?? '').trim();
  const notes = String(formData.get('notes') ?? '').trim();
  const preferredWorkerRaw = String(formData.get('preferredWorker') ?? '').trim();
  const preferredWorkerId = preferredWorkerRaw === '' ? null : preferredWorkerRaw;
  const preferredWeekendWorkerRaw = String(formData.get('preferredWeekendWorker') ?? '').trim();
  const preferredWeekendWorkerId = preferredWeekendWorkerRaw === '' ? null : preferredWeekendWorkerRaw;

  if (name) {
    await db()
      .prepare(`INSERT INTO service_users (id, name, address, notes, preferred_worker_id, preferred_weekend_worker_id) VALUES (?, ?, ?, ?, ?, ?)`)
      .bind(randomId(), name, address || null, notes || null, preferredWorkerId, preferredWeekendWorkerId)
      .run();
    return Astro.redirect('/admin/users');
  }
}

const users = await db()
  .prepare(
    `SELECT u.id, u.name, u.address, u.active, u.created_at, 
            w.name as preferred_worker_name,
            w2.name as preferred_weekend_worker_name
     FROM service_users u
     LEFT JOIN workers w ON w.id = u.preferred_worker_id
     LEFT JOIN workers w2 ON w2.id = u.preferred_weekend_worker_id
     ORDER BY u.created_at DESC`
  )
  .all<{ 
    id: string; 
    name: string; 
    address: string | null; 
    active: number; 
    created_at: string; 
    preferred_worker_name: string | null;
    preferred_weekend_worker_name: string | null;
  }>();

const workers = await db()
  .prepare(`SELECT id, name FROM workers WHERE active = 1 ORDER BY name ASC`)
  .all<{ id: string; name: string }>();

type ServiceUserRow = (typeof users.results)[number];
---

<AppLayout title="Usuarios | Admin">
  <div class="flex items-center justify-between border-b border-zinc-200 pb-4">
    <div>
      <div class="flex items-center gap-2">
        <a class="text-sm font-medium text-zinc-500 hover:text-zinc-800 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-400">/</span>
        <span class="text-sm font-medium text-zinc-800">Usuarios/as</span>
      </div>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-zinc-900">Gestión de Usuarios/as</h1>
    </div>
    <a class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium hover:bg-zinc-50 transition-colors shadow-sm" href="/admin">
      Volver
    </a>
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-3 items-start">
    <section class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm lg:col-span-1 sticky top-6">
      <h2 class="text-lg font-bold text-zinc-900 border-b border-zinc-100 pb-3 mb-4">Nuevo/a Usuario/a</h2>
      <form method="post" class="space-y-4">
        <label class="block">
          <span class="text-sm font-semibold text-zinc-700">Nombre completo</span>
          <input class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all" name="name" placeholder="Ej: Dolores Góngora Orive" required />
        </label>

        <label class="block">
          <span class="text-sm font-semibold text-zinc-700">Dirección (opcional)</span>
          <input class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all" name="address" placeholder="Ej: Calle Mayor 12, 3ºA" />
        </label>

        <label class="block">
          <span class="text-sm font-semibold text-zinc-700">Notas / Observaciones (opcional)</span>
          <textarea class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all" name="notes" rows="3" placeholder="Información relevante sobre el usuario..."></textarea>
        </label>

        <label class="block">
          <span class="text-sm font-semibold text-zinc-700">Trabajadora Habitual (L-V)</span>
          <select class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all" name="preferredWorker">
            <option value="">— Ninguna en específico —</option>
            {workers.results.map((w) => (
              <option value={w.id}>{w.name}</option>
            ))}
          </select>
        </label>
        
        <label class="block">
          <span class="text-sm font-semibold text-zinc-700">Trabajadora Habitual (Finde/Festivo)</span>
          <select class="mt-1.5 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all" name="preferredWeekendWorker">
            <option value="">— Ninguna en específico —</option>
            {workers.results.map((w) => (
              <option value={w.id}>{w.name}</option>
            ))}
          </select>
        </label>

        <button class="mt-2 inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 hover:bg-emerald-700 transition-colors px-4 py-2.5 text-sm font-bold text-white shadow-sm">
          Registrar usuario/a
        </button>
      </form>
    </section>

    <section class="rounded-2xl border border-zinc-200 bg-white shadow-sm lg:col-span-2 overflow-hidden">
      <div class="p-6 border-b border-zinc-100 flex items-center justify-between">
        <h2 class="text-lg font-bold text-zinc-900">Listado Activo ({users.results.length})</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[720px] text-left text-sm">
          <thead class="bg-zinc-50 text-xs uppercase text-zinc-500 border-b border-zinc-200">
            <tr>
              <th class="px-6 py-3 font-semibold">Nombre</th>
              <th class="px-6 py-3 font-semibold">Dirección</th>
              <th class="px-6 py-3 font-semibold">Trabajadora Asignada</th>
              <th class="px-6 py-3 font-semibold">Estado</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-100">
            {users.results.map((u: ServiceUserRow) => (
              <tr class="hover:bg-zinc-50/50 transition-colors">
                <td class="px-6 py-4">
                  <a class="font-bold text-emerald-600 hover:underline uppercase" href={`/admin/users/${u.id}`}>
                    {u.name}
                  </a>
                </td>
                <td class="px-6 py-4 text-zinc-600">{u.address ?? <span class="italic text-zinc-400">Sin dirección</span>}</td>
                <td class="px-6 py-4 text-zinc-600">
                  <div class="flex flex-col gap-1">
                    {u.preferred_worker_name ? (
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700" title="Laborables">
                        <span class="w-4 text-center">L-V:</span> {u.preferred_worker_name}
                      </span>
                    ) : null}
                    {u.preferred_weekend_worker_name ? (
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-orange-50 text-orange-700" title="Festivos y Fines de semana">
                        <span class="w-4 text-center">F/F:</span> {u.preferred_weekend_worker_name}
                      </span>
                    ) : null}
                    {!u.preferred_worker_name && !u.preferred_weekend_worker_name && (
                      <span class="italic text-zinc-400 text-xs">—</span>
                    )}
                  </div>
                </td>
                <td class="px-6 py-4">
                  {u.active === 1 ? (
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Activo
                    </span>
                  ) : (
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-zinc-100 text-zinc-700">
                      <span class="h-1.5 w-1.5 rounded-full bg-zinc-400"></span> Inactivo
                    </span>
                  )}
                </td>
              </tr>
            ))}

            {users.results.length === 0 && (
              <tr>
                <td colspan="3" class="px-6 py-8 text-center text-zinc-500 italic">
                  No hay usuarios/as registrados en el sistema.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</AppLayout>

