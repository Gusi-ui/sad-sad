---
import AppLayout from '../../../layouts/AppLayout.astro';
import EntitySearchList from '../../../components/EntitySearchList.astro';
import { db } from '../../../lib/db';

const users = await db()
  .prepare(
    `SELECT u.id, u.name, u.active, u.address, u.phone, u.created_at
     FROM service_users u
     ORDER BY u.name ASC`
  )
  .all<{
    id: string;
    name: string;
    active: number;
    address: string | null;
    phone: string | null;
    created_at: string;
  }>();

const items = users.results.map((u) => ({
  id: u.id,
  name: u.name,
  href: `/admin/users/${u.id}`,
  active: u.active,
  meta: u.phone || 'Sin teléfono',
  detail: u.address || 'Sin dirección'
}));
---

<AppLayout title="Usuarios | Admin">
  <div class="ui-header">
    <div>
      <div class="ui-breadcrumbs">
        <a class="hover:text-zinc-900 transition-colors" href="/admin">Panel de control</a>
        <span class="text-zinc-300">/</span>
        <span class="text-zinc-800">Usuarios/as</span>
        <span class="ui-badge bg-emerald-100 text-emerald-900">Total {users.results.length}</span>
      </div>
      <h1 class="ui-title">Usuarios/as</h1>
      <p class="ui-subtitle">La lista se muestra completa y se filtra al escribir.</p>
    </div>
    <a href="/admin/users/new" class="ui-btn ui-btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      Nuevo/a usuario/a
    </a>
  </div>

  <div class="mt-6 max-w-3xl">
    <EntitySearchList
      id="users"
      placeholder="Buscar por nombre…"
      items={items}
      emptyText="No se encontraron usuarios/as."
    />
  </div>
</AppLayout>
