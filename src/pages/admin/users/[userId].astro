---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../lib/db';
import { randomId } from '../../../lib/crypto';
import { toYmd } from '../../../lib/dates';
import { computeUserMonthBreakdown, formatHours, minutesToHours } from '../../../lib/month-hours';
import { bumpManyWorkerAssignmentsVersions } from '../../../lib/realtime';
import { sendPushToWorkerIds } from '../../../lib/push';

export const prerender = false;

const { userId } = Astro.params;
if (!userId) return Astro.redirect('/admin/users');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('_action') ?? '');
  const database = db();
  const cf = Astro.locals.cfContext;
  const queuePush = (workerIds: string[]) => {
    cf?.waitUntil(
      sendPushToWorkerIds(database, workerIds, {
        title: 'Planificación actualizada',
        body: 'Se han aplicado cambios en tu agenda. Entra para verlos.',
        url: '/w/planning'
      }) as any
    );
  };

  if (action === 'update_user') {
    const name = String(formData.get('name') ?? '').trim();
    const address = String(formData.get('address') ?? '').trim();
    const notes = String(formData.get('notes') ?? '').trim();
    const active = formData.get('active') === 'on' ? 1 : 0;
    const quotaRaw = String(formData.get('monthlyHoursQuota') ?? '').trim();
    const quotaParsed = quotaRaw === '' ? null : Number(quotaRaw);
    const quotaDb = quotaParsed === null || !Number.isFinite(quotaParsed) ? null : quotaParsed;

    if (name) {
      await database
        .prepare(
          `UPDATE service_users SET name = ?, address = ?, notes = ?, active = ?, monthly_hours_quota = ? WHERE id = ?`
        )
        .bind(name, address || null, notes || null, active, quotaDb, userId)
        .run();
    }
    return Astro.redirect(`/admin/users/${userId}`);
  }

  if (action === 'add_template') {
    const kind = String(formData.get('kind') ?? 'laborable');
    const startTime = String(formData.get('startTime') ?? '').trim();
    const endTime = String(formData.get('endTime') ?? '').trim();
    const requiredWorkerType = String(formData.get('requiredWorkerType') ?? 'laborable');
    const preferredWorkerRaw = String(formData.get('preferredWorker') ?? '').trim();
    const preferredWorkerId = preferredWorkerRaw === '' ? null : preferredWorkerRaw;

    // Manejar múltiples días seleccionados
    const selectedDays = formData.getAll('weekdays').map(d => Number(d));

    if (startTime && endTime) {
      if (selectedDays.length > 0) {
        // Crear una plantilla para cada día seleccionado
        for (const weekday of selectedDays) {
          if (Number.isFinite(weekday) && weekday >= 0 && weekday <= 6) {
            await database
              .prepare(
                `INSERT INTO service_templates (id, service_user_id, kind, weekday, start_time, end_time, required_worker_type, preferred_worker_id)
                 VALUES (?, ?, ?, ?, ?, ?, ?, ?)`
              )
              .bind(randomId(), userId, kind, weekday, startTime, endTime, requiredWorkerType, preferredWorkerId)
              .run();
          }
        }
      } else {
        // Si no se selecciona ningún día, se asume "Todos los días de ese tipo" (weekday = null)
        await database
          .prepare(
            `INSERT INTO service_templates (id, service_user_id, kind, weekday, start_time, end_time, required_worker_type, preferred_worker_id)
             VALUES (?, ?, ?, ?, ?, ?, ?, ?)`
          )
          .bind(randomId(), userId, kind, null, startTime, endTime, requiredWorkerType, preferredWorkerId)
          .run();
      }
    }

    return Astro.redirect(`/admin/users/${userId}`);
  }

  if (action === 'update_template') {
    const templateId = String(formData.get('templateId') ?? '').trim();
    const startTime = String(formData.get('startTime') ?? '').trim();
    const endTime = String(formData.get('endTime') ?? '').trim();
    const requiredWorkerType = String(formData.get('requiredWorkerType') ?? 'laborable');
    const preferredWorkerRaw = String(formData.get('preferredWorker') ?? '').trim();
    const preferredWorkerId = preferredWorkerRaw === '' ? null : preferredWorkerRaw;

    const timeOk = (value: string) => /^\d{2}:\d{2}$/.test(value);
    const allowedWorkerTypes = new Set(['laborable', 'festivo', 'ambos']);
    const safeRequiredWorkerType = allowedWorkerTypes.has(requiredWorkerType) ? requiredWorkerType : 'laborable';

    if (templateId && timeOk(startTime) && timeOk(endTime)) {
      const today = toYmd(new Date());
      const affected = await database
        .prepare(
          `SELECT DISTINCT assigned_worker_id as id
           FROM assignments
           WHERE template_id = ? AND source = 'template' AND status != 'done' AND date >= ? AND assigned_worker_id IS NOT NULL`
        )
        .bind(templateId, today)
        .all<{ id: string }>();

      await database
        .prepare(
          `UPDATE service_templates
           SET start_time = ?, end_time = ?, required_worker_type = ?, preferred_worker_id = ?
           WHERE id = ? AND service_user_id = ?`
        )
        .bind(startTime, endTime, safeRequiredWorkerType, preferredWorkerId, templateId, userId)
        .run();

      await database
        .prepare(
          `UPDATE assignments
           SET planned_start = ?, planned_end = ?
           WHERE template_id = ? AND source = 'template' AND status != 'done' AND date >= ?`
        )
        .bind(startTime, endTime, templateId, today)
        .run();

      const ids = affected.results.map((r) => r.id);
      await bumpManyWorkerAssignmentsVersions(database, ids);
      queuePush(ids);
    }

    return Astro.redirect(`/admin/users/${userId}`);
  }

  if (action === 'delete_template') {
    const templateId = String(formData.get('templateId') ?? '').trim();
    if (templateId) {
      const affected = await database
        .prepare(
          `SELECT DISTINCT assigned_worker_id as id
           FROM assignments
           WHERE template_id = ? AND status != 'done' AND assigned_worker_id IS NOT NULL`
        )
        .bind(templateId)
        .all<{ id: string }>();

      await database
        .prepare(`DELETE FROM assignments WHERE template_id = ? AND status != 'done'`)
        .bind(templateId)
        .run();
      await database
        .prepare(`DELETE FROM service_templates WHERE id = ? AND service_user_id = ?`)
        .bind(templateId, userId)
        .run();
      const leftTemplates = await database
        .prepare(`SELECT COUNT(*) AS c FROM service_templates WHERE service_user_id = ?`)
        .bind(userId)
        .first<{ c: number }>();
      if ((leftTemplates?.c ?? 0) === 0) {
        await database
          .prepare(`DELETE FROM assignments WHERE service_user_id = ? AND template_id IS NULL AND source = 'manual' AND status != 'done'`)
          .bind(userId)
          .run();
      }
      const ids = affected.results.map((r) => r.id);
      await bumpManyWorkerAssignmentsVersions(database, ids);
      queuePush(ids);
    }
    return Astro.redirect(`/admin/users/${userId}`);
  }

  if (action === 'clean_orphan_assignments') {
    const affected = await database
      .prepare(
        `SELECT DISTINCT assigned_worker_id as id
         FROM assignments
         WHERE service_user_id = ? AND template_id IS NULL AND source = 'manual' AND status != 'done' AND assigned_worker_id IS NOT NULL`
      )
      .bind(userId)
      .all<{ id: string }>();

    await database
      .prepare(`DELETE FROM assignments WHERE service_user_id = ? AND template_id IS NULL AND source = 'manual' AND status != 'done'`)
      .bind(userId)
      .run();
    const ids = affected.results.map((r) => r.id);
    await bumpManyWorkerAssignmentsVersions(database, ids);
    queuePush(ids);
    return Astro.redirect(`/admin/users/${userId}`);
  }

  if (action === 'sync_user_schedule') {
    const affected = await database
      .prepare(
        `SELECT DISTINCT assigned_worker_id as id
         FROM assignments
         WHERE service_user_id = ? AND source = 'template' AND status != 'done' AND assigned_worker_id IS NOT NULL`
      )
      .bind(userId)
      .all<{ id: string }>();

    await database
      .prepare(`DELETE FROM assignments WHERE service_user_id = ? AND source = 'template' AND status != 'done'`)
      .bind(userId)
      .run();
    const templatesForUser = await database
      .prepare(`SELECT id, kind, weekday, start_time, end_time FROM service_templates WHERE service_user_id = ?`)
      .bind(userId)
      .all<{ id: string; kind: 'laborable' | 'festivo'; weekday: number | null; start_time: string; end_time: string }>();
    const currentYear = new Date().getUTCFullYear();
    const monthStart = new Date(Date.UTC(currentYear, 0, 1));
    const monthEnd = new Date(Date.UTC(currentYear, 11, 31));
    const startYmd = toYmd(monthStart);
    const endYmd = toYmd(monthEnd);
    const holidayRows = await database
      .prepare(`SELECT date FROM holidays WHERE date >= ? AND date <= ? AND scope IN ('national','catalonia','mataro')`)
      .bind(startYmd, endYmd)
      .all<{ date: string }>();
    const holidaySet = new Set(holidayRows.results.map((r) => r.date));
    for (let d = new Date(monthStart); d <= monthEnd; d.setUTCDate(d.getUTCDate() + 1)) {
      const ymd = toYmd(new Date(d));
      const weekday = d.getUTCDay();
      const isWeekend = weekday === 0 || weekday === 6;
      const dayKind = holidaySet.has(ymd) ? 'festivo' : isWeekend ? 'fin_semana' : 'laborable';
      const applicable = templatesForUser.results.filter((t) => {
        if (dayKind === 'laborable') {
          if (t.kind !== 'laborable') return false;
          if (t.weekday === null) return true;
          return t.weekday === weekday;
        }
        if (t.kind !== 'festivo') return false;
        if (t.weekday === null) return true;
        return t.weekday === weekday;
      });
      for (const t of applicable) {
        await database
          .prepare(
            `INSERT INTO assignments
              (id, date, service_user_id, template_id, kind, planned_start, planned_end, source)
             VALUES (?, ?, ?, ?, ?, ?, ?, 'template')
             ON CONFLICT(service_user_id, date, template_id) DO UPDATE SET
               kind = excluded.kind,
               planned_start = excluded.planned_start,
               planned_end = excluded.planned_end,
               status = 'planned',
               source = 'template'`
          )
          .bind(randomId(), ymd, userId, t.id, dayKind === 'fin_semana' ? 'fin_semana' : t.kind, t.start_time, t.end_time)
          .run();
      }
    }
    const ids = affected.results.map((r) => r.id);
    await bumpManyWorkerAssignmentsVersions(database, ids);
    queuePush(ids);
    return Astro.redirect(`/admin/users/${userId}`);
  }

  if (action === 'normalize_festive_template_requirements') {
    await database
      .prepare(`UPDATE service_templates SET required_worker_type = 'festivo' WHERE service_user_id = ? AND kind = 'festivo' AND required_worker_type = 'laborable'`)
      .bind(userId)
      .run();
    return Astro.redirect(`/admin/users/${userId}`);
  }

  if (action === 'delete_user') {
    const affected = await database
      .prepare(
        `SELECT DISTINCT assigned_worker_id as id
         FROM assignments
         WHERE service_user_id = ? AND assigned_worker_id IS NOT NULL`
      )
      .bind(userId)
      .all<{ id: string }>();

    await database.prepare(`DELETE FROM assignments WHERE service_user_id = ?`).bind(userId).run();
    await database.prepare(`DELETE FROM service_templates WHERE service_user_id = ?`).bind(userId).run();
    await database.prepare(`DELETE FROM service_users WHERE id = ?`).bind(userId).run();
    const ids = affected.results.map((r) => r.id);
    await bumpManyWorkerAssignmentsVersions(database, ids);
    queuePush(ids);
    return Astro.redirect('/admin/users');
  }
}

const user = await db()
  .prepare(`SELECT id, name, address, phone, notes, active, monthly_hours_quota FROM service_users WHERE id = ? LIMIT 1`)
  .bind(userId)
  .first<{
    id: string;
    name: string;
    address: string | null;
    phone: string | null;
    notes: string | null;
    active: number;
    monthly_hours_quota: number | null;
  }>();

if (!user) return Astro.redirect('/admin/users');

const workers = await db()
  .prepare(`SELECT id, name FROM workers WHERE active = 1 ORDER BY name ASC`)
  .all<{ id: string; name: string }>();

const templates = await db()
  .prepare(
    `SELECT id, kind, weekday, start_time, end_time, required_worker_type, preferred_worker_id
     FROM service_templates
     WHERE service_user_id = ?
     ORDER BY kind ASC, weekday ASC, start_time ASC`
  )
  .bind(userId)
  .all<{ id: string; kind: string; weekday: number | null; start_time: string; end_time: string; required_worker_type: string; preferred_worker_id: string | null }>();

const orphanAssignments = await db()
  .prepare(`SELECT COUNT(*) AS c FROM assignments WHERE service_user_id = ? AND template_id IS NULL AND source = 'manual' AND status != 'done'`)
  .bind(userId)
  .first<{ c: number }>();

const wrongFestiveRequirement = await db()
  .prepare(`SELECT COUNT(*) AS c FROM service_templates WHERE service_user_id = ? AND kind = 'festivo' AND required_worker_type = 'laborable'`)
  .bind(userId)
  .first<{ c: number }>();

type TemplateRow = (typeof templates.results)[number];

const weekdayLabel = (weekday: number | null) => {
  if (weekday === null) return '—';
  const labels = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];
  return labels[weekday] ?? String(weekday);
};

const now = new Date();
const reportYear = Number(Astro.url.searchParams.get('year') ?? now.getFullYear());
const reportMonth = Number(Astro.url.searchParams.get('month') ?? now.getMonth() + 1);
const safeYear = Number.isFinite(reportYear) ? reportYear : now.getFullYear();
const safeMonth =
  Number.isFinite(reportMonth) && reportMonth >= 1 && reportMonth <= 12 ? reportMonth : now.getMonth() + 1;

const monthBreakdown = await computeUserMonthBreakdown(db(), userId, safeYear, safeMonth);
const hoursFromTemplates = minutesToHours(monthBreakdown.plannedMinutesFromTemplates);
const hoursFromAssignments = minutesToHours(monthBreakdown.plannedMinutesFromAssignments);
const quota = user.monthly_hours_quota;
const deltaTemplates = quota !== null && quota !== undefined ? hoursFromTemplates - quota : null;
const deltaAssignments = quota !== null && quota !== undefined ? hoursFromAssignments - quota : null;
---

<AppLayout title={`${user.name} | Admin`}>
  <div>
    <div class="ui-breadcrumbs">
      <a class="hover:text-zinc-900 transition-colors" href="/admin/users">Usuarios/as</a>
      <span class="text-zinc-300">/</span>
      <span class="text-zinc-800 truncate">{user.name}</span>
      <a class="ui-pill ml-2 no-underline hover:bg-zinc-50" href="/admin/users">Volver</a>
    </div>
    <h1 class="ui-title mt-2 text-3xl">{user.name}</h1>
    <p class="ui-subtitle">ID: {user.id}</p>
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-2">
    <section class="ui-card-solid ui-card-body-sm lg:col-span-2">
      <h2 class="text-sm font-semibold">Datos</h2>
      <form method="post" class="mt-4 grid gap-4 sm:grid-cols-2">
        <input type="hidden" name="_action" value="update_user" />
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Nombre</span>
          <input class="ui-input mt-1" name="name" value={user.name} required />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Teléfono</span>
          <input class="ui-input mt-1" name="phone" value={user.phone ?? ''} type="tel" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Dirección</span>
          <input class="ui-input mt-1" name="address" value={user.address ?? ''} />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Horas mensuales aprobadas (ayuntamiento)</span>
          <input
            class="ui-input mt-1"
            name="monthlyHoursQuota"
            inputmode="decimal"
            placeholder="Ej. 86"
            value={user.monthly_hours_quota ?? ''}
          />
        </label>
        
        <label class="block sm:col-span-2">
          <span class="text-sm font-medium text-zinc-700">Notas</span>
          <textarea class="ui-textarea mt-1" name="notes" rows="2">{user.notes ?? ''}</textarea>
        </label>

        <div class="sm:col-span-2 flex items-center justify-between mt-2 border-t border-zinc-100 pt-4">
          <label class="flex items-center gap-2">
            <input class="h-4 w-4" type="checkbox" name="active" checked={user.active === 1} />
            <span class="text-sm font-medium text-zinc-700">Usuario/a activo</span>
          </label>
          <button class="ui-btn ui-btn-primary px-6 py-2">Guardar cambios</button>
        </div>
      </form>
    </section>

    <section class="ui-card-solid ui-card-body-sm order-3 lg:col-span-2">
      <h2 class="text-sm font-semibold">Plantillas de servicio</h2>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <form method="post">
          <input type="hidden" name="_action" value="sync_user_schedule" />
          <button class="ui-btn ui-btn-secondary px-3 py-1.5 text-xs">
            Regenerar agenda anual de este usuario
          </button>
        </form>
        {((orphanAssignments?.c ?? 0) > 0) && (
          <form method="post" onsubmit="return window.confirm('Se limpiarán servicios antiguos sin plantilla de este usuario. ¿Continuar?')">
            <input type="hidden" name="_action" value="clean_orphan_assignments" />
            <button class="ui-btn rounded-xl border border-amber-300 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-900 hover:bg-amber-100">
              Limpiar {orphanAssignments?.c ?? 0} servicios huérfanos
            </button>
          </form>
        )}
        {((wrongFestiveRequirement?.c ?? 0) > 0) && (
          <form method="post">
            <input type="hidden" name="_action" value="normalize_festive_template_requirements" />
            <button class="ui-btn rounded-xl border border-orange-300 bg-orange-50 px-3 py-1.5 text-xs font-semibold text-orange-900 hover:bg-orange-100">
              Corregir {wrongFestiveRequirement?.c ?? 0} plantillas festivas
            </button>
          </form>
        )}
      </div>

      <form method="post" class="mt-4 grid gap-4 sm:grid-cols-2">
        <input type="hidden" name="_action" value="add_template" />
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Tipo de día</span>
          <select class="ui-select mt-1" name="kind">
            <option value="laborable">Laborable (Lunes a Viernes)</option>
            <option value="festivo">Festivo / Fin de semana</option>
          </select>
        </label>

        <div class="block sm:col-span-2">
          <span class="text-sm font-medium text-zinc-700 block mb-2">Días de la semana (opcional)</span>
          <div class="flex flex-wrap gap-2">
            <label class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50 cursor-pointer">
              <input type="checkbox" name="weekdays" value="1" class="h-4 w-4 rounded border-zinc-300 text-emerald-600 focus:ring-emerald-600" />
              Lunes
            </label>
            <label class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50 cursor-pointer">
              <input type="checkbox" name="weekdays" value="2" class="h-4 w-4 rounded border-zinc-300 text-emerald-600 focus:ring-emerald-600" />
              Martes
            </label>
            <label class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50 cursor-pointer">
              <input type="checkbox" name="weekdays" value="3" class="h-4 w-4 rounded border-zinc-300 text-emerald-600 focus:ring-emerald-600" />
              Miércoles
            </label>
            <label class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50 cursor-pointer">
              <input type="checkbox" name="weekdays" value="4" class="h-4 w-4 rounded border-zinc-300 text-emerald-600 focus:ring-emerald-600" />
              Jueves
            </label>
            <label class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50 cursor-pointer">
              <input type="checkbox" name="weekdays" value="5" class="h-4 w-4 rounded border-zinc-300 text-emerald-600 focus:ring-emerald-600" />
              Viernes
            </label>
            <label class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50 cursor-pointer">
              <input type="checkbox" name="weekdays" value="6" class="h-4 w-4 rounded border-zinc-300 text-emerald-600 focus:ring-emerald-600" />
              Sábado
            </label>
            <label class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50 cursor-pointer">
              <input type="checkbox" name="weekdays" value="0" class="h-4 w-4 rounded border-zinc-300 text-emerald-600 focus:ring-emerald-600" />
              Domingo
            </label>
          </div>
          <p class="text-xs text-zinc-500 mt-1.5 italic">Si no seleccionas ningún día, se aplicará a <b>todos los días</b> del tipo elegido.</p>
        </div>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Inicio</span>
          <input class="ui-input mt-1" name="startTime" placeholder="08:00" required />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Fin</span>
          <input class="ui-input mt-1" name="endTime" placeholder="09:30" required />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Requiere trabajadora</span>
          <select class="ui-select mt-1" name="requiredWorkerType">
            <option value="laborable">Laborable</option>
            <option value="festivo">Festivo/Finde</option>
            <option value="ambos">Ambos</option>
          </select>
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Trabajadora preferida (opcional)</span>
          <select class="ui-select mt-1" name="preferredWorker">
            <option value="">— Ninguna en específico —</option>
            {workers.results.map((w) => (
              <option value={w.id}>{w.name}</option>
            ))}
          </select>
        </label>

        <button class="ui-btn ui-btn-primary sm:col-span-2">Añadir plantilla</button>
      </form>

      <div class="mt-6 overflow-x-auto">
        <table class="w-full min-w-[640px] text-left text-sm">
          <thead class="text-xs uppercase text-zinc-500">
            <tr>
              <th class="px-3 py-2">Tipo</th>
              <th class="px-3 py-2">Semana</th>
              <th class="px-3 py-2">Inicio</th>
              <th class="px-3 py-2">Fin</th>
              <th class="px-3 py-2">Requiere</th>
              <th class="px-3 py-2">Trabajadora Preferida</th>
              <th class="px-3 py-2 w-10"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-100">
            {templates.results.map((t: TemplateRow) => {
              const formId = `update-template-${t.id}`;
              return (
                <tr class="hover:bg-zinc-50 transition-colors">
                  <td class="px-3 py-3">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${t.kind === 'laborable' ? 'bg-blue-50 text-blue-700' : 'bg-orange-50 text-orange-700'}`}>
                      {t.kind === 'laborable' ? 'L-V' : 'Festivo'}
                    </span>
                  </td>
                  <td class="px-3 py-3 font-medium text-zinc-700">{weekdayLabel(t.weekday)}</td>
                  <td class="px-3 py-3">
                    <input class="ui-input h-9 w-24 px-2.5 py-1.5 text-xs" name="startTime" value={t.start_time} required form={formId} />
                  </td>
                  <td class="px-3 py-3">
                    <input class="ui-input h-9 w-24 px-2.5 py-1.5 text-xs" name="endTime" value={t.end_time} required form={formId} />
                  </td>
                  <td class="px-3 py-3">
                    <select class="ui-select h-9 py-1.5 text-xs capitalize" name="requiredWorkerType" form={formId}>
                      <option value="laborable" selected={t.required_worker_type === 'laborable'}>Laborable</option>
                      <option value="festivo" selected={t.required_worker_type === 'festivo'}>Festivo/Finde</option>
                      <option value="ambos" selected={t.required_worker_type === 'ambos'}>Ambos</option>
                    </select>
                  </td>
                  <td class="px-3 py-3">
                    <select class="ui-select h-9 py-1.5 text-xs" name="preferredWorker" form={formId}>
                      <option value="" selected={!t.preferred_worker_id}>— Ninguna —</option>
                      {workers.results.map((w) => (
                        <option value={w.id} selected={t.preferred_worker_id === w.id}>{w.name}</option>
                      ))}
                    </select>
                  </td>
                  <td class="px-3 py-3 text-right">
                    <div class="inline-flex items-center gap-2">
                      <form method="post" id={formId} class="inline">
                        <input type="hidden" name="_action" value="update_template" />
                        <input type="hidden" name="templateId" value={t.id} />
                        <button class="ui-btn ui-btn-secondary px-2 py-1 text-xs">Guardar</button>
                      </form>
                      <form method="post" class="inline">
                        <input type="hidden" name="_action" value="delete_template" />
                        <input type="hidden" name="templateId" value={t.id} />
                        <button type="submit" class="text-zinc-400 hover:text-red-600 transition-colors p-1" title="Eliminar plantilla">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              );
            })}
            
            {templates.results.length === 0 && (
              <tr>
                <td colspan="7" class="px-3 py-6 text-center text-sm text-zinc-500 italic">
                  Este usuario no tiene plantillas configuradas.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </section>

    <section class="ui-card-solid ui-card-body-sm order-2 lg:col-span-2">
      <h2 class="text-sm font-semibold">Cuadre de horas (mes natural)</h2>
      <p class="mt-1 text-xs text-zinc-600">
        Para el <strong>ayuntamiento</strong> la referencia oficial son las horas en{' '}
        <code class="rounded bg-zinc-100 px-1">assignments</code> del mes (lo que se planifica y se puede exportar como listado de asignaciones). Las plantillas sirven para generar la agenda y como referencia de planificación.
      </p>
      <p class="mt-2 text-xs text-zinc-600">
        Un día <strong>laborable</strong> que sea festivo oficial no cuenta servicio de plantilla laborable: ese día se trata como festivo (plantillas tipo festivo si las hay).
      </p>

      <form method="get" class="mt-4 flex flex-wrap items-end gap-3">
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Año</span>
          <input class="ui-input mt-1 w-28" name="year" type="number" value={safeYear} />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Mes</span>
          <input class="ui-input mt-1 w-24" name="month" type="number" min="1" max="12" value={safeMonth} />
        </label>
        <button class="ui-btn ui-btn-primary px-4 py-2">Calcular</button>
      </form>

      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-zinc-100 bg-zinc-50 p-3">
          <div class="text-xs text-zinc-500">Días laborables</div>
          <div class="text-lg font-semibold">{monthBreakdown.daysLaborable}</div>
        </div>
        <div class="rounded-xl border border-zinc-100 bg-zinc-50 p-3">
          <div class="text-xs text-zinc-500">Días festivo (calendario)</div>
          <div class="text-lg font-semibold">{monthBreakdown.daysFestivo}</div>
        </div>
        <div class="rounded-xl border border-zinc-100 bg-zinc-50 p-3">
          <div class="text-xs text-zinc-500">Días fin de semana</div>
          <div class="text-lg font-semibold">{monthBreakdown.daysFinSemana}</div>
        </div>
        <div class="rounded-xl border border-zinc-100 bg-zinc-50 p-3">
          <div class="text-xs text-zinc-500">Cuota aprobada</div>
          <div class="text-lg font-semibold">{quota !== null && quota !== undefined ? formatHours(quota) : '—'}</div>
        </div>
      </div>

      <div class="mt-4 grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border-2 border-zinc-800 bg-zinc-50 p-4">
          <div class="text-sm font-semibold">Assignments del mes (oficial ayuntamiento)</div>
          <div class="mt-2 text-2xl font-semibold">{formatHours(hoursFromAssignments)}</div>
          {deltaAssignments !== null ? (
            <div class={`mt-2 text-sm font-medium ${deltaAssignments > 0.02 ? 'text-amber-700' : deltaAssignments < -0.02 ? 'text-blue-700' : 'text-emerald-700'}`}>
              {deltaAssignments > 0.02
                ? `Sobran ~${formatHours(Math.abs(deltaAssignments))} respecto a la cuota`
                : deltaAssignments < -0.02
                  ? `Faltan ~${formatHours(Math.abs(deltaAssignments))} respecto a la cuota`
                  : 'Cuadra con la cuota (aprox.)'}
            </div>
          ) : (
            <div class="mt-2 text-xs text-zinc-500">Indica cuota para comparar.</div>
          )}
        </div>
        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="text-sm font-semibold">Según plantillas (planificación / agenda)</div>
          <div class="mt-2 text-2xl font-semibold">{formatHours(hoursFromTemplates)}</div>
          {deltaTemplates !== null ? (
            <div class={`mt-2 text-sm font-medium ${deltaTemplates > 0.02 ? 'text-amber-700' : deltaTemplates < -0.02 ? 'text-blue-700' : 'text-emerald-700'}`}>
              {deltaTemplates > 0.02
                ? `Sobran ~${formatHours(Math.abs(deltaTemplates))} respecto a la cuota`
                : deltaTemplates < -0.02
                  ? `Faltan ~${formatHours(Math.abs(deltaTemplates))} respecto a la cuota`
                  : 'Cuadra con la cuota (aprox.)'}
            </div>
          ) : (
            <div class="mt-2 text-xs text-zinc-500">Indica cuota en “Horas mensuales aprobadas” para ver diferencia.</div>
          )}
        </div>
      </div>

      <p class="mt-4 text-xs text-zinc-500">
        <strong>Ej. usuario “todos los días”:</strong> plantillas <code class="rounded bg-zinc-100 px-1">laborable</code> sin día (o L–V
        repetido) para mañana y tarde; plantillas <code class="rounded bg-zinc-100 px-1">festivo</code> sin día para mañana en festivo/finde.
        <strong>Ej. L–M–X:</strong> tres plantillas <code class="rounded bg-zinc-100 px-1">laborable</code> con weekday 1, 3 y 5.
      </p>
    </section>

    <section class="rounded-2xl border border-rose-200 bg-rose-50 p-5 shadow-sm order-4 lg:col-span-2">
      <h2 class="text-sm font-semibold text-red-800">Zona de peligro</h2>
      <p class="mt-1 text-xs text-red-700">
        Si eliminas este usuario se borrarán también sus plantillas y todos sus servicios en agenda para liberar carga de las trabajadoras.
      </p>
      <form method="post" class="mt-4">
        <input type="hidden" name="_action" value="delete_user" />
        <button class="ui-btn ui-btn-danger px-4 py-2">
          Eliminar usuario/a
        </button>
      </form>
    </section>
  </div>
</AppLayout>
