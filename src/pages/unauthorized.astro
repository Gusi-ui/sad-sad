---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Acceso no autorizado">
  <div class="mx-auto max-w-xl rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
    <h1 class="text-xl font-semibold">Acceso no autorizado</h1>
    <p class="mt-2 text-sm text-zinc-600">
      No tienes permisos para acceder a esta sección.
    </p>
    <a class="mt-4 inline-flex rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white" href="/login">
      Ir al login
    </a>
  </div>
</AppLayout>

