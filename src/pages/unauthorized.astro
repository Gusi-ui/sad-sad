---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Acceso no autorizado">
  <div class="mx-auto max-w-xl ui-card-solid ui-card-body">
    <h1 class="ui-title text-2xl">Acceso no autorizado</h1>
    <p class="ui-subtitle">
      No tienes permisos para acceder a esta sección.
    </p>
    <a class="ui-btn ui-btn-primary mt-4" href="/login">
      Ir al login
    </a>
  </div>
</AppLayout>
