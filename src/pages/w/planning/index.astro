---
import WorkerLayout from '../../../layouts/WorkerLayout.astro';

export const prerender = false;
---

<WorkerLayout title="Planificación | SAD">
  <header class="flex items-center gap-3 bg-white px-4 py-3 shadow-sm relative z-10">
    <a class="text-zinc-800 p-1 -ml-1" href="/w">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
    </a>
    <h1 class="text-xl font-bold text-zinc-800">Planificación</h1>
  </header>

  <div class="mt-4 px-4 space-y-4">
    <a class="flex items-center justify-between p-6 bg-white border border-zinc-200 rounded-2xl shadow-sm hover:border-[#0284C7] transition-colors" href="/w/today">
      <div class="flex items-center gap-4">
        <div class="rounded-full bg-blue-50 p-3 text-[#0284C7]">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line><rect x="8" y="14" width="8" height="4" rx="1"></rect></svg>
        </div>
        <div>
          <div class="text-lg font-semibold text-zinc-800">Diaria</div>
          <div class="text-sm text-zinc-500">Servicios del día actual</div>
        </div>
      </div>
      <svg class="text-zinc-400" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </a>

    <a class="flex items-center justify-between p-6 bg-white border border-zinc-200 rounded-2xl shadow-sm hover:border-[#0284C7] transition-colors" href="/w/week">
      <div class="flex items-center gap-4">
        <div class="rounded-full bg-blue-50 p-3 text-[#0284C7]">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line><path d="M8 14h8"></path><path d="M8 18h4"></path></svg>
        </div>
        <div>
          <div class="text-lg font-semibold text-zinc-800">Semanal</div>
          <div class="text-sm text-zinc-500">Vista de toda la semana</div>
        </div>
      </div>
      <svg class="text-zinc-400" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </a>

    <a class="flex items-center justify-between p-6 bg-white border border-zinc-200 rounded-2xl shadow-sm hover:border-[#0284C7] transition-colors" href="/w/month">
      <div class="flex items-center gap-4">
        <div class="rounded-full bg-blue-50 p-3 text-[#0284C7]">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line><rect x="7" y="14" width="2" height="2"></rect><rect x="11" y="14" width="2" height="2"></rect><rect x="15" y="14" width="2" height="2"></rect></svg>
        </div>
        <div>
          <div class="text-lg font-semibold text-zinc-800">Mensual</div>
          <div class="text-sm text-zinc-500">Calendario del mes completo</div>
        </div>
      </div>
      <svg class="text-zinc-400" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </a>
  </div>
</WorkerLayout>

