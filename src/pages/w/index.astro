---
import WorkerLayout from '../../layouts/WorkerLayout.astro';

export const prerender = false;
---

<WorkerLayout title="Inicio | SAD">
  <header class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Inicio</h1>
      <p class="mt-1 text-sm text-zinc-600">Selecciona una opción</p>
    </div>
    <form method="post" action="/api/auth/logout">
      <button class="rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm font-medium text-zinc-900">
        Salir
      </button>
    </form>
  </header>

  <nav class="mt-6 space-y-4">
    <a
      class="block rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm hover:border-zinc-300"
      href="/w/planning"
    >
      <div class="text-base font-semibold">Planificación</div>
      <div class="mt-1 text-sm text-zinc-600">Diaria · Semanal · Mensual</div>
    </a>

    <div class="block rounded-2xl border border-dashed border-zinc-300 bg-white p-5 text-sm text-zinc-600">
      Próximamente: fichajes, desplazamientos, incidencias, resumen contrato.
    </div>
  </nav>
</WorkerLayout>

