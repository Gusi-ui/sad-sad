---
import WorkerLayout from '../../../layouts/WorkerLayout.astro';
import { db } from '../../../lib/db';
import { toYmd } from '../../../lib/dates';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');

const { userId } = Astro.params;
if (!userId) return Astro.redirect('/w/users');

const database = db();
const todayYmd = toYmd(new Date());

const allowed = await database
  .prepare(
    `SELECT 1 as ok
     FROM service_users u
     WHERE u.id = ?
       AND u.active = 1
       AND (
         EXISTS (
           SELECT 1 FROM service_templates t
           WHERE t.service_user_id = u.id AND t.preferred_worker_id = ?
         ) OR EXISTS (
           SELECT 1 FROM assignments a
           WHERE a.service_user_id = u.id
             AND a.assigned_worker_id = ?
             AND a.status != 'done'
             AND a.date >= ?
         )
       )
     LIMIT 1`
  )
  .bind(userId, workerId, workerId, todayYmd)
  .first<{ ok: number }>();

if (!allowed?.ok) return Astro.redirect('/w/users');

const user = await database
  .prepare(`SELECT id, name, address, phone, notes FROM service_users WHERE id = ?`)
  .bind(userId)
  .first<{ id: string; name: string; address: string | null; phone: string | null; notes: string | null }>();

if (!user) return Astro.redirect('/w/users');

const trim = (v: string | null) => (v ?? '').trim();
const phone = trim(user.phone);
const address = trim(user.address);
const notes = trim(user.notes);
const phoneHref = phone ? `tel:${phone.replace(/[^\d+]/g, '')}` : null;
const mapsHref = address ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}` : null;
---

<WorkerLayout title={user.name}>
  <main class="mx-auto max-w-[680px] px-4 pb-28 pt-6">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <a class="text-sm font-medium text-zinc-700 underline decoration-zinc-300" href="/w/users">← Mis usuarios/as</a>
        <h1 class="mt-2 text-2xl font-bold text-[#1E3A8A] uppercase truncate">{user.name}</h1>
        <p class="mt-1 text-sm text-zinc-600">Información ampliada del usuario/a.</p>
      </div>
    </div>

    <section class="mt-5 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
      <div class="text-xs uppercase tracking-wider text-zinc-500">Contacto</div>
      <div class="mt-3 grid gap-3">
        <div class="rounded-xl border border-zinc-200 bg-zinc-50 px-3 py-2">
          <div class="text-[11px] font-semibold uppercase tracking-wider text-zinc-500">Dirección</div>
          <div class="mt-1 text-sm font-semibold text-zinc-800">{address || '—'}</div>
          <div class="mt-2 flex flex-wrap gap-2">
            {mapsHref ? (
              <a class="inline-flex items-center gap-2 rounded-full border border-[#0284C7]/30 bg-white px-3 py-1 text-xs font-semibold text-[#0284C7]" href={mapsHref} target="_blank" rel="noreferrer">
                Abrir en mapas
              </a>
            ) : (
              <span class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs font-semibold text-zinc-500">
                Abrir en mapas
              </span>
            )}
          </div>
        </div>

        <div class="rounded-xl border border-zinc-200 bg-zinc-50 px-3 py-2">
          <div class="text-[11px] font-semibold uppercase tracking-wider text-zinc-500">Teléfono</div>
          <div class="mt-1 text-sm font-semibold text-zinc-800">{phone || '—'}</div>
          <div class="mt-2 flex flex-wrap gap-2">
            {phoneHref ? (
              <a class="inline-flex items-center gap-2 rounded-full border border-emerald-300 bg-white px-3 py-1 text-xs font-semibold text-emerald-700" href={phoneHref}>
                Llamar
              </a>
            ) : (
              <span class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs font-semibold text-zinc-500">
                Llamar
              </span>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="mt-4 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
      <div class="text-xs uppercase tracking-wider text-zinc-500">Notas / Indicaciones</div>
      <div class="mt-2 rounded-xl border border-zinc-200 bg-zinc-50 px-3 py-3 text-sm font-medium text-zinc-800 whitespace-pre-line">
        {notes || '—'}
      </div>
      <p class="mt-2 text-xs text-zinc-500">
        Estas notas las actualiza coordinación en el panel de control (tareas, indicaciones y cualquier información relevante).
      </p>
    </section>
  </main>
</WorkerLayout>

