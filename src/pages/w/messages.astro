---
import WorkerLayout from '../../layouts/WorkerLayout.astro';
import { db } from '../../lib/db';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');

const database = db();
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('_action') ?? '').trim();
  if (action === 'mark_one_read') {
    const notificationId = String(formData.get('notificationId') ?? '').trim();
    if (notificationId) {
      await database
        .prepare(
          `UPDATE worker_notifications
           SET read_at = COALESCE(read_at, datetime('now'))
           WHERE id = ? AND worker_id = ?`
        )
        .bind(notificationId, workerId)
        .run();
    }
  }
  if (action === 'mark_all_read') {
    await database
      .prepare(
        `UPDATE worker_notifications
         SET read_at = datetime('now')
         WHERE worker_id = ? AND read_at IS NULL`
      )
      .bind(workerId)
      .run();
  }
  return Astro.redirect('/w/messages');
}

const notifications = await database
  .prepare(
    `SELECT id, category, title, body, url, created_at, read_at
     FROM worker_notifications
     WHERE worker_id = ?
     ORDER BY datetime(created_at) DESC
     LIMIT 100`
  )
  .bind(workerId)
  .all<{
    id: string;
    category: string;
    title: string;
    body: string;
    url: string | null;
    created_at: string;
    read_at: string | null;
  }>();

const unreadCount = notifications.results.filter((n) => !n.read_at).length;
---

<WorkerLayout title="Mensajería">
  <main class="mx-auto max-w-[680px] px-4 pb-28 pt-6">
    <a class="text-sm font-medium text-zinc-700 underline decoration-zinc-300" href="/w">← Inicio</a>
    <div class="mt-2 flex items-center justify-between gap-3">
      <h1 class="text-2xl font-bold text-[#1E3A8A]">Mensajería</h1>
      {unreadCount > 0 && (
        <span class="inline-flex items-center rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-700">
          {unreadCount} sin leer
        </span>
      )}
    </div>

    <div class="mt-4 flex items-center justify-end">
      <form method="post">
        <input type="hidden" name="_action" value="mark_all_read" />
        <button class="ui-btn ui-btn-secondary rounded-xl px-3 py-2 text-xs font-semibold" type="submit" disabled={unreadCount === 0}>
          Marcar todo como leído
        </button>
      </form>
    </div>

    <div class="mt-3 space-y-3">
      {notifications.results.map((message) => (
        <article class:list={['rounded-2xl border bg-white p-4 shadow-sm', message.read_at ? 'border-zinc-200' : 'border-sky-200']}>
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <h2 class="text-sm font-semibold text-zinc-900">{message.title}</h2>
              <p class="mt-1 text-sm text-zinc-700">{message.body}</p>
            </div>
            {!message.read_at && <span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-sky-500" title="Sin leer"></span>}
          </div>
          <div class="mt-3 flex items-center justify-between gap-3">
            <div class="text-xs text-zinc-500">
              {new Date(message.created_at).toLocaleString('es-ES')}
            </div>
            <div class="flex items-center gap-2">
              {message.url && (
                <a class="ui-btn ui-btn-secondary rounded-xl px-3 py-1.5 text-xs font-semibold" href={message.url}>
                  Abrir
                </a>
              )}
              {!message.read_at && (
                <form method="post">
                  <input type="hidden" name="_action" value="mark_one_read" />
                  <input type="hidden" name="notificationId" value={message.id} />
                  <button class="ui-btn ui-btn-primary rounded-xl px-3 py-1.5 text-xs font-semibold" type="submit">
                    Marcar leído
                  </button>
                </form>
              )}
            </div>
          </div>
        </article>
      ))}

      {notifications.results.length === 0 && (
        <div class="rounded-2xl border border-zinc-200 bg-white p-5 text-sm text-zinc-600">
          Aún no tienes mensajes.
        </div>
      )}
    </div>
  </main>
</WorkerLayout>
