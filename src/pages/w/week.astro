---
import WorkerLayout from '../../layouts/WorkerLayout.astro';
import { db } from '../../lib/db';
import { datesOfIsoWeek, getIsoWeekKey, toYmd } from '../../lib/dates';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');

const currentWeek = getIsoWeekKey(new globalThis.Date());
const weekKey = String(Astro.url.searchParams.get('week') ?? currentWeek);
const weekDates = datesOfIsoWeek(weekKey);
if (!weekDates) return Astro.redirect(`/w/week?week=${currentWeek}`);

const startYmd = toYmd(new globalThis.Date(weekDates[0]));
const endYmd = toYmd(new globalThis.Date(weekDates[6]));

const assignments = await db()
  .prepare(
    `SELECT a.id, a.date, a.kind, a.planned_start, a.planned_end,
            su.name as user_name
     FROM assignments a
     JOIN service_users su ON su.id = a.service_user_id
     WHERE a.assigned_worker_id = ? AND a.date >= ? AND a.date <= ? AND a.status = 'planned'
     ORDER BY a.date ASC, a.planned_start ASC, su.name ASC`
  )
  .bind(workerId, startYmd, endYmd)
  .all<{ id: string; date: string; kind: string; planned_start: string; planned_end: string; user_name: string }>();

type AssignmentRow = (typeof assignments.results)[number];

const timeToMinutes = (hhmm: string) => {
  const [hRaw, mRaw] = hhmm.split(':');
  const h = Number(hRaw);
  const m = Number(mRaw);
  if (!Number.isFinite(h) || !Number.isFinite(m)) return null;
  if (h < 0 || h > 23 || m < 0 || m > 59) return null;
  return h * 60 + m;
};

const formatDuration = (minutes: number) => {
  const total = Math.max(0, Math.floor(minutes));
  const h = Math.floor(total / 60);
  const m = total % 60;
  return `${h} h ${String(m).padStart(2, '0')} min`;
};

const assignmentsByDate = new Map<string, Array<AssignmentRow>>();
let totalMinutes = 0;

for (const a of assignments.results) {
  const list = assignmentsByDate.get(a.date) ?? [];
  list.push(a);
  assignmentsByDate.set(a.date, list);

  const start = timeToMinutes(a.planned_start);
  const end = timeToMinutes(a.planned_end);
  if (start !== null && end !== null) {
    totalMinutes += Math.max(0, end - start);
  }
}

const days = weekDates.map((d) => {
  const ymd = toYmd(new globalThis.Date(d));
  const label = new globalThis.Date(d).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
  return { ymd, label, assignments: assignmentsByDate.get(ymd) ?? [] };
});

const totalServiciosStr = formatDuration(totalMinutes);
const totalActividadesStr = formatDuration(Math.floor(totalMinutes * 0.05));
const totalDesplazamientoStr = formatDuration(Math.floor(totalMinutes * 0.1));

// Navigation logic
const [yearStr, weekStr] = weekKey.split('-W');
let yearNum = parseInt(yearStr, 10);
let weekNum = parseInt(weekStr, 10);

let prevWeekNum = weekNum - 1;
let prevYearNum = yearNum;
if (prevWeekNum < 1) {
  prevYearNum -= 1;
  prevWeekNum = 52; // simplification
}

let nextWeekNum = weekNum + 1;
let nextYearNum = yearNum;
if (nextWeekNum > 52) {
  nextYearNum += 1;
  nextWeekNum = 1;
}

const prevWeekKey = `${prevYearNum}-W${String(prevWeekNum).padStart(2, '0')}`;
const nextWeekKey = `${nextYearNum}-W${String(nextWeekNum).padStart(2, '0')}`;
---

<WorkerLayout title="Planificación Semanal">
  <header class="flex items-center gap-3 bg-white px-4 py-3 shadow-sm relative z-10">
    <a class="text-zinc-800 p-1 -ml-1" href="/w/planning">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
    </a>
    <h1 class="text-xl font-bold text-zinc-800">Semana {weekStr}</h1>
  </header>

  <div class="p-4 space-y-6">
    <div class="flex items-center justify-between px-2">
      <a href={`?week=${prevWeekKey}`} class="text-[#0284C7] p-2 -ml-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </a>
      <div class="text-center">
        <div class="text-xs text-zinc-500 uppercase tracking-wider">Del {startYmd}</div>
        <div class="text-xs text-zinc-500 uppercase tracking-wider">Al {endYmd}</div>
      </div>
      <a href={`?week=${nextWeekKey}`} class="text-[#0284C7] p-2 -mr-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    </div>

    <div class="space-y-4">
      {days.map((day) => (
        <div class="bg-white rounded-xl shadow-sm border border-zinc-200 overflow-hidden">
          <a href={`/w/day/${day.ymd}`} class="block bg-zinc-50 px-4 py-2 border-b border-zinc-200 flex justify-between items-center hover:bg-zinc-100 transition-colors">
            <h3 class="font-bold text-[#1E3A8A] capitalize">{day.label}</h3>
            <div class="flex items-center gap-2">
              <span class="text-xs font-medium bg-blue-100 text-blue-800 px-2 py-0.5 rounded-full">{day.assignments.length}</span>
              <svg class="text-zinc-400" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </div>
          </a>
          
          <div class="divide-y divide-zinc-100">
            {day.assignments.map((a) => {
              const start = timeToMinutes(a.planned_start) ?? 0;
              const end = timeToMinutes(a.planned_end) ?? 0;
              const durationMin = Math.max(0, end - start);
              const durationStr = formatDuration(durationMin);

              return (
                <div class="p-3 text-sm">
                  <div class="flex justify-between items-start mb-1">
                    <span class="font-bold text-[#4B79A1]">{a.planned_start} - {a.planned_end}</span>
                    <span class="text-xs text-zinc-500 bg-zinc-100 px-2 py-0.5 rounded">{durationStr}</span>
                  </div>
                  <div class="flex gap-2 text-zinc-700">
                    <span class="text-zinc-500">Usr:</span>
                    <span class="font-medium uppercase">{a.user_name}</span>
                  </div>
                </div>
              );
            })}
            
            {day.assignments.length === 0 && (
              <div class="p-4 text-center text-sm text-zinc-400 italic">
                Sin servicios planificados
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="space-y-1 pt-4 px-1 border-t border-zinc-200">
      <div class="flex items-center gap-2">
        <span class="text-[15px] text-zinc-600">Tiempo servicios (Semana):</span>
        <span class="text-[15px] font-bold text-[#1E3A8A]">{totalServiciosStr}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[15px] text-zinc-600">Tiempo actividades:</span>
        <span class="text-[15px] font-bold text-[#1E3A8A]">{totalActividadesStr}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[15px] text-zinc-600">Tiempo desplazamiento:</span>
        <span class="text-[15px] font-bold text-[#1E3A8A]">{totalDesplazamientoStr}</span>
      </div>
    </div>

    <div class="flex items-start gap-3 rounded-lg border border-zinc-200 bg-white p-3 shadow-sm mt-4">
      <div class="text-zinc-500 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
      </div>
      <p class="text-[13px] text-zinc-600 italic leading-snug">
        Este resumen de horas no contiene las horas de ausencia remuneradas
      </p>
    </div>
  </div>
</WorkerLayout>
