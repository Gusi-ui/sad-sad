---
import WorkerLayout from '../../layouts/WorkerLayout.astro';
import { db } from '../../lib/db';
import { datesOfIsoWeek, getIsoWeekKey, toYmd } from '../../lib/dates';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');

const currentWeek = getIsoWeekKey(new Date());
const weekKey = String(Astro.url.searchParams.get('week') ?? currentWeek);
const weekDates = datesOfIsoWeek(weekKey);
if (!weekDates) return Astro.redirect(`/w/week?week=${currentWeek}`);

const startYmd = toYmd(new Date(weekDates[0]));
const endYmd = toYmd(new Date(weekDates[6]));

const assignments = await db()
  .prepare(
    `SELECT a.id, a.date, a.kind, a.planned_start, a.planned_end,
            su.name as user_name
     FROM assignments a
     JOIN service_users su ON su.id = a.service_user_id
     WHERE a.assigned_worker_id = ? AND a.date >= ? AND a.date <= ? AND a.status = 'planned'
     ORDER BY a.date ASC, a.planned_start ASC, su.name ASC`
  )
  .bind(workerId, startYmd, endYmd)
  .all<{ id: string; date: string; kind: string; planned_start: string; planned_end: string; user_name: string }>();

type AssignmentRow = (typeof assignments.results)[number];

const timeToMinutes = (hhmm: string) => {
  const [hRaw, mRaw] = hhmm.split(':');
  const h = Number(hRaw);
  const m = Number(mRaw);
  if (!Number.isFinite(h) || !Number.isFinite(m)) return null;
  if (h < 0 || h > 23 || m < 0 || m > 59) return null;
  return h * 60 + m;
};

const minutesByDate = new Map<string, number>();
for (const a of assignments.results) {
  const start = timeToMinutes(a.planned_start);
  const end = timeToMinutes(a.planned_end);
  if (start === null || end === null) continue;
  minutesByDate.set(a.date, (minutesByDate.get(a.date) ?? 0) + Math.max(0, end - start));
}

const totalWeekMinutes = Array.from(minutesByDate.values()).reduce((acc, v) => acc + v, 0);

const formatMinutes = (minutes: number) => {
  const total = Math.max(0, Math.floor(minutes));
  const h = Math.floor(total / 60);
  const m = total % 60;
  return `${h}h ${String(m).padStart(2, '0')}m`;
};

const days = weekDates.map((d) => {
  const ymd = toYmd(new Date(d));
  const label = new Date(d).toLocaleDateString('es-ES', { weekday: 'short', day: '2-digit', month: '2-digit' });
  return { ymd, label, minutes: minutesByDate.get(ymd) ?? 0 };
});
---

<WorkerLayout title="Semana | SAD" activeTab="week">
  <header class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Semana</h1>
      <p class="mt-1 text-sm text-zinc-600">{weekKey} · {startYmd} → {endYmd}</p>
    </div>
  </header>

  <section class="mt-4 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
    <div class="flex items-center justify-between">
      <div class="text-sm font-semibold">Total planificado</div>
      <div class="text-sm text-zinc-700">{formatMinutes(totalWeekMinutes)}</div>
    </div>
  </section>

  <section class="mt-4">
    <h2 class="text-sm font-semibold text-zinc-900">Por día</h2>
    <div class="mt-3 space-y-2">
      {days.map((day) => (
        <a
          class="flex items-center justify-between rounded-2xl border border-zinc-200 bg-white px-4 py-3 shadow-sm"
          href={`/w/day/${day.ymd}`}
        >
          <div class="text-sm font-medium text-zinc-900">{day.label}</div>
          <div class="text-sm text-zinc-700">{formatMinutes(day.minutes)}</div>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-6">
    <h2 class="text-sm font-semibold text-zinc-900">Servicios</h2>
    <div class="mt-3 space-y-2">
      {assignments.results.map((a: AssignmentRow) => (
        <div class="rounded-2xl border border-zinc-200 bg-white px-4 py-3 text-sm shadow-sm">
          <div class="flex items-center justify-between">
            <div class="font-medium">{a.user_name}</div>
            <div class="text-zinc-700">{a.planned_start}–{a.planned_end}</div>
          </div>
          <div class="mt-1 text-xs text-zinc-500">{a.date} · {a.kind}</div>
        </div>
      ))}
      {assignments.results.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-zinc-300 bg-white p-6 text-sm text-zinc-600">
          No tienes servicios asignados esta semana.
        </div>
      ) : null}
    </div>
  </section>
</WorkerLayout>

