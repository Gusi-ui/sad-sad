---
import WorkerLayout from '../../layouts/WorkerLayout.astro';
import { db } from '../../lib/db';
import { toYmd } from '../../lib/dates';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');

const worker = await db()
  .prepare('SELECT name FROM workers WHERE id = ?')
  .bind(workerId)
  .first<{ name: string }>();

const workerName = worker?.name ?? 'EMPLEADO/A';

const now = new Date();
const year = Number(Astro.url.searchParams.get('year') ?? now.getFullYear());
const month = Number(Astro.url.searchParams.get('month') ?? now.getMonth() + 1); // 1..12
const safeYear = Number.isFinite(year) ? year : now.getFullYear();
const safeMonth = Number.isFinite(month) && month >= 1 && month <= 12 ? month : now.getMonth() + 1;

const monthStart = new Date(Date.UTC(safeYear, safeMonth - 1, 1));
const monthEnd = new Date(Date.UTC(safeYear, safeMonth, 0)); // last day

const startYmd = toYmd(new Date(monthStart));
const endYmd = toYmd(new Date(monthEnd));

const assignments = await db()
  .prepare(
    `SELECT a.date, a.planned_start, a.planned_end
     FROM assignments a
     WHERE a.assigned_worker_id = ?
       AND a.status = 'planned'
       AND a.date >= ? AND a.date <= ?`
  )
  .bind(workerId, startYmd, endYmd)
  .all<{ date: string; planned_start: string; planned_end: string }>();

const formatHoursMins = (minutes: number) => {
  const total = Math.max(0, Math.floor(minutes));
  const h = Math.floor(total / 60);
  const m = total % 60;
  const sign = minutes < 0 ? '-' : '';
  return `${sign}${h} h ${String(m).padStart(2, '0')} min`;
};

const timeToMinutes = (hhmm: string) => {
  const [hRaw, mRaw] = hhmm.split(':');
  const h = Number(hRaw);
  const m = Number(mRaw);
  if (!Number.isFinite(h) || !Number.isFinite(m)) return null;
  if (h < 0 || h > 23 || m < 0 || m > 59) return null;
  return h * 60 + m;
};

const extras = await db()
  .prepare('SELECT date, travel_minutes FROM worker_day_extras WHERE worker_id = ? AND date >= ? AND date <= ?')
  .bind(workerId, startYmd, endYmd)
  .all<{ date: string; travel_minutes: number }>();

const travelByDate = new Map<string, number>(extras.results.map((r) => [r.date, r.travel_minutes ?? 0]));

const contracts = await db()
  .prepare('SELECT hours_per_week, hours_per_month, start_date, end_date FROM worker_contracts WHERE worker_id = ?')
  .bind(workerId)
  .all<{ hours_per_week: number; hours_per_month: number | null; start_date: string; end_date: string | null }>();

const contract = contracts.results.find(c => c.start_date <= endYmd && (!c.end_date || c.end_date >= startYmd));
const monthlyContractHours = contract?.hours_per_month ?? 0; // Si no hay contrato mensual

const assignmentsByDate = new Map<string, Array<{ planned_start: string; planned_end: string }>>();
for (const a of assignments.results) {
  const list = assignmentsByDate.get(a.date) ?? [];
  list.push(a);
  assignmentsByDate.set(a.date, list);
}

let totalServicesMinutes = 0;
let totalBreakMinutes = 0;
let totalTravelMinutes = 0;

const countsByDate = new Map<string, number>();

for (let day = 1; day <= monthEnd.getUTCDate(); day += 1) {
  const d = new Date(Date.UTC(safeYear, safeMonth - 1, day));
  const ymd = toYmd(d);
  
  const dayAssignments = assignmentsByDate.get(ymd) ?? [];
  countsByDate.set(ymd, dayAssignments.length);
  
  let dayServicesMinutes = 0;
  for (const a of dayAssignments) {
    const start = timeToMinutes(a.planned_start);
    const end = timeToMinutes(a.planned_end);
    if (start !== null && end !== null) {
      dayServicesMinutes += Math.max(0, end - start);
    }
  }
  
  const dayTravelMinutes = travelByDate.get(ymd) ?? 0;
  const dayBreakMinutes = dayServicesMinutes > 6 * 60 ? 20 : 0;
  
  totalServicesMinutes += dayServicesMinutes;
  totalTravelMinutes += dayTravelMinutes;
  totalBreakMinutes += dayBreakMinutes;
}

const totalPayableMinutes = totalServicesMinutes + totalBreakMinutes + totalTravelMinutes;
const contractMinutes = monthlyContractHours * 60;
const monthlyDeficitMinutes = totalPayableMinutes - contractMinutes;

const daysInMonth = monthEnd.getUTCDate();
const firstWeekday = monthStart.getUTCDay(); // 0=Dom..6=Sáb
// Adjust so Monday is 0 and Sunday is 6
const firstWeekdayIso = firstWeekday === 0 ? 6 : firstWeekday - 1;

const grid: Array<{ ymd: string | null; day: number | null; count: number; isWeekend: boolean }> = [];

for (let i = 0; i < firstWeekdayIso; i += 1) grid.push({ ymd: null, day: null, count: 0, isWeekend: false });
for (let day = 1; day <= daysInMonth; day += 1) {
  const d = new Date(Date.UTC(safeYear, safeMonth - 1, day));
  const ymd = toYmd(new Date(d));
  const wd = d.getUTCDay();
  grid.push({ ymd, day, count: countsByDate.get(ymd) ?? 0, isWeekend: wd === 0 || wd === 6 });
}
while (grid.length % 7 !== 0) grid.push({ ymd: null, day: null, count: 0, isWeekend: false });

const monthNames = [
  'ENERO', 'FEBRERO', 'MARZO', 'ABRIL', 'MAYO', 'JUNIO',
  'JULIO', 'AGOSTO', 'SEPTIEMBRE', 'OCTUBRE', 'NOVIEMBRE', 'DICIEMBRE'
];
const monthLabel = `${monthNames[safeMonth - 1]} (${safeYear})`;

const prevMonth = safeMonth === 1 ? 12 : safeMonth - 1;
const prevYear = safeMonth === 1 ? safeYear - 1 : safeYear;
const nextMonth = safeMonth === 12 ? 1 : safeMonth + 1;
const nextYear = safeMonth === 12 ? safeYear + 1 : safeYear;

const totalServiciosStr = formatHoursMins(totalServicesMinutes);
const totalBreakStr = formatHoursMins(totalBreakMinutes);
const totalDesplazamientoStr = formatHoursMins(totalTravelMinutes);
const totalStr = formatHoursMins(totalPayableMinutes);
const deficitStr = formatHoursMins(Math.abs(monthlyDeficitMinutes));
const deficitIsPositive = monthlyDeficitMinutes >= 0;

---

<WorkerLayout title="Planificación Mensual">
  <header class="flex items-center gap-3 bg-white px-4 py-3 shadow-sm relative z-10">
    <a class="text-zinc-800 p-1 -ml-1" href="/w/planning">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
    </a>
    <h1 class="text-xl font-bold text-zinc-800">Mensual</h1>
  </header>

  <div class="p-4 space-y-6">
    <div class="rounded bg-[#F8F9FA] border border-zinc-200 p-3">
      <p class="text-sm text-zinc-600">
        Los días marcados contienen uno o varios servicios planificados.
      </p>
    </div>

    <div>
      <div class="text-sm text-zinc-500">Empleado:</div>
      <div class="font-bold text-[#1E3A8A] uppercase tracking-wide">{workerName}</div>
    </div>

    <div class="flex items-center justify-between px-2">
      <a href={`?year=${prevYear}&month=${prevMonth}`} class="text-[#0284C7] p-2 -ml-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </a>
      <div class="font-bold text-zinc-900 text-[15px]">{monthLabel}</div>
      <a href={`?year=${nextYear}&month=${nextMonth}`} class="text-[#0284C7] p-2 -mr-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    </div>

    <div class="bg-white">
      <div class="grid grid-cols-7 mb-2">
        {['L', 'M', 'X', 'J', 'V', 'S', 'D'].map((d) => (
          <div class="text-center text-sm font-medium text-zinc-500">{d}</div>
        ))}
      </div>

      <div class="grid grid-cols-7 gap-[1px] bg-zinc-100 border border-zinc-100">
        {grid.map((cell, index) => {
          if (!cell.ymd) {
            return <div class="bg-white aspect-[4/3]"></div>;
          }

          const col = index % 7;
          const isSunday = col === 6;
          const isSaturday = col === 5;

          let bgClass = "bg-[#8BA8C2]"; // Default blue-gray for weekdays
          let textClass = "text-white";
          
          if (isSunday) {
            bgClass = "bg-[#E3D5C8]"; // Beige/brown for Sundays
            textClass = "text-[#A66E38]";
          } else if (isSaturday) {
            bgClass = "bg-[#A2B9CE]"; // Lighter blue-gray for Saturdays
            textClass = "text-white";
          }

          const hasServices = cell.count > 0;

          return (
            <a 
              href={`/w/day/${cell.ymd}`}
              class={`relative flex items-center justify-center aspect-[4/3] ${bgClass} ${textClass} hover:opacity-90`}
            >
              {hasServices && !isSunday && (
                <div class="absolute top-0 left-0 right-0 h-1.5 bg-[#0052CC]"></div>
              )}
              <span class="text-[15px] font-medium">{cell.day}</span>
            </a>
          );
        })}
      </div>
    </div>

    <div class="space-y-1 pt-2">
      <div class="flex items-center gap-2">
        <span class="text-sm text-zinc-600">Tiempo servicios:</span>
        <span class="text-sm font-semibold text-[#0284C7]">{totalServiciosStr}</span>
      </div>
      {totalBreakMinutes > 0 && (
        <div class="flex items-center gap-2">
          <span class="text-sm text-zinc-600">Descansos (+6h/día):</span>
          <span class="text-sm font-semibold text-emerald-600">+{totalBreakStr}</span>
        </div>
      )}
      <div class="flex items-center gap-2">
        <span class="text-sm text-zinc-600">Tiempo desplazamiento:</span>
        <span class="text-sm font-semibold text-[#0284C7]">{totalDesplazamientoStr}</span>
      </div>
      <div class="flex items-center justify-between pt-2 mt-2 border-t border-zinc-200">
        <span class="text-[15px] font-bold text-zinc-800">Total suma horas:</span>
        <span class="text-[15px] font-bold text-[#0284C7]">{totalStr}</span>
      </div>
      {monthlyContractHours > 0 && (
        <>
          <div class="flex items-center justify-between pt-1">
            <span class="text-[13px] text-zinc-500">Contrato Mensual:</span>
            <span class="text-[13px] font-bold text-zinc-700">{monthlyContractHours} h</span>
          </div>
          <div class="flex items-center justify-between pt-1">
            <span class="text-[13px] text-zinc-500">Balance Mensual:</span>
            <span class={`text-[13px] font-bold ${deficitIsPositive ? 'text-emerald-600' : 'text-red-600'}`}>
              {deficitIsPositive ? '+' : '-'}{deficitStr}
            </span>
          </div>
        </>
      )}
    </div>

    <div class="flex items-start gap-3 rounded-lg border border-zinc-200 bg-white p-3 shadow-sm mt-4">
      <div class="text-zinc-500 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
      </div>
      <p class="text-[13px] text-zinc-600 italic leading-snug">
        Este resumen de horas no contiene las horas de ausencia remuneradas
      </p>
    </div>
  </div>
</WorkerLayout>
