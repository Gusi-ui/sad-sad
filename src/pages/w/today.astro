---
import WorkerLayout from '../../layouts/WorkerLayout.astro';
import { db } from '../../lib/db';
import { getIsoWeekKey, toYmd } from '../../lib/dates';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');

const todayYmd = toYmd(new Date());
const weekKey = getIsoWeekKey(new Date());

const assignments = await db()
  .prepare(
    `SELECT a.id, a.date, a.kind, a.planned_start, a.planned_end,
            su.name as user_name,
            su.address as user_address
     FROM assignments a
     JOIN service_users su ON su.id = a.service_user_id
     WHERE a.assigned_worker_id = ? AND a.date = ? AND a.status = 'planned'
     ORDER BY a.planned_start ASC, su.name ASC`
  )
  .bind(workerId, todayYmd)
  .all<{ id: string; date: string; kind: string; planned_start: string; planned_end: string; user_name: string; user_address: string | null }>();

type AssignmentRow = (typeof assignments.results)[number];

const timeToMinutes = (hhmm: string) => {
  const [hRaw, mRaw] = hhmm.split(':');
  const h = Number(hRaw);
  const m = Number(mRaw);
  if (!Number.isFinite(h) || !Number.isFinite(m)) return null;
  if (h < 0 || h > 23 || m < 0 || m > 59) return null;
  return h * 60 + m;
};

const totalMinutes = assignments.results.reduce((acc, a) => {
  const start = timeToMinutes(a.planned_start);
  const end = timeToMinutes(a.planned_end);
  if (start === null || end === null) return acc;
  return acc + Math.max(0, end - start);
}, 0);

const formatMinutes = (minutes: number) => {
  const total = Math.max(0, Math.floor(minutes));
  const h = Math.floor(total / 60);
  const m = total % 60;
  return `${h}h ${String(m).padStart(2, '0')}m`;
};
---

<WorkerLayout title="Hoy | SAD" activeTab="today">
  <header class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Hoy</h1>
      <p class="mt-1 text-sm text-zinc-600">{todayYmd} · Semana {weekKey}</p>
    </div>
    <form method="post" action="/api/auth/logout">
      <button class="rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm font-medium text-zinc-900">
        Salir
      </button>
    </form>
  </header>

  <section class="mt-4 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
    <div class="flex items-center justify-between">
      <div class="text-sm font-semibold">Resumen</div>
      <div class="text-sm text-zinc-700">{formatMinutes(totalMinutes)}</div>
    </div>
    <p class="mt-2 text-xs text-zinc-500">
      Por ahora el dashboard muestra horas planificadas (fichajes reales vendrán después).
    </p>
  </section>

  <section class="mt-4">
    <h2 class="text-sm font-semibold text-zinc-900">Servicios ({assignments.results.length})</h2>
    <div class="mt-3 space-y-3">
      {assignments.results.map((a: AssignmentRow) => (
        <article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-sm font-semibold">{a.user_name}</div>
              <div class="mt-1 text-xs text-zinc-600">{a.user_address ?? '—'}</div>
            </div>
            <div class="text-right">
              <div class="text-sm font-medium">{a.planned_start}–{a.planned_end}</div>
              <div class="mt-1 text-xs text-zinc-500">{a.kind}</div>
            </div>
          </div>
        </article>
      ))}

      {assignments.results.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-zinc-300 bg-white p-6 text-sm text-zinc-600">
          No tienes servicios asignados hoy.
        </div>
      ) : null}
    </div>
  </section>
</WorkerLayout>

