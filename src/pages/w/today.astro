---
import AppLayout from '../../layouts/AppLayout.astro';
const account = Astro.locals.account;
---

<AppLayout title="Hoy | SAD">
  <div class="mx-auto max-w-xl">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-semibold tracking-tight">Hoy</h1>
        <p class="mt-1 text-sm text-zinc-600">Sesión: {account?.email}</p>
      </div>

      <form method="post" action="/api/auth/logout">
        <button class="rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm font-medium text-zinc-900">
          Salir
        </button>
      </form>
    </div>

    <div class="mt-4 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
      <div class="text-sm font-medium">Agenda (MVP)</div>
      <p class="mt-1 text-sm text-zinc-600">
        En el siguiente paso conectamos la BD y mostramos los servicios asignados del día,
        junto a los botones de fichaje inicio/fin.
      </p>
    </div>
  </div>
</AppLayout>

