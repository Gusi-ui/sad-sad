---
import WorkerLayout from '../../layouts/WorkerLayout.astro';
import { db } from '../../lib/db';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');
const database = db();

const users = await database
  .prepare(
    `SELECT DISTINCT u.id, u.name, u.address, u.phone, u.notes
     FROM service_users u
     JOIN service_templates t ON t.service_user_id = u.id
     WHERE u.active = 1 AND t.preferred_worker_id = ?
     ORDER BY u.name COLLATE NOCASE`
  )
  .bind(workerId)
  .all<{ id: string; name: string; address: string | null; phone: string | null; notes: string | null }>();
---

<WorkerLayout title="Mis usuarios/as">
  <main class="mx-auto max-w-[680px] px-4 pb-28 pt-6">
    <div class="flex items-start justify-between gap-3">
      <div>
        <a class="text-sm font-medium text-zinc-700 underline decoration-zinc-300" href="/w">← Inicio</a>
        <h1 class="mt-2 text-2xl font-bold text-[#1E3A8A]">Mis usuarios/as</h1>
        <p class="mt-1 text-sm text-zinc-600">Listado de usuarios/as asignados a tu planificación.</p>
      </div>
    </div>

    <div class="mt-5 space-y-3">
      {users.results.map((u) => (
        <section class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
          <div class="text-xs uppercase tracking-wider text-zinc-500">Usuario/a</div>
          <div class="mt-1 text-lg font-bold text-zinc-900 uppercase">{u.name}</div>

          <div class="mt-3 grid gap-2 text-sm">
            <div class="flex gap-2">
              <span class="min-w-24 text-zinc-500">Dirección:</span>
              <span class="font-medium text-zinc-800">{u.address ?? '—'}</span>
            </div>
            <div class="flex gap-2">
              <span class="min-w-24 text-zinc-500">Teléfono:</span>
              <span class="font-medium text-zinc-800">{u.phone ?? '—'}</span>
            </div>
            <div class="flex gap-2">
              <span class="min-w-24 text-zinc-500">Notas:</span>
              <span class="font-medium text-zinc-800 whitespace-pre-line">{u.notes ?? '—'}</span>
            </div>
          </div>
        </section>
      ))}

      {users.results.length === 0 && (
        <div class="rounded-2xl border border-zinc-200 bg-white p-4 text-sm text-zinc-500 italic">
          No tienes usuarios/as asignados todavía.
        </div>
      )}
    </div>
  </main>
</WorkerLayout>
