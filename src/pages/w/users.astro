---
import WorkerLayout from '../../layouts/WorkerLayout.astro';
import { db } from '../../lib/db';
import { toYmd } from '../../lib/dates';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');
const database = db();
const todayYmd = toYmd(new Date());

const users = await database
  .prepare(
    `SELECT DISTINCT u.id, u.name, u.address, u.phone, u.notes
     FROM service_users u
     WHERE u.active = 1 AND (
       EXISTS (
         SELECT 1 FROM service_templates t
         WHERE t.service_user_id = u.id AND t.preferred_worker_id = ?
       ) OR EXISTS (
         SELECT 1 FROM assignments a
         WHERE a.service_user_id = u.id
           AND a.assigned_worker_id = ?
           AND a.status != 'done'
           AND a.date >= ?
       )
     )
     ORDER BY u.name COLLATE NOCASE`
  )
  .bind(workerId, workerId, todayYmd)
  .all<{ id: string; name: string; address: string | null; phone: string | null; notes: string | null }>();

const trim = (v: string | null) => (v ?? '').trim();
const formatPhone = (v: string | null) => trim(v) || '—';
const notesPreview = (v: string | null) => {
  const s = trim(v);
  if (!s) return '—';
  return s.length > 96 ? `${s.slice(0, 96)}…` : s;
};
---

<WorkerLayout title="Mis usuarios/as">
  <main class="mx-auto max-w-[680px] px-4 pb-28 pt-6">
    <div class="flex items-start justify-between gap-3">
      <div>
        <a class="text-sm font-medium text-zinc-700 underline decoration-zinc-300" href="/w">← Inicio</a>
        <h1 class="mt-2 text-2xl font-bold text-[#1E3A8A]">Mis usuarios/as</h1>
        <p class="mt-1 text-sm text-zinc-600">Listado de usuarios/as asignados a tu planificación.</p>
      </div>
    </div>

    <div class="mt-5 space-y-3">
      {users.results.map((u) => (
        <a
          class="group block rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm transition hover:-translate-y-[1px] hover:border-[#0284C7]/40 hover:shadow-md active:translate-y-0"
          href={`/w/users/${u.id}`}
        >
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="text-xs uppercase tracking-wider text-zinc-500">Usuario/a</div>
              <div class="mt-1 text-lg font-bold text-zinc-900 uppercase truncate">{u.name}</div>
            </div>
            <div class="mt-1 flex items-center gap-2">
              <span class="rounded-full border border-zinc-200 bg-zinc-50 px-2 py-0.5 text-[11px] font-semibold text-zinc-700">Ver</span>
              <svg class="text-zinc-400 transition group-hover:text-[#0284C7]" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </div>
          </div>

          <div class="mt-3 grid gap-2 text-sm">
            <div class="flex gap-2">
              <span class="min-w-24 text-zinc-500">Dirección:</span>
              <span class="font-medium text-zinc-800 truncate">{trim(u.address) || '—'}</span>
            </div>
            <div class="flex gap-2">
              <span class="min-w-24 text-zinc-500">Teléfono:</span>
              <span class="font-medium text-zinc-800">{formatPhone(u.phone)}</span>
            </div>
            <div class="flex gap-2">
              <span class="min-w-24 text-zinc-500">Notas:</span>
              <span class="font-medium text-zinc-800">{notesPreview(u.notes)}</span>
            </div>
          </div>
        </a>
      ))}

      {users.results.length === 0 && (
        <div class="rounded-2xl border border-zinc-200 bg-white p-4 text-sm text-zinc-500 italic">
          No tienes usuarios/as asignados todavía.
        </div>
      )}
    </div>
  </main>
</WorkerLayout>
