---
import WorkerLayout from '../../../layouts/WorkerLayout.astro';
import { db } from '../../../lib/db';

export const prerender = false;

const account = Astro.locals.account;
const workerId = account?.workerId ?? null;
if (!workerId) return Astro.redirect('/unauthorized');

const { date } = Astro.params;
const dateYmd = String(date ?? '').trim();
if (!/^\d{4}-\d{2}-\d{2}$/.test(dateYmd)) return Astro.redirect('/w/week');

const assignments = await db()
  .prepare(
    `SELECT a.id, a.date, a.kind, a.planned_start, a.planned_end,
            su.name as user_name,
            su.address as user_address
     FROM assignments a
     JOIN service_users su ON su.id = a.service_user_id
     WHERE a.assigned_worker_id = ? AND a.date = ? AND a.status = 'planned'
     ORDER BY a.planned_start ASC, su.name ASC`
  )
  .bind(workerId, dateYmd)
  .all<{ id: string; date: string; kind: string; planned_start: string; planned_end: string; user_name: string; user_address: string | null }>();

type AssignmentRow = (typeof assignments.results)[number];
---

<WorkerLayout title={`Día ${dateYmd} | SAD`} activeTab="week">
  <header>
    <a class="text-sm font-medium text-zinc-700 underline decoration-zinc-300" href="/w/week">← Volver</a>
    <h1 class="mt-2 text-2xl font-semibold tracking-tight">{dateYmd}</h1>
  </header>

  <section class="mt-4">
    <h2 class="text-sm font-semibold text-zinc-900">Servicios ({assignments.results.length})</h2>
    <div class="mt-3 space-y-3">
      {assignments.results.map((a: AssignmentRow) => (
        <article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-sm font-semibold">{a.user_name}</div>
              <div class="mt-1 text-xs text-zinc-600">{a.user_address ?? '—'}</div>
            </div>
            <div class="text-right">
              <div class="text-sm font-medium">{a.planned_start}–{a.planned_end}</div>
              <div class="mt-1 text-xs text-zinc-500">{a.kind}</div>
            </div>
          </div>
        </article>
      ))}

      {assignments.results.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-zinc-300 bg-white p-6 text-sm text-zinc-600">
          No tienes servicios asignados este día.
        </div>
      ) : null}
    </div>
  </section>
</WorkerLayout>

